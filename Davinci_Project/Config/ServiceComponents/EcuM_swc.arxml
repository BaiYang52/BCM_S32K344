                      </POSSIBLE-ERROR-REFS>
                    </CLIENT-SERVER-OPERATION>
                    <CLIENT-SERVER-OPERATION UUID="09b4f8e0-efc7-4f8f-905f-ad0f77831df3">
                      <SHORT-NAME>GetShutdownCause</SHORT-NAME>
                      <DESC>
                        <L-2 L="FOR-ALL">Returns the selected shutdown cause as set by the operation SelectShutdownCause.</L-2>
                      </DESC>
                      <ARGUMENTS>
                        <ARGUMENT-DATA-PROTOTYPE UUID="fc8a29b6-df0d-43df-b1da-a1a656458d41">
