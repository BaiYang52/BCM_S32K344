				<ECUC-MODULE-DEF UUID="cd5d2b77-7c41-4c5b-86d7-ec8d25b5b55e">
					<SHORT-NAME>vBaseEnv</SHORT-NAME>
					<LONG-NAME>
						<L-4 L="EN">Vector Base Environment</L-4>
					</LONG-NAME>
					<DESC>
						<L-2 L="EN">The Vector Base Environment (vBaseEnv) provides everything necessary to get a microcontroller project compiled/linked and performs a basic hardware setup (inlcuding memory init, PLL init, Port init and Watchdog init) in order to get a cyclic runtime behavior.
#vBRS #OS #vLinkGen #Startup
#Vector</L-2>
					</DESC>
					<CATEGORY>VENDOR_SPECIFIC_MODULE_DEFINITION</CATEGORY>
					<ADMIN-DATA>
						<DOC-REVISIONS>
							<DOC-REVISION>
