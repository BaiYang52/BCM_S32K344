								<DATE>2018-06-11</DATE>
								<MODIFICATIONS>
									<MODIFICATION>
										<CHANGE>
											<L-2 L="EN">initial vBaseEnv version</L-2>
										</CHANGE>
										<REASON>
											<L-2 L="EN">new Preconfig and HW-selection concept</L-2>
										</REASON>
									</MODIFICATION>
								</MODIFICATIONS>
							</DOC-REVISION>
						</DOC-REVISIONS>
					</ADMIN-DATA>
