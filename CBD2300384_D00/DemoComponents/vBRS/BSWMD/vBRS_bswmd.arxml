				<ECUC-MODULE-DEF UUID="2a529512-0c79-453f-ba41-bd3983d8a550">
					<SHORT-NAME>vBRS</SHORT-NAME>
					<LONG-NAME>
						<L-4 L="EN">Basic Runtime System</L-4>
					</LONG-NAME>
					<DESC>
						<L-2 L="EN">The Vector Basic Runtime System (vBRS) provides functionality to initialize a microcontrollers' memory, PLL, Ports and Watchdog. It also provides startup code and functionalities for basic initialization and handling of the different Vector Software stacks.
It is part of the vBaseEnv.
For internal development and external use.
#vBaseEnv #Startup
#Vector</L-2>
					</DESC>
					<CATEGORY>VENDOR_SPECIFIC_MODULE_DEFINITION</CATEGORY>
