								<ECUC-BOOLEAN-PARAM-DEF UUID="c710f131-ad37-47b5-b725-f0c8fe35db82">
									<SHORT-NAME>vBRSEnableEcuMStubGeneration</SHORT-NAME>
									<LONG-NAME>
										<L-4 L="EN">Generation of EcuM Stub</L-4>
									</LONG-NAME>
