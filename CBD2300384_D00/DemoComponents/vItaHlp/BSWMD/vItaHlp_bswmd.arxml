							<POST-BUILD-CHANGEABLE>false</POST-BUILD-CHANGEABLE>
							<REFERENCES>
								<ECUC-REFERENCE-DEF UUID="9d998c9a-2f69-4fac-b88a-d7b1a4b189ed">
									<SHORT-NAME>vItaHlpTestComSpinlockRef</SHORT-NAME>
									<DESC>
										<L-2 L="EN">The reference to an OS Spinlock which is used to control the access to the vItaHlp event handler from tasks running on different cores.
The OS Spinlock is not needed for tests in a single core environment.</L-2>
									</DESC>
									<ADMIN-DATA>
