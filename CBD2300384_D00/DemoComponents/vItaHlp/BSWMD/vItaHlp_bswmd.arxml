												</ECUC-REFERENCE-DEF>
											</REFERENCES>
											<SUB-CONTAINERS>
												<ECUC-PARAM-CONF-CONTAINER-DEF UUID="a4994ee4-b0b6-42d2-b4a6-f0e817a79a57">
													<SHORT-NAME>vItaHlpFlsStandardTestTestElement</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">StandardTest - TestElement</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">Definition of test element parameters used for the Fls test.
Add a container for each test element.</L-2>
													</DESC>
													<ADMIN-DATA>
														<SDGS>
															<SDG GID="DV:CfgPostBuild">
																<SD GID="DV:postBuildSelectableChangeable">false</SD>
																<SD GID="DV:postBuildNotDeletable">false</SD>
															</SDG>
														</SDGS>
													</ADMIN-DATA>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
													<POST-BUILD-CHANGEABLE>false</POST-BUILD-CHANGEABLE>
													<PARAMETERS>
														<ECUC-INTEGER-PARAM-DEF UUID="61526452-e4fe-45e6-a56d-03141c0c12f5">
															<SHORT-NAME>vItaHlpFlsStandardTestTestElementStartPage</SHORT-NAME>
															<LONG-NAME>
																<L-4 L="EN">Start Page</L-4>
															</LONG-NAME>
															<DESC>
																<L-2 L="EN">The index of the page of a flash memory area, which is used for the test. The index 0 denotes the first page of the first sector. The index is unique over all flash pages of the Unit Under Test (FlsSector).</L-2>
															</DESC>
															<ADMIN-DATA>
																<SDGS>
																	<SDG GID="DV:CfgPostBuild">
																		<SD GID="DV:variantMultiplicityPBL">false</SD>
																	</SDG>
																</SDGS>
															</ADMIN-DATA>
															<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
															<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
															<IMPLEMENTATION-CONFIG-CLASSES>
																<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
																	<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
																	<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
																</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
															</IMPLEMENTATION-CONFIG-CLASSES>
															<ORIGIN>Vector Informatik</ORIGIN>
															<REQUIRES-INDEX>false</REQUIRES-INDEX>
															<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
															<DEFAULT-VALUE>0</DEFAULT-VALUE>
															<MIN>0</MIN>
														</ECUC-INTEGER-PARAM-DEF>
														<ECUC-INTEGER-PARAM-DEF UUID="762bafe3-bdb4-4771-a9f9-f046d948a5b8">
															<SHORT-NAME>vItaHlpFlsStandardTestTestElementNumberOfPages</SHORT-NAME>
															<LONG-NAME>
																<L-4 L="EN">Number of Pages</L-4>
															</LONG-NAME>
															<DESC>
																<L-2 L="EN">The number of consecutive flash pages, used for the test.
The maximum number of flash pages is given by the number of configured flash sectors (FlsNumberOfSectors), the size of a flash sector (FlsSectorSize) and the size of a flash page (FlsPageSize) as:
max number of pages = FlsNumberOfSectors * FlsSectorSize / FlsPageSize</L-2>
															</DESC>
															<ADMIN-DATA>
																<SDGS>
																	<SDG GID="DV:CfgPostBuild">
