										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="4551378b-c30f-4832-8fc5-54edae43be1a">
											<SHORT-NAME>vItaHlpWdgTestConfig</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Definition of parameters used for the vItaHlp WDG module tests.</L-2>
											</DESC>
											<ADMIN-DATA>
