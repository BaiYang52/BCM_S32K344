							<SUB-CONTAINERS>
								<ECUC-CHOICE-CONTAINER-DEF UUID="7741e6e1-54cc-4693-8836-353638a1e7ef">
									<SHORT-NAME>vItaHlpTestComLinkLayer</SHORT-NAME>
									<DESC>
										<L-2 L="EN">Select the link layer used for the test communication.</L-2>
									</DESC>
									<ADMIN-DATA>
