												<SD GID="DV:postBuildSelectableChangeable">false</SD>
												<SD GID="DV:postBuildNotDeletable">false</SD>
											</SDG>
										</SDGS>
									</ADMIN-DATA>
									<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
									<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
									<POST-BUILD-CHANGEABLE>false</POST-BUILD-CHANGEABLE>
									<CHOICES>
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="8b74a121-61bb-4c69-9c87-94749d8e76eb">
											<SHORT-NAME>vItaHlpTestComTcm</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Definition of parameters used for test control communication via TCM module.

Note:
This container contains only the configuration parameters needed for vItaHlp for the test communication via TCM.
The configuration and setup of the TCM module needs further manual steps which are described in the Technical Reference of the TCM.</L-2>
											</DESC>
											<ADMIN-DATA>
												<SDGS>
													<SDG GID="DV:CfgPostBuild">
														<SD GID="DV:postBuildSelectableChangeable">false</SD>
														<SD GID="DV:postBuildNotDeletable">false</SD>
													</SDG>
												</SDGS>
											</ADMIN-DATA>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
											<POST-BUILD-CHANGEABLE>false</POST-BUILD-CHANGEABLE>
											<PARAMETERS>
												<ECUC-STRING-PARAM-DEF UUID="bfa40efb-9a02-464a-b2e6-0132de7c1058">
													<SHORT-NAME>vItaHlpTcmCanoeChannelName</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Canoe Channel Name</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">Set the name as configured in the CANoe network.
Do not use CANoe keywords (CAN1...CAN32) as channel name. Generally avoid using similar constructs like CAN0, CAN00, etc. for channel names.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<IMPLEMENTATION-CONFIG-CLASSES>
														<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
															<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
															<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
														</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
													</IMPLEMENTATION-CONFIG-CLASSES>
													<ORIGIN>Vector Informatik</ORIGIN>
													<REQUIRES-INDEX>false</REQUIRES-INDEX>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL>
															<MIN-LENGTH>1</MIN-LENGTH>
														</ECUC-STRING-PARAM-DEF-CONDITIONAL>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
											</PARAMETERS>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="1e8d1a44-e34a-4502-9d2c-6e7f05c461a8">
											<SHORT-NAME>vItaHlpTestComCan</SHORT-NAME>
											<ADMIN-DATA>
												<SDGS>
													<SDG GID="DV:CfgPostBuild">
														<SD GID="DV:postBuildSelectableChangeable">false</SD>
														<SD GID="DV:postBuildNotDeletable">false</SD>
													</SDG>
												</SDGS>
											</ADMIN-DATA>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
											<POST-BUILD-CHANGEABLE>false</POST-BUILD-CHANGEABLE>
											<PARAMETERS>
												<ECUC-STRING-PARAM-DEF UUID="91f1e8c6-f380-4c9f-ac9a-4e220aabcfc5">
													<SHORT-NAME>vItaHlpCanCanoeChannelName</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Canoe Channel Name</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">Set the name as configured in the CANoe network.
Do not use CANoe keywords (CAN1...CAN32) as channel name. Generally avoid using similar constructs like CAN0, CAN00, etc. for channel names.

Note: Please take care that the Canoe Channel names are consistent (e.g. use the same Canoe Channel name if TestCom and CAN Test Module references the same CAN Controller). </L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<IMPLEMENTATION-CONFIG-CLASSES>
														<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
															<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
															<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
														</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
													</IMPLEMENTATION-CONFIG-CLASSES>
													<ORIGIN>Vector Informatik</ORIGIN>
													<REQUIRES-INDEX>false</REQUIRES-INDEX>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL>
															<MIN-LENGTH>1</MIN-LENGTH>
														</ECUC-STRING-PARAM-DEF-CONDITIONAL>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
											</PARAMETERS>
											<REFERENCES>
												<ECUC-REFERENCE-DEF UUID="06797ba2-5018-4555-ace2-80f8c8a56ef7">
													<SHORT-NAME>vItaHlpCanControllerRef</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">CAN Controller Ref</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">The reference to the CAN Controller, which shall be used for the test communication.
Following CAN-IDs are used for the test communication:
- Tx CAN ID: 0
- Rx CAN ID: 1

It must be ensured, that an Rx Basic Hardware Object for the referenced CAN Controller is available, which can receive the specified CAN ID.</L-2>
													</DESC>
