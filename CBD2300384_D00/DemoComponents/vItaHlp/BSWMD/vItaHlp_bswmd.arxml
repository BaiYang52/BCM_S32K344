													<DEFAULT-VALUE>true</DEFAULT-VALUE>
												</ECUC-BOOLEAN-PARAM-DEF>
												<ECUC-BOOLEAN-PARAM-DEF UUID="745895d2-c553-41f9-b395-665d1ee11864">
													<SHORT-NAME>vItaHlpFlsStandardTestFlsEraseAndBlankCheck</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Standard Test - Flash Erase and BlankCheck</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">Enables the Flash Erase and BlankCheck test for the Unit Under Test (FlsSector).
Disable this test, in case the Fls_BlankCheck API is not supported at all by the DUT, or in case the Fls_BlankCheck API is disabled for the given Fls driver module. 
Requires the following APIs from the Fls module to be enabled:
   - /Fls/FlsGeneral/FlsGetJobResultApi</L-2>
													</DESC>
													<ADMIN-DATA>
														<SDGS>
															<SDG GID="DV:CfgPostBuild">
																<SD GID="DV:variantMultiplicityPBL">false</SD>
															</SDG>
														</SDGS>
													</ADMIN-DATA>
