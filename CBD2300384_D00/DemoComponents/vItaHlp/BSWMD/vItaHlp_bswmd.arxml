											<PARAMETERS>
												<ECUC-BOOLEAN-PARAM-DEF UUID="5b17c2f8-5735-484a-9ba7-fa9f332a4c99">
													<SHORT-NAME>vItaHlpWdgStandardTestImmediateReset</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Standard Test - Immediate Reset</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">Enables the WDG Immediate Reset test.</L-2>
													</DESC>
													<ADMIN-DATA>
														<SDGS>
															<SDG GID="DV:CfgPostBuild">
																<SD GID="DV:variantMultiplicityPBL">false</SD>
															</SDG>
														</SDGS>
													</ADMIN-DATA>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<IMPLEMENTATION-CONFIG-CLASSES>
														<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
															<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
															<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
														</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
													</IMPLEMENTATION-CONFIG-CLASSES>
													<ORIGIN>Vector Informatik</ORIGIN>
													<REQUIRES-INDEX>false</REQUIRES-INDEX>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<DEFAULT-VALUE>true</DEFAULT-VALUE>
												</ECUC-BOOLEAN-PARAM-DEF>
												<ECUC-BOOLEAN-PARAM-DEF UUID="8098e339-29cb-44f0-a981-40a94ed736d9">
													<SHORT-NAME>vItaHlpWdgStandardTestTimingResetSlow</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Standard Test - Timing Reset Slow</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">Enables the WDG test to verify the timing conditions of the watchdog driver.
For this test, the watchdog hardware is configured with a long timeout period (Slow-Mode).
The test can be enabled, if the HW derivative
   - Supports Slow-Mode AND
   - Slow-Mode is configured as default mode OR switching to Slow-Mode is supported during runtime.</L-2>
													</DESC>
													<ADMIN-DATA>
														<SDGS>
															<SDG GID="DV:CfgPostBuild">
																<SD GID="DV:variantMultiplicityPBL">false</SD>
															</SDG>
														</SDGS>
													</ADMIN-DATA>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<IMPLEMENTATION-CONFIG-CLASSES>
														<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
															<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
															<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
														</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
													</IMPLEMENTATION-CONFIG-CLASSES>
													<ORIGIN>Vector Informatik</ORIGIN>
													<REQUIRES-INDEX>false</REQUIRES-INDEX>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<DEFAULT-VALUE>true</DEFAULT-VALUE>
												</ECUC-BOOLEAN-PARAM-DEF>
												<ECUC-BOOLEAN-PARAM-DEF UUID="5484d02c-88f1-4e55-b41f-945dd742417a">
													<SHORT-NAME>vItaHlpWdgStandardTestTimingResetFast</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Standard Test - Timing Reset Fast</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">Enables the WDG test to verify the timing conditions of the watchdog driver.
For this test, the watchdog hardware is configured with a short timeout period (Fast-Mode).
The test can be enabled, if the HW derivative
   - Supports Fast-Mode AND
   - Fast-Mode is configured as default mode OR switching to Fast-Mode is supported during runtime.</L-2>
													</DESC>
													<ADMIN-DATA>
														<SDGS>
															<SDG GID="DV:CfgPostBuild">
																<SD GID="DV:variantMultiplicityPBL">false</SD>
															</SDG>
														</SDGS>
													</ADMIN-DATA>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<IMPLEMENTATION-CONFIG-CLASSES>
														<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
															<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
															<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
														</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
													</IMPLEMENTATION-CONFIG-CLASSES>
													<ORIGIN>Vector Informatik</ORIGIN>
													<REQUIRES-INDEX>false</REQUIRES-INDEX>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<DEFAULT-VALUE>true</DEFAULT-VALUE>
												</ECUC-BOOLEAN-PARAM-DEF>
												<ECUC-BOOLEAN-PARAM-DEF UUID="8e0aaa63-88f0-4e7e-a3c7-f084e24da350">
													<SHORT-NAME>vItaHlpWdgStandardTestDisableAllowed</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Standard Test - Disable Allowed</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">Enables the WDG test to verify, if disabling of the watchdog driver is allowed.
Enable this test, if switching from Fast-Mode or Slow-Mode to Off-Mode is supported during runtime.</L-2>
													</DESC>
													<ADMIN-DATA>
														<SDGS>
															<SDG GID="DV:CfgPostBuild">
																<SD GID="DV:variantMultiplicityPBL">false</SD>
															</SDG>
														</SDGS>
													</ADMIN-DATA>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<IMPLEMENTATION-CONFIG-CLASSES>
														<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
															<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
															<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
														</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
													</IMPLEMENTATION-CONFIG-CLASSES>
													<ORIGIN>Vector Informatik</ORIGIN>
													<REQUIRES-INDEX>false</REQUIRES-INDEX>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<DEFAULT-VALUE>true</DEFAULT-VALUE>
												</ECUC-BOOLEAN-PARAM-DEF>
												<ECUC-INTEGER-PARAM-DEF UUID="6a38b76c-97e1-4cfc-b9cb-7156b73487c1">
