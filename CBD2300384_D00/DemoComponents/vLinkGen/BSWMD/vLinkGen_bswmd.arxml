												<ECUC-CHOICE-REFERENCE-DEF UUID="5751946f-bec9-4c43-92ca-7f86e72172c1">
													<SHORT-NAME>vLinkGenVarSectionGroupRef</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Sections</L-4>
													</LONG-NAME>
													<DESC>
