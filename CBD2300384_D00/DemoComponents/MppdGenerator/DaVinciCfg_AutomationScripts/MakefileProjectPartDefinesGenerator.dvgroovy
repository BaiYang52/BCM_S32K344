    private static String mcalExcludeList()
    {
        String templ =  "#------------------------------------------------------------------------------\n" +
                        "#------------------------- MUST be filled out ---------------------------------\n" +
                        "# Define MCAL modules that shall be excluded from build\n" +
                        "#------------------------------------------------------------------------------\n" +
                        "MCAL_EXCLUDE_ADC    = 0\n" +
                        "MCAL_EXCLUDE_CRC    = 0\n" +
                        "MCAL_EXCLUDE_DIO    = 0\n" +
                        "MCAL_EXCLUDE_EEP    = 0\n" +
                        "MCAL_EXCLUDE_FLS    = 0\n" +
                        "MCAL_EXCLUDE_GPT    = 0\n" +
                        "MCAL_EXCLUDE_ICU    = 0\n" +
                        "MCAL_EXCLUDE_MCU    = 0\n" +
                        "MCAL_EXCLUDE_OCU    = 0\n" +
                        "MCAL_EXCLUDE_PORT   = 0\n" +
                        "MCAL_EXCLUDE_PWM    = 0\n" +
                        "MCAL_EXCLUDE_SPI    = 0\n" +
                        "MCAL_EXCLUDE_WDG    = 0\n" +
                        "MCAL_EXCLUDE_FEE    = 0\n" +
                        "MCAL_EXCLUDE_CRY    = 1\n" +
                        "MCAL_EXCLUDE_FLSTST = 1\n" +
                        "MCAL_EXCLUDE_RAMTST = 1\n" +
                        "MCAL_EXCLUDE_CORTST = 1\n" +
                        // Mcu_Platform Rh850 -----------------------------------------------------------------------------
                        (Controller == "Rh850" ?
                            "MCAL_EXCLUDE_WDG_DRIVER_A  = 0\n" +
                            "MCAL_EXCLUDE_WDG_DRIVER_B  = 1\n" +
                            "MCAL_EXCLUDE_WDG_DRIVER_C  = 1\n"
                        :
                            ""
                        ) +
                        "\n"

        return templ
    }

    private static String e2eLibSwitches()
    {
        return """
#------------------------------------------------------------------------------
#------------------------- MUST be filled out ---------------------------------
# Define the E2E Library Profiles that shall be used
# E2E configuration for SysService_E2eLib@Make after version 1.03.00
# ATTENTION: All profiles are deactivated, those have to be manually configured
#------------------------------------------------------------------------------
E2E_USE_PROFILE_01   = 0
E2E_USE_PROFILE_02   = 0
E2E_USE_PROFILE_04   = 0
E2E_USE_PROFILE_05   = 0
E2E_USE_PROFILE_06   = 0
E2E_USE_PROFILE_07   = 0
E2E_USE_PROFILE_08   = 0
E2E_USE_PROFILE_11   = 0
E2E_USE_PROFILE_22   = 0
E2E_USE_PROFILE_44   = 0
E2E_USE_PROFILE_JLR  = 0

"""
    }

    private static String linTpSwitch()
    {
        DefRef defRefAsrLinTp = DefRef.create(DefRef.MICROSAR_PACKAGE, "LinTp")
        return """
#------------------------------------------------------------------------------
#------------------------- MUST be filled out ---------------------------------
# Define if the LinTp functionality shall be supported by the LinIf
#------------------------------------------------------------------------------
LINIF_USE_LINTP    = """ + (activeProject {defRefAsrLinTp.hasValidDefinition(getInstance(IProjectContext))} ? "1" : "0") + "\n"
    }

    /********************/
    /* MODULE TEMPLATES */
    /********************/
    static String moduleAutosar()
    {
        String moduleList = "", usedList = "", pathList = "", templ

        for(component in packagesAsrMake)
        {
            moduleList += moduleListData(component.componentName)
            usedList += moduleUsed(component.componentName)
            pathList += modulePath(component)
        }

        templ = moduleList +
                "\n" +
                usedList +
                "\n" +
                pathList

        // GenTool Geny and "external\BSW\Mcal_" outdated
        return templ
    }

    private static String moduleListData(String packageName)
    {
        return writeVar("MODULE_LIST_PROJECT", "+=", packageName.toUpperCase())
    }

    private static String moduleUsed(String componentName)
    {
        String templ
        if(!componentName.startsWith("FblDrvFlash_"))
        {
            templ = writeVar(componentName.toUpperCase() + "_USED", "=", "1")
        }
        else
        {
            templ = writeVar(componentName.toUpperCase() + "_USED", "=", "0")
        }

        return templ
    }

    private static String modulePath(Component component)
    {
        return writeVar(component.componentName.toUpperCase() + "_PATH", "=", component.path)
    }

    /*************************/
    /* APPLICATION TEMPLATES */
    /*************************/

    static String application()
    {
        String templ = ""

        templ += applicationIncludeList()

        return templ
    }

    private static String applicationIncludeList()
    {
        String templ =  "# additional application include directories\n" +
                        writeVar("ADDITIONAL_INCLUDES", "+=", "Include", 0) +
                        (packagesAsrMake.find({it.componentName.startsWith("Vtt")}) ?
                            writeVar("ADDITIONAL_INCLUDES", "+=", "IncludeHw", 0)
                        :
                            ""
                        ) +
                        "\n" +
                        "# application source files\n" +
                        applicationSourceFilesStatic() +
                        applicationSourceFiles()
        return templ
    }

    /* *IMPORTANT* the application generation differs drastically from the xslt template, because it can be heavily simplified with the new information */

    private static String applicationSourceFilesStatic()
    {
        String templ =  (evaluateXPath("CANbeddedVersionInfo/ComponentCheck/Component[@Project=\"SysService_Asr4EcuM\" or @Project=\"SysService_AsrEcuM\"]") ?
                            writeVar("APP_SOURCE_LST", "+=", "Source\\EcuM_Callout_Stubs.c", 0)
                        :
                            ""
                        ) +
                        (evaluateXPath("CANbeddedVersionInfo/ComponentCheck/Component[@Project=\"SysService_Asr4BswMCfg5\"]") ?
                            writeVar("APP_SOURCE_LST", "+=", "Source\\BswM_Callout_Stubs.c", 0)
                        :
                            ""
                        ) +
                        (evaluateXPath("CANbeddedVersionInfo/ComponentCheck/Component[@Project=\"Os_CoreGen7\"]") ?
                            writeVar("APP_SOURCE_LST", "+=", "Source\\Os_Callout_Stubs.c", 0)
                        :
                            ""
                        )
        return templ
    }

    private static String applicationSourceFiles()
    {
        String templ = ""
        for(component in ApplComponents)
        {
            templ += writeVar("APP_SOURCE_LST", "+=", component.path, 0)
        }
        return templ
    }


    /*********************************/
    /* STRING MANIPULATION FUNCTIONS */
    /*********************************/
    private static String writeVar(String varName, String operator, String varContent, int varPad=64)
    {
        return (pad(varName, varPad) + " " + operator + " " + varContent + "\n")
    }

    // extends a given string to a specified length with ' '
    private static String pad(String string, int length)
    {
        while(string.length() < length)
        {
            string += " "
        }
        return string
    }

