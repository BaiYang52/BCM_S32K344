//    }

    static String sectionComment(String sectionName)
    {
        String templ =  "###############################################################################\n" +
                        "#  "+ sectionName + "\n" +
                        "###############################################################################\n"
        return templ
    }

    /********************/
    /* GETTER FUNCTIONS */
    /********************/
    static String getMakeSupportType(){
        return MakeSupportType
    }

    static String getSipFolderStructure(){
        return SipFolderStructure
    }

    /**************************/
    /* XQuery/XPath FUNCTIONS */
    /**************************/
    /**
     * @brief Evaluates a XPath and returns the results
     * @param document Document on which the XPath should be evaluated
     * @param xpathExpression The expression to evaluate
     * @return List of results as strings
     * @throws Exception
     */
    private static List<String> evaluateXPath(String xpathExpression) throws Exception
    {
        // Create XPathFactory object
        XPathFactory xpathFactory = XPathFactory.newInstance()

        // Create XPath object
        XPath xpath = xpathFactory.newXPath()

        List<String> values = new ArrayList<>()
        try
        {
            // Create XPathExpression object
            XPathExpression expr = xpath.compile(xpathExpression)

            // Evaluate expression result on XML document
            NodeList nodes = (NodeList) expr.evaluate(xmlDoc, XPathConstants.NODESET)

            for (int i = 0; i < nodes.getLength(); i++) {
                values.add(nodes.item(i).getNodeValue())
            }
        } catch (XPathExpressionException e) {
            e.printStackTrace()
        }
        return values
    }

    private static boolean evaluateXPathBool(String xpathExpression) throws Exception
    {
        boolean retVal
        // Create XPathFactory object
        XPathFactory xpathFactory = XPathFactory.newInstance()

        // Create XPath object
        XPath xpath = xpathFactory.newXPath()

        try
        {
            // Create XPathExpression object
            XPathExpression expr = xpath.compile(xpathExpression)

            // Evaluate expression result on XML document
            retVal = expr.evaluate(xmlDoc, XPathConstants.BOOLEAN)

        } catch (XPathExpressionException e) {
            e.printStackTrace()
            retVal = false
        }
        return retVal
    }

    /**
     * @brief Loads the Document
     * @param fileName Filename/Path to load
     * @return The file as a Document
     * @throws Exception
     */
    private static Document getDocument(String fileName) throws Exception
    {
        DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance()
        factory.setNamespaceAware(true)
        DocumentBuilder builder = factory.newDocumentBuilder()
        Document doc = builder.parse(fileName)
        return doc
    }
}

//daVinci enables the IDE code completion support
daVinci {
    /*
     * Task: CreateMakefileProjectPartDefines
     * Type: DV_APPLICATION
     */
    scriptTask("CreateMakefileProjectPartDefines", DV_APPLICATION) {
        taskDescription 'Creates the file Makefile.project.part.defines based on the current project'

        code{
            /****************/
            /* Prerequisite */
            /****************/
            final String versionInfoPath = paths.resolveSipPath("Doc/DeliveryInformation/version.info")
            scriptLogger.debug(versionInfoPath)

            Template templ = new Template(versionInfoPath, paths.getDpaProjectFolder().resolve("Appl"), paths.getSipRootFolder())

            // Create new file/truncate existing to zero
            PrintWriter writer = new PrintWriter(paths.getDpaProjectFolder().resolve("Appl").resolve("_Makefile.project.part.defines").toString(), "UTF-8")

            /**************/
            /* Parameters */
            /**************/
            String selectedApplication = "StartAppl" // assumption: always 'StartAppl'

            /**********************************************************************************************************/
            /*****************************************     Templates     **********************************************/
            /**********************************************************************************************************/

            /*****************/
            /* Main Template */
            /*****************/

            String MakeSupportType = templ.getMakeSupportType()
            String SipFolderStructure = templ.getSipFolderStructure()

            String MainTempl =
                    templ.sectionComment("Makefile.project.part.defines") +
                            "\n" +
                            "# MakeSupport type: " + MakeSupportType + "\n" +
                            "# Derived product: Microsar4\n" +
                            "# Folder structure: " + SipFolderStructure + "\n" +
                            templ.staticShared() +
                            "\n" +
                            templ.staticAutosar() +
                            "\n" +
                            templ.sectionComment( "Modules") +
                            "\n" +
                            templ.moduleAutosar() +
                            "\n" +
                            (selectedApplication ?
                                    templ.sectionComment("Application (" + selectedApplication + ")") +
                                            templ.application()
                                    :
                                    templ.sectionComment("Application (no application selected)")
                            )
            // TODO: count(swcp:swcp/attributes:attributeassignments/attributes:attributeassignment[@attributes:attribute='Program' and @attributes:value='MSR_Ford_SLP1']) != 0

            writer.println(MainTempl)

            writer.close()
        }
    }


}