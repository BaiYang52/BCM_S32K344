        <SPEC-OBJECT IDENTIFIER="id-f5e564fe2cd5074aa7ca05eabd4ff51d" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="75113519ab0cd313b8812874a0f95d8efeb8a40b0046e69831a429cd41bd4ee7">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="75113519ab0cd313b8812874a0f95d8efeb8a40b0046e69831a429cd41bd4ee7">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
