        <SPEC-OBJECT IDENTIFIER="id-31e5c7bfe6fbbec308c0e4f1299986ef" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="9be9ce96899c9bad845b4635ea809a2fc12da823e8466e46707b4483012e6bf5">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="9be9ce96899c9bad845b4635ea809a2fc12da823e8466e46707b4483012e6bf5">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
The user of MICROSAR Safe shall verify that for each core with ID <xhtml:em>WDGM_NR_OF_TRIGGER_MODES_CORE&lt;ID></xhtml:em> matches the actual number of configured Watchdog Manager Trigger Modes.
<xhtml:br/>
The define can be found in <xhtml:em>WdgM_Cfg.h</xhtml:em>.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
