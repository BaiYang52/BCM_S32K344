        <SPEC-OBJECT IDENTIFIER="id-7541cf9c0627d2a685404711ea63a901" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="5ce44b6f9b2d4c8e496a170084cf8c2aed471d1a8dbd6d5195f759f60193042b">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="5ce44b6f9b2d4c8e496a170084cf8c2aed471d1a8dbd6d5195f759f60193042b">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>This component assumes the following safety requirements:</xhtml:p>
<xhtml:table>
                      <xhtml:tbody>
                        <xhtml:tr>
                          <xhtml:th> ID </xhtml:th>
                          <xhtml:th> Safety Requirement </xhtml:th>
                          <xhtml:th> Associated TSR </xhtml:th>
                          <xhtml:th> ASIL </xhtml:th>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102743</xhtml:td>
                          <xhtml:td>WdgM shall provide a service to initialize itself.</xhtml:td>
                          <xhtml:td>TSR-1</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102747</xhtml:td>
                          <xhtml:td>WdgM shall provide Supervised Entities.</xhtml:td>
                          <xhtml:td>TSR-14,TSR-15,TSR-13</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102748</xhtml:td>
                          <xhtml:td>WdgM shall provide Checkpoints.</xhtml:td>
                          <xhtml:td>TSR-15,TSR-14,TSR-13</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102746</xhtml:td>
                          <xhtml:td>WdgM shall provide a mechanism for Alive Supervision.</xhtml:td>
                          <xhtml:td>TSR-14</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102745</xhtml:td>
                          <xhtml:td>WdgM shall provide a mechanism for Deadline Supervision.</xhtml:td>
                          <xhtml:td>TSR-15</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102744</xhtml:td>
                          <xhtml:td>WdgM shall provide a mechanism for Logical Supervision.</xhtml:td>
                          <xhtml:td>TSR-13</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102749</xhtml:td>
                          <xhtml:td>WdgM shall provide a service to trigger a checkpoint.</xhtml:td>
                          <xhtml:td>TSR-13,TSR-15,TSR-14</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102754</xhtml:td>
                          <xhtml:td>WdgM shall provide a service to activate the supervision of a Supervised Entity.</xhtml:td>
                          <xhtml:td>TSR-13,TSR-15,TSR-14</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102755</xhtml:td>
                          <xhtml:td>WdgM shall provide a service to deactivate the supervision of a Supervised Entity.</xhtml:td>
                          <xhtml:td>TSR-14,TSR-13,TSR-15</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102763</xhtml:td>
                          <xhtml:td>WdgM shall provide a service to cyclically update the global supervision status.</xhtml:td>
                          <xhtml:td>TSR-14,TSR-13,TSR-15</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102756</xhtml:td>
                          <xhtml:td>WdgM shall provide modes.</xhtml:td>
                          <xhtml:td>TSR-15,TSR-14,TSR-13</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102758</xhtml:td>
                          <xhtml:td>WdgM shall provide a service to set a new trigger mode.</xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102764</xhtml:td>
                          <xhtml:td>WdgM shall provide a global status DEACTIVATED.</xhtml:td>
                          <xhtml:td>TSR-14,TSR-13,TSR-15</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102765</xhtml:td>
                          <xhtml:td>WdgM shall provide a global status OK.</xhtml:td>
                          <xhtml:td>TSR-14,TSR-15,TSR-13</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102766</xhtml:td>
                          <xhtml:td>WdgM shall provide a global status FAILED.</xhtml:td>
                          <xhtml:td>TSR-15,TSR-14,TSR-13</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102767</xhtml:td>
                          <xhtml:td>WdgM shall provide a global status EXPIRED.</xhtml:td>
                          <xhtml:td>TSR-15,TSR-14,TSR-13</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102768</xhtml:td>
                          <xhtml:td>WdgM shall provide a global status STOPPED.</xhtml:td>
                          <xhtml:td>TSR-14,TSR-13,TSR-15</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102769</xhtml:td>
                          <xhtml:td>WdgM shall provide a supervised entity status DEACTIVATED.</xhtml:td>
                          <xhtml:td>TSR-14,TSR-13,TSR-15</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102770</xhtml:td>
                          <xhtml:td>WdgM shall provide a supervised entity status OK.</xhtml:td>
                          <xhtml:td>TSR-14,TSR-15,TSR-13</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102771</xhtml:td>
                          <xhtml:td>WdgM shall provide a supervised entity status FAILED.</xhtml:td>
                          <xhtml:td>TSR-15,TSR-13,TSR-14</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-102772</xhtml:td>
                          <xhtml:td>WdgM shall provide a supervised entity status EXPIRED.</xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15</xhtml:td>
                          <xhtml:td> ASIL D </xhtml:td>
                        </xhtml:tr>
                      </xhtml:tbody>
                    </xhtml:table>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
