        <SPEC-OBJECT IDENTIFIER="id-baf6d364ff57a77a6c7764ba129ae640" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="98951a66fe8c0918a7a5d4e119334fe85c33a6bbfdf6415d16fd30c7d05afb2b">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="98951a66fe8c0918a7a5d4e119334fe85c33a6bbfdf6415d16fd30c7d05afb2b">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
The user of MICROSAR Safe shall only configure PAs for the same ECU in one E2EConfig.
<xhtml:br/>
If source code needs to be generated for different ECUs, then an individual E2EConfig file must be defined for each ECU.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
