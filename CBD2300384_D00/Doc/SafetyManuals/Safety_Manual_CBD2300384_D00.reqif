        <SPEC-OBJECT IDENTIFIER="id-7bb4332f16858132f327d7aa70311a75" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="941ea3b8039db8fcdd3fc70a262cfce4aae850f646c899e9e35f006d68c38f50">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="941ea3b8039db8fcdd3fc70a262cfce4aae850f646c899e9e35f006d68c38f50">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
