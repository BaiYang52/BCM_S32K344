        <SPEC-OBJECT IDENTIFIER="id-b29c0ed63502940ee33d8e996108722e" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="3a098fd318b7d6d72bf383cbb71fcbe6d3cc73ad010331f49769bb41e9e1c62f">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="3a098fd318b7d6d72bf383cbb71fcbe6d3cc73ad010331f49769bb41e9e1c62f">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
<xhtml:strong>The user of MICROSAR Safe shall initialize all components of MICROSAR Safe prior to using them.</xhtml:strong>
</xhtml:p>
<xhtml:p>
This constraint is required by AUTOSAR anyway. Vector uses this assumption in its safety analyses and development process.
<xhtml:br/>
Unintended re-initialization may lead to unintended behavior. Thus, the user shall ensure that initialization shall occur only at defined points in time.
<xhtml:br/>
Correct initialization can be verified, e.g. during integration testing.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-12">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-1CA9D32E-C888-46C9-902C-240BE93D5966">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="RQM_SAFETY_MANUAL_ITEM">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-DATE THE-VALUE="2023-04-17T14:14:08.073-04:00">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-DATE-REF>id-aa6269f32be4c61f516adebdbf3b1e19</ATTRIBUTE-DEFINITION-DATE-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-DATE>
            <ATTRIBUTE-VALUE-DATE THE-VALUE="2023-04-17T14:14:08.073-04:00">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-DATE-REF>id-1deeefdd91604feff8470574ac6fef3d</ATTRIBUTE-DEFINITION-DATE-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-DATE>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>id-9005dd4fc53fa9c4b4bcb1b9bddbb116</SPEC-OBJECT-TYPE-REF>
