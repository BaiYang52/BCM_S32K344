        <SPEC-OBJECT IDENTIFIER="id-8cd4acc4d6995fcdb4c504380c382a1e" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="6970de69966e31b680bfac971ebd8a489f5e8bd67ea4c79bf63a6ede42a1ed7e">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="6970de69966e31b680bfac971ebd8a489f5e8bd67ea4c79bf63a6ede42a1ed7e">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
<xhtml:strong>TSR-100551 MICROSAR Safe shall provide a mechanism to switch between operating modes.</xhtml:strong>
</xhtml:p>
<xhtml:p>Fault detection and mitigation often result in a degraded or safe state. </xhtml:p>
<xhtml:p>MICROSAR Safe does not unintentionally switch between operating modes. MICROSAR Safe switches to exactly the requested operating mode.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="DocItem">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
