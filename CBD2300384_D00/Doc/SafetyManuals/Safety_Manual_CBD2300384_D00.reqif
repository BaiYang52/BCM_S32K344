        <SPEC-OBJECT IDENTIFIER="id-de9c0cffd2e7c6315665a474eeeb03d9" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="05e3ed675ae7e6326e12516ef0495b310d14ea07bd6024c54d43568735e653c8">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="05e3ed675ae7e6326e12516ef0495b310d14ea07bd6024c54d43568735e653c8">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
