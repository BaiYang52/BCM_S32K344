        <SPEC-OBJECT IDENTIFIER="id-b229aa275511bf1c64974517e5252997" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="365aea0e7471f03bdc7436855e851a70a049efa18830a31c5dc03413a84f4246">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="365aea0e7471f03bdc7436855e851a70a049efa18830a31c5dc03413a84f4246">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>This component assumes the following safety requirements:</xhtml:p>
<xhtml:table>
                      <xhtml:tbody>
                        <xhtml:tr>
                          <xhtml:th> ID </xhtml:th>
                          <xhtml:th> Safety Requirement </xhtml:th>
                          <xhtml:th> Associated TSR </xhtml:th>
                          <xhtml:th> ASIL </xhtml:th>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-1086</xhtml:td>
                          <xhtml:td>E2E shall provide services to protect data.</xhtml:td>
                          <xhtml:td>TSR-10</xhtml:td>
                          <xhtml:td> ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-1087</xhtml:td>
                          <xhtml:td>E2E shall provide services to initialize the protection state.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-10</xhtml:td>
                          <xhtml:td> ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-1088</xhtml:td>
                          <xhtml:td>E2E shall provide services to check protected data.</xhtml:td>
                          <xhtml:td>TSR-10</xhtml:td>
                          <xhtml:td> ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-1089</xhtml:td>
                          <xhtml:td>E2E shall provide services to initialize the check state.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-10</xhtml:td>
                          <xhtml:td> ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-1175</xhtml:td>
                          <xhtml:td>E2E shall provide a service to map the check result to an adequate state machine status</xhtml:td>
                          <xhtml:td>TSR-10</xhtml:td>
                          <xhtml:td> ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-1091</xhtml:td>
                          <xhtml:td>E2E shall provide a service to check data within a reception window.</xhtml:td>
                          <xhtml:td>TSR-10</xhtml:td>
                          <xhtml:td> ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-1092</xhtml:td>
                          <xhtml:td>E2E shall provide a service to initialize the state machine.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-10</xhtml:td>
                          <xhtml:td> ASIL D</xhtml:td>
                        </xhtml:tr>
                      </xhtml:tbody>
                    </xhtml:table>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
