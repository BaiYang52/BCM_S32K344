        <SPEC-OBJECT IDENTIFIER="id-ad87fdd15678474f6d3bb627871d0688" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="b769bf5c0d02f83c6c4b0b9137720e5ae5aa19e85d7e8c4631fc9701e73bd3fa">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="b769bf5c0d02f83c6c4b0b9137720e5ae5aa19e85d7e8c4631fc9701e73bd3fa">
