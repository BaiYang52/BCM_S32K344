        <SPEC-OBJECT IDENTIFIER="id-ba25c8725cb3983b9ab21a55635b6e46" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="bdf9f685015b59d7795cba245f87fa121d852b1253ad9ad84c492cd8a2ab65ab">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="bdf9f685015b59d7795cba245f87fa121d852b1253ad9ad84c492cd8a2ab65ab">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall verify that no configured MPU region grants write access to OS variables from non-trusted software.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-539">
              <DEFINITION>
