          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="7aacacf03a7499fe1c9eb6ca1ec0fecc77a582e1a0a86696a9f23743ff36a785">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
