        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="id-4e2f0b355b878d540becedd841235b12" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="226ef3c985c79b3d3bc6ddd9a40259b9aad78fa83ef444a598cd5bbbade3d545">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="226ef3c985c79b3d3bc6ddd9a40259b9aad78fa83ef444a598cd5bbbade3d545">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall verify that peripheral APIs </xhtml:p>
<xhtml:ul>
                      <xhtml:li>Os_ReadPeripheral8Legacy</xhtml:li>
                      <xhtml:li>Os_ReadPeripheral16Legacy</xhtml:li>
                      <xhtml:li>Os_ReadPeripheral32Legacy</xhtml:li>
                      <xhtml:li>Os_WritePeripheral8Legacy</xhtml:li>
                      <xhtml:li>Os_WritePeripheral16Legacy</xhtml:li>
                      <xhtml:li>Os_WritePeripheral32Legacy</xhtml:li>
                      <xhtml:li>Os_ModifyPeripheral8Legacy</xhtml:li>
                      <xhtml:li>Os_ModifyPeripheral16Legacy</xhtml:li>
                      <xhtml:li>Os_ModifyPeripheral32Legacy</xhtml:li>
                    </xhtml:ul>
<xhtml:p>are not used on platforms which address width is greater than 32 bits.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-44342">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-811C1986-5B48-4A5C-B920-60307889DACE">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
