          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="b7ce8979252deb5edf0b8f75132a0378c106d23fcc50db7cb8a1c971ecb89b98">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
