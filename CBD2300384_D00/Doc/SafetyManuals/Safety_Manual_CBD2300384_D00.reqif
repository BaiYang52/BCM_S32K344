        <SPEC-OBJECT IDENTIFIER="id-97880ddd9227837602d65d8fbaa1c56d" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="0f92b89d335f76a808528518eae5c95a76bbe3a1514786abc7fb541101f6733e">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="0f92b89d335f76a808528518eae5c95a76bbe3a1514786abc7fb541101f6733e">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>This component assumes the following safety requirements:</xhtml:p>
<xhtml:table>
                      <xhtml:tbody>
                        <xhtml:tr>
                          <xhtml:th> ID </xhtml:th>
                          <xhtml:th> Safety Requirement </xhtml:th>
                          <xhtml:th> Associated TSR </xhtml:th>
                          <xhtml:th> ASIL</xhtml:th>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-107414</xhtml:td>
                          <xhtml:td>WdgIf shall provide a service to set the mode of a watchdog device</xhtml:td>
                          <xhtml:td>TSR-13,TSR-15,TSR-14</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-107415</xhtml:td>
                          <xhtml:td>WdgIf shall provide a service to set the trigger condition for a watchdog device</xhtml:td>
                          <xhtml:td>TSR-13,TSR-15,TSR-14</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-107416</xhtml:td>
                          <xhtml:td>WdgIf shall support a mechanism to combine statuses of different cores and handle one watchdog for different cores</xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                      </xhtml:tbody>
                    </xhtml:table>
<xhtml:p>This component in addition to the assumed safety requirements ensures freedom from interference with respect to memory with up to ASIL D.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-519">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
