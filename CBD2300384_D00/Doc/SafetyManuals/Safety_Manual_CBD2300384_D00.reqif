        <SPEC-OBJECT IDENTIFIER="id-581c3921d88ec8b05d2e5eb3a8e06a58" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="e0669eb45db522f379980a42ba0433887715e49b508420316cf790dde623bd08">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="e0669eb45db522f379980a42ba0433887715e49b508420316cf790dde623bd08">
              <DEFINITION>
