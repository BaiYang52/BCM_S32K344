              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>Additional verification measures</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="9.3">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-5cc4ddac421a59e2d94cd9af3cb22413</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
