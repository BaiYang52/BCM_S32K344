        <SPEC-OBJECT IDENTIFIER="id-67c0812158ca33941ed9fa84da789ed7" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="672cfdd69e6c9e08bea7f63fcd3ccd4606dd654a41334f8d8c022d6288bc29b4">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="672cfdd69e6c9e08bea7f63fcd3ccd4606dd654a41334f8d8c022d6288bc29b4">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
The user shall ensure real time behavior of the system, even in case of delayed calls of the <xhtml:em>ProtectionHook</xhtml:em>.
<xhtml:br/>
The <xhtml:em>ProtectionHook</xhtml:em> may be delayed by the execution of Cat 0 ISRs. So Cat 0 ISRs should either not be used or assure a sufficiently short runtime.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-44679">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-CCA4257F-95C4-45FB-B7B0-FA928CBB4579">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="RQM_SAFETY_MANUAL_ITEM">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
