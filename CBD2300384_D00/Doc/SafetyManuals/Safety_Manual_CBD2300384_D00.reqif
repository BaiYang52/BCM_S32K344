        <SPEC-OBJECT IDENTIFIER="id-aa3c9306e003165a46a20b6c63c1b0e9" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="220bee67e6331e1e4aa9a3c8322c4f0b90b4db4b24e2d100acd96d3edbd1a10d">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="220bee67e6331e1e4aa9a3c8322c4f0b90b4db4b24e2d100acd96d3edbd1a10d">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
<xhtml:strong>The user of MICROSAR Safe shall perform a worst-case execution time analysis when using MICROSAR Safe in systems with safety-related availability requirements.</xhtml:strong>
</xhtml:p>
<xhtml:p>In systems with safety-related availability requirements, it is assumed that an upper bound for the execution time of MICROSAR functionality is required. </xhtml:p>
<xhtml:p>This requirement is only applicable if using MICROSAR Safe in a system with safety-related availability requirements.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-246328">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
