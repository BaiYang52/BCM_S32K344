        <SPEC-OBJECT IDENTIFIER="id-a2e79d3fc3689dc8fb3405f7378bf2d9" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="ee8a53fe41cb279e250a43fc6ec1dad86ba78ca620e7de981d7e0cd8b5158e7e">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="ee8a53fe41cb279e250a43fc6ec1dad86ba78ca620e7de981d7e0cd8b5158e7e">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall ensure by linkage for each optimized spinlock that only intended tasks and ISRs have write access to the corresponding spinlock data (or at least only tasks and ISRs of partitions with the same ASIL levels).</xhtml:p>
<xhtml:p>The user of MICROSAR Safe shall verify that no unintended task or ISR has access to data of optimized spinlocks.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-495">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
