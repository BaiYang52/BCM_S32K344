          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="cf65aa32398e265adf80fd8274c9ded71d8ce9681cef83b9d753e100322862b5">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
