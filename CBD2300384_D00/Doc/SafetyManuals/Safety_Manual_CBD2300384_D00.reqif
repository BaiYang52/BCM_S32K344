        <SPEC-OBJECT IDENTIFIER="id-cc702535a177766bde89693c8bece5bd" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="07311e63f1daf194a2bae05ed192a55f5ef24bcec43b596984a5d2cd54acc1d6">
          <VALUES>
