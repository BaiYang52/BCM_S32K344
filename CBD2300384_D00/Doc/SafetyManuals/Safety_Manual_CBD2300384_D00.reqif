        <SPEC-OBJECT IDENTIFIER="id-e3d4c1bf853337459dafe8a3e44ac70d" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="aa15a567fa57fa11bdf9d5bb4593565864712956ae885f5ff1a459f77042a032">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="aa15a567fa57fa11bdf9d5bb4593565864712956ae885f5ff1a459f77042a032">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
The user of MICROSAR Safe shall verify the configured cores in <xhtml:em>wdgm_verifier_info.c</xhtml:em>.
</xhtml:p>
<xhtml:p>
The configured cores are defined in the <xhtml:em>main()</xhtml:em> function.
<xhtml:br/>
For each configured core with ID, the following line shall be present:
</xhtml:p>
<xhtml:pre>
<xhtml:code>
<xhtml:br/>
result += verify (&amp;WdgMConfig_Modem_core&lt;ID>, &amp;verifier_info);
<xhtml:br/>
<xhtml:br/>
</xhtml:code>
</xhtml:pre>
<xhtml:p>where ID is the core ID and	m is the ID of the WdgM mode.</xhtml:p>
<xhtml:p>Verification shall include that for each core there is a corresponding line in the file.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-518">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
