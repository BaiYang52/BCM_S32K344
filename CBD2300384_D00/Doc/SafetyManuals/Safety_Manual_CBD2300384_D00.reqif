            <SPEC-OBJECT-TYPE-REF>id-9005dd4fc53fa9c4b4bcb1b9bddbb116</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="id-6d4b88d520d80bc011cedd039f7ebe87" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="922f0b4c041af3c936a670e17bccca2e6cf1e29ca3916cc5da9ab18e384c103e">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="922f0b4c041af3c936a670e17bccca2e6cf1e29ca3916cc5da9ab18e384c103e">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
