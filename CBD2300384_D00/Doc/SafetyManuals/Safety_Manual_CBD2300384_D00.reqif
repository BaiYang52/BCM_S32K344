          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="f0bc5c1a17b6c1e6ed56e3a1faaf1bb2019630bfd15cd910f86a013a9151155d">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
