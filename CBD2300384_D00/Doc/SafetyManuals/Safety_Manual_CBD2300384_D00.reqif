          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="a9106f611a168427607d76ae5e51b3947a294469917f422e9ede6b8cc79a38df">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
