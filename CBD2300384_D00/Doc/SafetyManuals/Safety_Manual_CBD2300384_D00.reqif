        <SPEC-OBJECT IDENTIFIER="id-1cf712f6e6a9f56515cd48f003074e4d" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="c618a66abd595c41bdf9f90d074100b699c38fee96c8bdcfaef183f4efab7a47">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="c618a66abd595c41bdf9f90d074100b699c38fee96c8bdcfaef183f4efab7a47">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
The user of MICROSAR Safe shall verify that a trusted, non-trusted or fast trusted function checks the validity of passed arguments before usage.
<xhtml:br/>
The caller of CallTrustedFunction, Os_CallNonTrustedFunction or Os_CallFastTrustedFunction might be non-trusted. Therefore, the passed data might also not be trustworthy.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-497">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-E945A453-1A0B-48F1-B6A7-E0C14FA0A647">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="RQM_SAFETY_MANUAL_ITEM">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
