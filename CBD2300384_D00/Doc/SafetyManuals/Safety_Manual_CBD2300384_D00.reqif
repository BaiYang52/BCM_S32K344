        <SPEC-OBJECT IDENTIFIER="id-f9cbbf0d0941c41f0b8ef6e741ec0bde" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="6ca2d8e798bcf11025c0a61414fde7f52725ab21b86caf405cc6dd01fe232ca6">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="6ca2d8e798bcf11025c0a61414fde7f52725ab21b86caf405cc6dd01fe232ca6">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall verify that the following API functions are only called from privileged mode:</xhtml:p>
<xhtml:ul>
                      <xhtml:li>
<xhtml:em>Os_DisableLevelKM</xhtml:em>
</xhtml:li>
                      <xhtml:li>
<xhtml:em>Os_EnableLevelKM</xhtml:em>
</xhtml:li>
                      <xhtml:li>
<xhtml:em>Os_DisableGlobalKM</xhtml:em>
</xhtml:li>
                      <xhtml:li>
<xhtml:em>Os_EnableGlobalKM</xhtml:em>
</xhtml:li>
                    </xhtml:ul>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-488">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-F8076FD9-FA18-4A5B-B0CC-57BBA2718DA2">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
