        <SPEC-OBJECT IDENTIFIER="id-41dfd952eab5b1156214da8e2e835f3c" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="e1316c4f9c8f5cfada1eddce58d575de5d3cafa3ed8c907a22b32fad0b9ea6ec">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="e1316c4f9c8f5cfada1eddce58d575de5d3cafa3ed8c907a22b32fad0b9ea6ec">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
This component requires the triggering of the watchdog and setting the triggering mode as a safety requirement from the watchdog driver.
<xhtml:br/>
This requirement is fulfilled if a watchdog driver by Vector is used.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-520">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-EDF082B5-28B3-467A-B019-B2C460DD37D8">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="RQM_SAFETY_MANUAL_ITEM">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
