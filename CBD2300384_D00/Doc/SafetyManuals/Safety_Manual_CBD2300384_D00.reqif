        <SPEC-OBJECT IDENTIFIER="id-e9dd4026bfb76a85d73c82a15d5d489b" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="3d08f6b8492b1af65d2b1eef0339c993b5a9922b82265e1debd99f870d5f81be">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="3d08f6b8492b1af65d2b1eef0339c993b5a9922b82265e1debd99f870d5f81be">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall be aware that user timing or ARTI hook implementation influences the runtime behaviour of the system.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-69754">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
