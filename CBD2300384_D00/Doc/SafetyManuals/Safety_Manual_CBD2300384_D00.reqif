        <SPEC-OBJECT IDENTIFIER="id-fda000b746ea8cf1d7dc86de0ddf5773" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="57a532134b10afb3c7a64b5c86708db532cd051027ea4fd2c2a476650b7a5af1">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="57a532134b10afb3c7a64b5c86708db532cd051027ea4fd2c2a476650b7a5af1">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall not use any OS API within timing or ARTI hooks.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
