        <SPEC-OBJECT IDENTIFIER="id-7b42f77956152331d6e18f02b7faa970" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="59f257d34c825b13e8106bfb0118de1045d60d146ddf17f9b71220f66f2b18f7">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="59f257d34c825b13e8106bfb0118de1045d60d146ddf17f9b71220f66f2b18f7">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall verify that each generated file is complete, i.e. each file must end with an &quot;EOF&quot; comment. </xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
