        <SPEC-OBJECT IDENTIFIER="id-f58af4470979dfd72c145eef3260a1e3" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="39452eadde66eb20aefe584464cd3aa962236ffac83c73bb5cf268c1a930d6f8">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="39452eadde66eb20aefe584464cd3aa962236ffac83c73bb5cf268c1a930d6f8">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
The user of MICROSAR Safe shall ensure that the output path for the generated E2EPW code (command-line argument &quot;outpath-path&quot;) shall be empty before the generator is started.
<xhtml:br/>
If the output path is not empty, code from previous generation runs may be accidentally integrated into the system.
<xhtml:br/>
This requirement is fulfilled if generation is performed using DaVinci Configurator PRO.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-134">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-143DB92C-C8E6-405A-93F6-722CF7B0F2E7">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="RQM_SAFETY_MANUAL_ITEM">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
