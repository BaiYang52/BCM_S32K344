        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="id-4bf84592600c4c842043cae96e15b05a" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="b76b33217b3cc9720a4a0e0c69a5a91020ef6fcb6a8693f8a3b62a74b5d09e21">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="b76b33217b3cc9720a4a0e0c69a5a91020ef6fcb6a8693f8a3b62a74b5d09e21">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>Tools by Vector do not implement mechanisms to handle hardware faults on the host development computer.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
