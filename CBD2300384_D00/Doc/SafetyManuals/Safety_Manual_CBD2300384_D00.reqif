              <DEFINITION>
                <ATTRIBUTE-DEFINITION-DATE-REF>id-1deeefdd91604feff8470574ac6fef3d</ATTRIBUTE-DEFINITION-DATE-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-DATE>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>id-9005dd4fc53fa9c4b4bcb1b9bddbb116</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="id-3e40ebdf298261ce5b89f2be94ac6c9c" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="250b67a1a1808f0eea7bccc71afe872652cde36d4c2818769c717ab3f90ba3fc">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="250b67a1a1808f0eea7bccc71afe872652cde36d4c2818769c717ab3f90ba3fc">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall verify that software, which implements safety functionality, shall not rely on functionality provided by the following APIs:</xhtml:p>
<xhtml:ul>
                      <xhtml:li>
<xhtml:em>Os_GetVersionInfo</xhtml:em>
</xhtml:li>
                      <xhtml:li>
Stack Usage API (<xhtml:em>Os_Get*StackUsage</xhtml:em>)
</xhtml:li>
                      <xhtml:li>
<xhtml:em>Os_InitInterruptOnly</xhtml:em>
</xhtml:li>
                    </xhtml:ul>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-592">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
