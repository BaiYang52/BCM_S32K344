              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall verify that the interrupt priority of any Category 2 interrupt (including CounterIsr) that can cause scheduling is lower than all other Category 2 interrupts.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
