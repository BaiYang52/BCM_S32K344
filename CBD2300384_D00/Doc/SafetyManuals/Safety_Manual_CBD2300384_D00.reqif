          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="5251d1f1c737b6ccac762ecbe18ca309ac62d02217dc72fbc96543c26cd834b2">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
