        <SPEC-OBJECT IDENTIFIER="id-59e22f4146b8b7b14455a916ab43cbd4" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="047069bc31b359b881a1c4c8bfa24a909798588113feead48f469d9e35547276">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="047069bc31b359b881a1c4c8bfa24a909798588113feead48f469d9e35547276">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
<xhtml:strong>The user of MICROSAR Safe shall verify the integrity of the delivery by Vector.</xhtml:strong>
<xhtml:br/>
Run the SIPModificationChecker.exe and verify that the source code, BSWMD and safety manual files are unchanged.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
