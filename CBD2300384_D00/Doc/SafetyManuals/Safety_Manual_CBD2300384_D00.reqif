          <TYPE>
            <SPEC-OBJECT-TYPE-REF>id-9005dd4fc53fa9c4b4bcb1b9bddbb116</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="id-c7faefa7d5d7402570266cdea3bfc3ce" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="b254078812bbb6feebfb15f71f3e87b7895a601cc3f763c9124db6f9285e1775">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="b254078812bbb6feebfb15f71f3e87b7895a601cc3f763c9124db6f9285e1775">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall verify that all ISRs of category 0 are implemented transparent. Transparent means, that the execution of a category 0 interrupt can not be detected by the OS. Thus, the user has to ensure, that the context described in the HSI of the platform remains unchanged or is restored correctly after the execution of a category 0 ISR.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-44676">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-A2E584A9-2103-4234-904B-68F934618F83">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="RQM_SAFETY_MANUAL_ITEM">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-DATE THE-VALUE="2023-04-17T14:14:08.073-04:00">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-DATE-REF>id-aa6269f32be4c61f516adebdbf3b1e19</ATTRIBUTE-DEFINITION-DATE-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-DATE>
