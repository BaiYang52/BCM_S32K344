        <SPEC-OBJECT IDENTIFIER="id-f5902ab3ca40aeb503bdafcdd728caed" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="f95585b1d719f6eb189cd19edf73abd97a78a6a3927a0f76c567ef2c5c8beb7a">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="f95585b1d719f6eb189cd19edf73abd97a78a6a3927a0f76c567ef2c5c8beb7a">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>This component assumes the following safety requirements: </xhtml:p>
<xhtml:table>
                      <xhtml:tbody>
                        <xhtml:tr>
                          <xhtml:th> ID </xhtml:th>
                          <xhtml:th> Safety Requirement </xhtml:th>
                          <xhtml:th> Associated TSR </xhtml:th>
                          <xhtml:th> ASIL </xhtml:th>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-MemoryInitializationZero</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to initialize memory to zero.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-MemoryInitializationPattern</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to initialize memory to a specified pattern.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-MemoryCopy</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to copy data from one memory location to another.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-MemoryCopyEndianConversion</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to copy data from one memory location to another with a converted endianness.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-MemoryComparison</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to compare two memory areas.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-MemoryComparisonPattern</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to check that a memory area contains only a specified pattern.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-BitSearch</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to search for the highest/lowest set/unset bit in different sized unsigned integers.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-Serialization</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to serialize differently sized integers to a byte stream.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-Deserialization</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to deserialize a byte stream to differently sized integers.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-EndianSwap</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to swap the endianness of differently sized integers.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-EndianConversion</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to convert differently sized integers from the platform endianness to big/little endian and vice versa.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-VStdLib-BitCopy</xhtml:td>
                          <xhtml:td>VStdLib_GenericAsr shall provide a service to copy data from one memory location to another where the amount of data to be copied is specified in bits.</xhtml:td>
                          <xhtml:td>TSR-1, TSR-4, TSR-5, TSR-6, TSR-7, TSR-8, TSR-9, TSR-10, TSR-12, TSR-13, TSR-14, TSR-15, TSR-16, TSR-17, TSR-18, TSR-100551, TSR-101876, TSR-111108, TSR-111109</xhtml:td>
                          <xhtml:td>ASIL D</xhtml:td>
                        </xhtml:tr>
                      </xhtml:tbody>
                    </xhtml:table>
<xhtml:p>The above listed TSRs apply to the Vector implementation (functions and macros) and not to externally defined implementations like, e.g., compiler intrinsics or user implementations.</xhtml:p>
<xhtml:p>This component in addition to the assumed safety requirements ensures freedom from interference with respect to memory and timing with up to ASIL D.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="DocItem">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-DATE THE-VALUE="2023-04-17T14:14:08.073-04:00">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-DATE-REF>id-aa6269f32be4c61f516adebdbf3b1e19</ATTRIBUTE-DEFINITION-DATE-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-DATE>
            <ATTRIBUTE-VALUE-DATE THE-VALUE="2023-04-17T14:14:08.073-04:00">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-DATE-REF>id-1deeefdd91604feff8470574ac6fef3d</ATTRIBUTE-DEFINITION-DATE-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-DATE>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>id-9005dd4fc53fa9c4b4bcb1b9bddbb116</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
