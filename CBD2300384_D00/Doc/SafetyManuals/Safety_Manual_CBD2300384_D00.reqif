            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>This component provides the following safety requirements:</xhtml:p>
<xhtml:table>
                      <xhtml:tbody>
                        <xhtml:tr>
                          <xhtml:th> ID </xhtml:th>
                          <xhtml:th> Safety requirements </xhtml:th>
                          <xhtml:th> Linked TSR </xhtml:th>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td> CREQ-105559 </xhtml:td>
                          <xhtml:td>Wdg shall provide a service to initialize itself and the watchdog hardware. </xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15 </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td> CREQ-105560 </xhtml:td>
                          <xhtml:td>Wdg shall provide a service to set the watchdog mode. </xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15 </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td> CREQ-105561 </xhtml:td>
                          <xhtml:td>Wdg shall provide a service to set trigger condition. </xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15 </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td> CREQ-105563 </xhtml:td>
                          <xhtml:td>Wdg shall provide a service that triggers the watchdog hardware if trigger condition is valid. </xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15 </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td> CREQ-106194 </xhtml:td>
                          <xhtml:td>Wdg shall provide an OFF mode. </xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15 </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td> CREQ-106195 </xhtml:td>
                          <xhtml:td>Wdg shall provide a SLOW mode. </xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15 </xhtml:td>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td> CREQ-106196 </xhtml:td>
                          <xhtml:td>Wdg shall provide a FAST mode. </xhtml:td>
                          <xhtml:td>TSR-13,TSR-14,TSR-15 </xhtml:td>
                        </xhtml:tr>
                      </xhtml:tbody>
                    </xhtml:table>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-279">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
