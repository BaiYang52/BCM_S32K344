        <SPEC-OBJECT IDENTIFIER="id-c4776fc1c50b61e3dcc10695d4d1eebf" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="317c3cd090029780e067ad0520037303c879243588eeb2bc0829d45701cad9b3">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="317c3cd090029780e067ad0520037303c879243588eeb2bc0829d45701cad9b3">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>E2EXF requires the following functionality as safety requirement from the E2ELIB:</xhtml:p>
<xhtml:ul>
                      <xhtml:li>data protection</xhtml:li>
                      <xhtml:li>initialization of protection state</xhtml:li>
                      <xhtml:li>checking of protection state</xhtml:li>
                      <xhtml:li>mapping of result state to state machine status</xhtml:li>
                      <xhtml:li>checking of data</xhtml:li>
                      <xhtml:li>initialization of state machine</xhtml:li>
                    </xhtml:ul>
<xhtml:p>This requirement is fulfilled if an ASIL E2ELIB by Vector is used.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-66294">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
