        <SPEC-OBJECT IDENTIFIER="id-c9a271cef2b45beb4a688ac73c80d448" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="43e0da473ecfaa5dfd4c7476b8836a4d3ced41fcd8411c47223e25d819941519">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="43e0da473ecfaa5dfd4c7476b8836a4d3ced41fcd8411c47223e25d819941519">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>This component assumes the following safety requirements:</xhtml:p>
<xhtml:table>
                      <xhtml:tbody>
                        <xhtml:tr>
                          <xhtml:th> ID </xhtml:th>
                          <xhtml:th> Safety Requirement </xhtml:th>
                          <xhtml:th> Associated TSR </xhtml:th>
                          <xhtml:th> ASIL </xhtml:th>
                        </xhtml:tr>
                        <xhtml:tr>
                          <xhtml:td>CREQ-118</xhtml:td>
                          <xhtml:td>OS shall provide different application modes.</xhtml:td>
                          <xhtml:td>TSR-1</xhtml:td>
