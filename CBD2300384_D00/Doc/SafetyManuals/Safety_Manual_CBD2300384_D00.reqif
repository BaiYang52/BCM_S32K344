              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>Tool Confidence</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="1.2.2">
