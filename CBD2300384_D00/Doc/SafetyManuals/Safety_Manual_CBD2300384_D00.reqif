        <SPEC-OBJECT IDENTIFIER="id-04a8e50f7fdad3ad893dd2d153c51158" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="a38677ea3061da0a7a5f838edc5a568cda4807ab1fde47046f47328400e13bb7">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="a38677ea3061da0a7a5f838edc5a568cda4807ab1fde47046f47328400e13bb7">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
<xhtml:strong>The user of MICROSAR Safe shall not use RTE Implementation Plugins for ASIL software.</xhtml:strong>
<xhtml:br/>
RTE implementation plugins can be used to partially replace RTE APIs with custom implementations.
<xhtml:br/>
The user of MICROSAR Safe shall ensure that the safety related parts of the RTE do not use RTE implementation plugins.
<xhtml:br/>
The RTE Analyzer lists used RTE implementation plugins to assist in this integration step.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-530545">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
