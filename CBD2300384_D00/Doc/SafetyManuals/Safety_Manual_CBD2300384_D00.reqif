        <SPEC-OBJECT IDENTIFIER="id-7f4c86bf9342f5d8893e9ce04e432538" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="d9a0382715d4569cbefe5705e9a5b06cb219b789f0e1479cdd56f5f6827dd435">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="d9a0382715d4569cbefe5705e9a5b06cb219b789f0e1479cdd56f5f6827dd435">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
The user of MICROSAR Safe shall verify that the Wdg driver is only initialized at intended points in time, e.g. during initialization.
<xhtml:br/>
Unintended re-initialization may lead to a disabled watchdog.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-253">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
