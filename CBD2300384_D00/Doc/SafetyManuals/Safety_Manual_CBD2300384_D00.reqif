        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="id-eb7cc61932766e416cd2d2bd3c8cab43" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="fbbdb02d6b60faedb892f449d844ffbbab7af7b56340e5365b96a4b63ec018bc">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="fbbdb02d6b60faedb892f449d844ffbbab7af7b56340e5365b96a4b63ec018bc">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
<xhtml:strong>The user of MICROSAR Safe shall ensure that the RTE Analyzer does not report unsupported templates.</xhtml:strong>
</xhtml:p>
<xhtml:p>The generated RTE code is based on templates. The templates are instantiated by the RTE Generator in different variants. The RTE Analyzer verifies that the analyzed template variants have been tested during the development of the RTE Generator according to ISO 26262.</xhtml:p>
<xhtml:p>
The last section of the RTE Analyzer configuration feedback report provides information about the template variants.
<xhtml:br/>
The report must show that no unsupported templates have been found.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-36067">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-7A262275-8DD3-48E3-905B-C9ACC722533B">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="RQM_SAFETY_MANUAL_ITEM">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-DATE THE-VALUE="2023-04-17T14:14:08.073-04:00">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-DATE-REF>id-aa6269f32be4c61f516adebdbf3b1e19</ATTRIBUTE-DEFINITION-DATE-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-DATE>
            <ATTRIBUTE-VALUE-DATE THE-VALUE="2023-04-17T14:14:08.073-04:00">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-DATE-REF>id-1deeefdd91604feff8470574ac6fef3d</ATTRIBUTE-DEFINITION-DATE-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-DATE>
          </VALUES>
