          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="bbe7631a5b7b110dc6e8315ac14402064354c1e8750df3617fef8c62385f16cc">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>If a state combiner is used, the user of MICROSAR Safe shall configure </xhtml:p>
<xhtml:ul>
                      <xhtml:li>
<xhtml:em>WdgIfStateCombinerOSSpinlock</xhtml:em> or <xhtml:em>WdgIfStateCombinerSpinlockID</xhtml:em> and
</xhtml:li>
                      <xhtml:li>
<xhtml:em>WdgIfStateCombinerStartUpSyncCycles</xhtml:em>
</xhtml:li>
                    </xhtml:ul>
<xhtml:p>for each core that is used by the state combiner.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
