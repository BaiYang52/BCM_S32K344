        <SPEC-OBJECT IDENTIFIER="id-bc124de0af6847908865096418fddaf6" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="3c17ab85e914417685cc00c964a41f83350dd90724accc256439ba4333f35209">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="3c17ab85e914417685cc00c964a41f83350dd90724accc256439ba4333f35209">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
The user of MICROSAR Safe shall verify that the E2E library communication state is checked for plausibility with <xhtml:em>E2EPW_Get[Protect|Check]State_p_o()</xhtml:em> after a startup/restart.
</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-138">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
