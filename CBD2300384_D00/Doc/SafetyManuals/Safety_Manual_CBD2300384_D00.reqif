              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>Technical Solution</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="1.2.1">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-5cc4ddac421a59e2d94cd9af3cb22413</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
