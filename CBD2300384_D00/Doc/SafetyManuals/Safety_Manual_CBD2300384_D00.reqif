        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="id-fce75fb5291907c9d9ee1a0833d4e63a" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="b5953d0983dd04040ced2c14adccfb86776e37b76bfcc4fbc5f7a4c0a594fd4a">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="b5953d0983dd04040ced2c14adccfb86776e37b76bfcc4fbc5f7a4c0a594fd4a">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>
<xhtml:strong>The user of MICROSAR Safe shall ensure the correct usage of the provided API from MICROSAR Safe components.</xhtml:strong>
</xhtml:p>
<xhtml:p>The correct usage of APIs is documented in the respective Technical Reference of the component.</xhtml:p>
<xhtml:p>If a component is used incorrectly, it may not fulfill its functionality as specified. Example: If the wrong data is handed over to the communication stack, the communication stack will send this wrong data on the bus.</xhtml:p>
<xhtml:p>This requirement is only applicable if using MICROSAR Safe in a system with safety-related availability requirements.</xhtml:p>
<xhtml:p>For components of MICROSAR Safe this requirement is only fulfilled if they have the required Technical Safety Requirements assumed (please see respective section of a component if the Technical Safety Requirement is assumed by that component) and are in turn used correctly again.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-494148">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-4F018A6F-AD4A-4023-944A-CC014442CBF5">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
