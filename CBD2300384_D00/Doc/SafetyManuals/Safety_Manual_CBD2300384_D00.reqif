        <SPEC-OBJECT IDENTIFIER="id-f3cd5f14a2c644028a66a43c6c053864" LAST-CHANGE="2023-04-17T14:14:08.073-04:00" LONG-NAME="ef0796bfb1c8dad71d00b1e5297953394c1bb3e8e539b1a18107f802859ef59c">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="ef0796bfb1c8dad71d00b1e5297953394c1bb3e8e539b1a18107f802859ef59c">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-474bf8df001703d4f13bcf6621ec60e3</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>id-356fa0b261512705956dc6124b01c001</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE>
                <xhtml:div>
<xhtml:div>
<xhtml:p>The user of MICROSAR Safe shall verify that none of the configured MPU regions grants write access to a memory section where OS stacks are linked to. To fulfill this requirement, the generated map file may be helpful.</xhtml:p>
</xhtml:div>
</xhtml:div>
              </THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-549">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-916bfa90513366b6033b4ebb05e88b13</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SMI-9E100ED0-B7D0-4441-9A8F-5F2B42CEFB2B">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-f71c12daf9754c5c0ec9549bb0a19b12</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="RQM_SAFETY_MANUAL_ITEM">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>id-83df1902a3d82b5ad802413febd9486c</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
