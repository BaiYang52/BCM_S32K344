												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsClassServiceTraceRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:d3c5dce4-6661-423d-8541-760e8bde9e2f">
													<SHORT-NAME>ArtiOsClassServiceTraceRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectClassParameter that defines the ArtiOsInstanceServiceTrace parameter. This attribute indicates the entry or exit of a service routine and the ID of this service routine. The value of this attribute must be evaluated from one single memory location.</L-2>
													</DESC>
