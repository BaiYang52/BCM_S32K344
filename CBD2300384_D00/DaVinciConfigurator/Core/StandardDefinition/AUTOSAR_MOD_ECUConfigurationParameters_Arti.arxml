													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "queuesize" of this "ArtiOsMessageContainer". This attribute provides the size of the queue for queued messages and "1" for unqueued messages.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsMessageContainerInstanceValidRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:40b080ea-4be2-42a1-bfad-758b5f8ca676">
													<SHORT-NAME>ArtiOsMessageContainerInstanceValidRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "validity" of this ArtiOsMessageContainerInstance. Every object declaration may contain a VALID attribute telling the debugger whether the object's attributes are currently valid. It may have an integer type of any size. Its possible values are 0 (invalid) and non zero (object is valid).</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiOsResourceClass -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:20fdf1bf-55b0-40cd-9f86-a3f7e7212764">
											<SHORT-NAME>ArtiOsResourceClass</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Contains the layout of an ArtiOsResource object. The ArtiOsResource object represents an OSEK resource.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
											<REFERENCES>
												<!-- Reference Definition: ArtiOsResourceClassGenericComponentClassRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:0e22238d-1295-43ee-9c9b-04147679330b">
													<SHORT-NAME>ArtiOsResourceClassGenericComponentClassRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to an ArtiGenericComponentClass that extends the ArtiOsResourceClass.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiGeneric/ArtiGenericComponentClass</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsResourceClassLockerRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:a3ac7330-3cb9-47c6-b083-076103ab5762">
													<SHORT-NAME>ArtiOsResourceClassLockerRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectClassParameter that declares the attribute ArtiOsResourceLockerRef in ArtiOsResourceInstances. This attribute indicates the locking ArtiOsTaskInstance or ArtiOsIsrInstance.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectClassParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsResourceClassStateRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:3a587256-3d4e-42dd-bdfd-6424edb739ce">
													<SHORT-NAME>ArtiOsResourceClassStateRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectClassParameter that declares the attribute ArtiOsResourceStateRef in ArtiOsResourceInstances. This attribute represents the state of a resource ("LOCKED"/"UNLOCKED"). The ArtiObjectClassParameter does include the mapping from integer to human readable "LOCKED" or "UNLOCKED".</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectClassParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiOsResourceInstance -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:335f2f7b-6bad-48f1-9923-1e77382b22f8">
											<SHORT-NAME>ArtiOsResourceInstance</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Represents an instance of an ArtiOsResource object.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<PARAMETERS>
												<!-- PARAMETER DEFINITION: ArtiOsResourceInstancePriority -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:9701fe64-1afd-4731-9d9a-5a76d7fd3812">
													<SHORT-NAME>ArtiOsResourceInstancePriority</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This attribute has two components that state: that the RESOURCE is used by TASKs only or by TASKs and ISRs, and the priority that will be used when locking the RESOURCE.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
											</PARAMETERS>
											<REFERENCES>
												<!-- Reference Definition: ArtiOsResourceInstanceEcuCRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:9870f0b8-92d8-465b-aff0-cbc3a736869b">
													<SHORT-NAME>ArtiOsResourceInstanceEcuCRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to an EcuC OsResource that is beeing extended.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Os/OsResource</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsResourceInstanceGenericComponentInstanceRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:87a06716-22dd-4533-88a1-6ec4c15fe2fd">
													<SHORT-NAME>ArtiOsResourceInstanceGenericComponentInstanceRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to an ArtiGenericComponentInstance that extends the ArtiOsResourceInstance.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiGeneric/ArtiGenericComponentInstance</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsResourceInstanceLockerRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:cd0c3100-679d-4814-ad76-cbcfa7e4d017">
													<SHORT-NAME>ArtiOsResourceInstanceLockerRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "locker" of this ArtiOsResource.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsResourceInstanceStateRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:a1bc17e6-735b-4885-acf3-3579cade827f">
													<SHORT-NAME>ArtiOsResourceInstanceStateRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "state" of this ArtiOsResource.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsResourceInstanceValidRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:69611519-6ebc-4a39-b6dd-f7ee915e568c">
													<SHORT-NAME>ArtiOsResourceInstanceValidRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "validity" of this ArtiOsResourceInstance. Every object declaration may contain a VALID attribute telling the debugger whether the object's attributes are currently valid. It may have an integer type of any size. Its possible values are 0 (invalid) and non zero (object is valid).</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiOsStackClass -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:d8126031-adca-4867-95d6-ba1adc5e86e2">
											<SHORT-NAME>ArtiOsStackClass</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Contains the layout of an ArtiOsStack object. The ArtiOsStack object defines the memory area of any stack in the system.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
											<REFERENCES>
												<!-- Reference Definition: ArtiOsStackClassGenericComponentClassRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:8afcf99d-3900-488c-9d99-8d88885087a8">
													<SHORT-NAME>ArtiOsStackClassGenericComponentClassRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to an ArtiGenericComponentClass that extends the ArtiOsStackClass.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiGeneric/ArtiGenericComponentClass</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiOsStackInstance -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:e719b4a1-b433-42d3-afe1-cf8273400432">
											<SHORT-NAME>ArtiOsStackInstance</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Represents an instance of an ArtiOsStack object.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<PARAMETERS>
												<!-- PARAMETER DEFINITION: ArtiOsStackInstanceDirection -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:8f64367d-6ec9-4d11-b1e4-a795bc5851fb">
													<SHORT-NAME>ArtiOsStackInstanceDirection</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This attribute specifies the direction of stack growth and may have either "UP" or "DOWN" as its value. UP means growing from lower to higher addresses. DOWN means growing from higher addresses to lower addresses.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
											</PARAMETERS>
											<REFERENCES>
												<!-- Reference Definition: ArtiOsStackInstanceBaseAddressRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:a8347439-fc5b-41db-bea9-b002016671e1">
													<SHORT-NAME>ArtiOsStackInstanceBaseAddressRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "baseaddress" of this ArtiOsStack. This attribute specifies the lowest address of stack memory area, regardless of the stack direction.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsStackInstanceFillPatternRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:107bd51c-e8e4-49d7-ac81-ec768c92bbd8">
													<SHORT-NAME>ArtiOsStackInstanceFillPatternRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "fillpattern" of this ArtiOsStack. If the operating system fills the stack during initialisation, this attribute specifies with which pattern the stack area is initialised. This allows the debugger to evaluate the maximum stack usage. For "stackdirection" "DOWN" the pattern starts at "baseaddress". For "stackdirection" "UP" the pattern starts at "baseaddress" + "size". If no pattern is used, this attribute must be omitted.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsStackInstanceGenericComponentInstanceRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:5a50e6bd-a0a8-49fc-8dad-89d8a95df83e">
													<SHORT-NAME>ArtiOsStackInstanceGenericComponentInstanceRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to an ArtiGenericComponentInstance that extends the ArtiOsStackInstance.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiGeneric/ArtiGenericComponentInstance</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsStackInstanceSizeRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:16d3d24f-27c0-4d4e-8c8d-0937ca8809bd">
													<SHORT-NAME>ArtiOsStackInstanceSizeRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "size" of this ArtiOsStack. This attribute represents the size (in bytes) of the memory area allocated for stack.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsStackInstanceValidRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:7e5eca33-79b5-4276-a09d-69ddbae8ce97">
													<SHORT-NAME>ArtiOsStackInstanceValidRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "validity" of this ArtiOsStackInstance. Every object declaration may contain a VALID attribute telling the debugger whether the object's attributes are currently valid. It may have an integer type of any size. Its possible values are 0 (invalid) and non zero (object is valid).</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiOsTaskClass -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:f4b3af52-d152-4341-a493-a38ae7d0a345">
											<SHORT-NAME>ArtiOsTaskClass</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Contains the layout of an ARTI "OsTask" object, extending the EcuC OsTask.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
											<REFERENCES>
												<!-- Reference Definition: ArtiOsTaskClassClassGenericComponentRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:2f77be33-f281-452e-b63e-154d05e6fd72">
													<SHORT-NAME>ArtiOsTaskClassClassGenericComponentRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to an ArtiGenericComponentClass that extends the OsTask.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiGeneric/ArtiGenericComponentClass</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsTaskClassContextRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:e907b038-bf11-420a-b91c-d059c913b741">
													<SHORT-NAME>ArtiOsTaskClassContextRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">ArtiOsTaskContextRef in ArtiOsTaskInstances. This attribute contains a reference to the context object that the task is currently using.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectClassParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsTaskClassCurrentTaskStateRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:5799e97c-37d7-48ac-b75f-6d2f10212ead">
													<SHORT-NAME>ArtiOsTaskClassCurrentTaskStateRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectClassParameter that defines the ArtiCurrentTaskStateInstance parameter including the task state mapping.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectClassParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsTaskClassPriorityRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:3299a988-d752-41a8-8311-f39944d56ddb">
													<SHORT-NAME>ArtiOsTaskClassPriorityRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectClassParameter that declares the attribute ArtiOsTaskPriorityRef in ArtiOsTaskInstances. This attribute represents the current priority of the TASK object. The current priority can be different from the static task priority as a result of priority ceiling protocol. The priority displayed is the priority as defined in the OsTask.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectClassParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsTaskClassStackRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:6c5b8e8d-143b-4d35-baaa-b2cce0139255">
													<SHORT-NAME>ArtiOsTaskClassStackRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectClassParameter that declares the attribute ArtiOsTaskStackRef in ArtiOsTaskInstances. This attribute contains a reference to the stack object that the task is currently using.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectClassParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiOsTaskInstance -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:485b0f61-3e65-4100-a507-b9e4a4c9cf25">
