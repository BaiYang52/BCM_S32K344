								<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:23abaaea-04ea-4349-8305-0ad31e31794e">
									<SHORT-NAME>ArtiValues</SHORT-NAME>
									<DESC>
										<L-2 L="EN">The ArtiValues container collects all parameter values for ARTI that are filled by the generators (OS, RTE, ...)</L-2>
									</DESC>
									<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
									<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
									<SUB-CONTAINERS>
										<!-- Container Definition: ArtiConstant -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:c161abde-e451-46ea-8dba-d7db465845ee">
											<SHORT-NAME>ArtiConstant</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This container holds a constant value.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<PARAMETERS>
												<!-- PARAMETER DEFINITION: ArtiConstantString -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:0a007e52-6426-4b2d-80fb-3e05379d598f">
													<SHORT-NAME>ArtiConstantString</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This is the constant value for a specific parameter.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
											</PARAMETERS>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiExpression -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:cc7289be-08d8-4286-91af-79259f674241">
											<SHORT-NAME>ArtiExpression</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This container holds a C like expression that a debugger can evaluate. This is similar to what is already done in ORTI.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<PARAMETERS>
												<!-- PARAMETER DEFINITION: ArtiExpressionString -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:dfcfe0ed-0e16-4049-969b-78a5d40b4491">
													<SHORT-NAME>ArtiExpressionString</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This string represents a C like expression that a debugger can evaluate.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
											</PARAMETERS>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiHook -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:81392ce4-93b8-4934-b9fe-7f01dcc2da72">
											<SHORT-NAME>ArtiHook</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This container represents an ARTI hook that is present in the module.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<PARAMETERS>
												<!-- PARAMETER DEFINITION: ArtiHookClass -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:00a1fa88-924d-4a55-8215-5a48f98ba9c1">
													<SHORT-NAME>ArtiHookClass</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Name of the (schedule) class of macros. Classes can be one of the predefined classes or user defined.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
												<!-- PARAMETER DEFINITION: ArtiHookContext -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:7a8eb1a0-da8c-4914-8cc9-a560b8a6643a">
													<SHORT-NAME>ArtiHookContext</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Name of the execution context. One of NOSUSP, SPRVSR, or USER.</L-2>
													</DESC>
													<INTRODUCTION>
														<P>
															<L-1 L="EN">See also chapter "ARTI Tracing Macro".</L-1>
														</P>
													</INTRODUCTION>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
												<!-- PARAMETER DEFINITION: ArtiHookEventName -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:ec285046-62b2-4145-ae17-79253c2fe836">
													<SHORT-NAME>ArtiHookEventName</SHORT-NAME>
													<DESC>
														<L-2 L="EN">The name of the event as defined for a particular class, or an arbitrary name for generic classes.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
												<!-- PARAMETER DEFINITION: ArtiHookInstance -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:cb5240f2-7b27-42ab-b327-42a3902e03fb">
													<SHORT-NAME>ArtiHookInstance</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Name of an instance of the (schedule) class.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
											</PARAMETERS>
											<REFERENCES>
												<!-- Reference Definition: ArtiHookEventParameterTypeRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:d22b8331-8951-49cb-96a3-3bbc2560d20e">
													<SHORT-NAME>ArtiHookEventParameterTypeRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to a parameter type to interpret the hook event number.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiParameterTypeMap</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiHookInstanceParameterTypeRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:4df421d6-b105-4baf-9768-ee004ef81c6e">
													<SHORT-NAME>ArtiHookInstanceParameterTypeRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to a parameter type to interpret the hook instance number.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiParameterTypeMap</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiObjectClassParameter -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:1c08a76b-96f1-4c04-abf7-5415edcb7bbb">
											<SHORT-NAME>ArtiObjectClassParameter</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This container represents a parameter of an Arti object class definition.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<REFERENCES>
												<!-- Reference Definition: ArtiObjectClassParameterTypeMapRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:c715d81a-354a-4048-8aef-a286b8082e74">
													<SHORT-NAME>ArtiObjectClassParameterTypeMapRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to a parameter type to interpret the instance parameter value.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiParameterTypeMap</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiObjectInstanceParameter -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:6575b287-9552-4ee7-8014-9d0b93ba9acb">
											<SHORT-NAME>ArtiObjectInstanceParameter</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This container represents a parameter of an Arti object instance.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<REFERENCES>
												<!-- Reference Definition: ArtiObjectInstanceParameterConstantRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:47fc42b3-bf66-4fe3-9ff5-bec32cc927a5">
													<SHORT-NAME>ArtiObjectInstanceParameterConstantRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to a constant representing the value of this parameter.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiConstant</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiObjectInstanceParameterExpressionRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:b19c6494-e2d8-427d-872d-ef02f4cc11b3">
													<SHORT-NAME>ArtiObjectInstanceParameterExpressionRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to an expression that evaluates the value of this parameter.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiExpression</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiObjectInstanceParameterHookRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:dbbd7880-78a6-4814-9702-0c1f420f4333">
													<SHORT-NAME>ArtiObjectInstanceParameterHookRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to a hook that records this parameter.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiHook</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiParameterTypeMap -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:522ccfe6-c7f4-400d-8817-54f1041e9fad">
											<SHORT-NAME>ArtiParameterTypeMap</SHORT-NAME>
											<DESC>
												<L-2 L="EN">A map of key/value pairs to map a parameter value to a display string and/or an Arti or EcuC object.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<SUB-CONTAINERS>
												<!-- Container Definition: ArtiParameterTypeMapPair -->
												<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:b141b4df-cead-4a92-aac5-ec2ecf7ec3f6">
													<SHORT-NAME>ArtiParameterTypeMapPair</SHORT-NAME>
													<DESC>
														<L-2 L="EN">A key/value pair to map a parameter value to a display string and/or an Arti or EcuC object.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
													<PARAMETERS>
														<!-- PARAMETER DEFINITION: ArtiParameterTypeMapPairInput -->
														<ECUC-INTEGER-PARAM-DEF UUID="ECUC:83031463-4053-4dbb-bfaf-237015e31ced">
															<SHORT-NAME>ArtiParameterTypeMapPairInput</SHORT-NAME>
															<DESC>
																<L-2 L="EN">The numerical value given by a parameter to translate.</L-2>
															</DESC>
															<INTRODUCTION>
																<P>
																	<L-1 L="EN">When used with Hooks (ArtiHooks), this parameter is mandatory (multiplicity 1) and its value is limited to the range of 0..65535. When used with Hooks, this parameter may be used to map the values given by "instanceParameter" and/or the "eventParameter" of the ARTI_TRACE macro.</L-1>
																</P>
															</INTRODUCTION>
															<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
															<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
															<ORIGIN>AUTOSAR_ECUC</ORIGIN>
															<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
															<MAX>65535</MAX>
															<MIN>0</MIN>
														</ECUC-INTEGER-PARAM-DEF>
														<!-- PARAMETER DEFINITION: ArtiParameterTypeMapPairOutput -->
														<ECUC-STRING-PARAM-DEF UUID="ECUC:0bc154c3-6242-45b2-beee-247d35a47561">
															<SHORT-NAME>ArtiParameterTypeMapPairOutput</SHORT-NAME>
															<DESC>
																<L-2 L="EN">The string to display for the Input value.</L-2>
															</DESC>
															<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
															<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
															<ORIGIN>AUTOSAR_ECUC</ORIGIN>
															<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
															<ECUC-STRING-PARAM-DEF-VARIANTS>
																<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
															</ECUC-STRING-PARAM-DEF-VARIANTS>
														</ECUC-STRING-PARAM-DEF>
													</PARAMETERS>
													<REFERENCES>
														<!-- Reference Definition: ArtiParameterTypeMapPairInputExpressionRef -->
														<ECUC-REFERENCE-DEF UUID="ECUC:21ef4ed0-1c9f-4534-bc7c-f3ab3266efe1">
															<SHORT-NAME>ArtiParameterTypeMapPairInputExpressionRef</SHORT-NAME>
															<DESC>
																<L-2 L="EN">Refers to an expression that evaluates to a numerical value to translate.</L-2>
															</DESC>
															<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
															<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
															<ORIGIN>AUTOSAR_ECUC</ORIGIN>
															<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiExpression</DESTINATION-REF>
														</ECUC-REFERENCE-DEF>
														<!-- Choice Reference Definition: ArtiParameterTypeMapPairOutputRef -->
														<ECUC-CHOICE-REFERENCE-DEF UUID="ECUC:17fa6f71-ca96-4719-b1e6-d19ab7d61747">
															<SHORT-NAME>ArtiParameterTypeMapPairOutputRef</SHORT-NAME>
															<DESC>
																<L-2 L="EN">Choice Reference to ArtiOsTaskInstance, ArtiOsIsrInstance, ArtiStatesTaskState, OsAppMode, ArtiOsContextInstance, or ArtiOsStackInstance.</L-2>
															</DESC>
															<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
															<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
															<ORIGIN>AUTOSAR_ECUC</ORIGIN>
															<DESTINATION-REFS>
																<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiOs/ArtiOsContextInstance</DESTINATION-REF>
																<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiOs/ArtiOsIsrInstance</DESTINATION-REF>
																<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiOs/ArtiOsStackInstance</DESTINATION-REF>
																<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiOs/ArtiOsTaskInstance</DESTINATION-REF>
																<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiStates/ArtiStatesTaskState</DESTINATION-REF>
																<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Os/OsAppMode</DESTINATION-REF>
															</DESTINATION-REFS>
														</ECUC-CHOICE-REFERENCE-DEF>
													</REFERENCES>
												</ECUC-PARAM-CONF-CONTAINER-DEF>
											</SUB-CONTAINERS>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiStates -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:f09e1b11-b3d0-4428-b514-97a06ade8299">
											<SHORT-NAME>ArtiStates</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This container contains all states of tasks, isrs... that the EcuC uses.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<SUB-CONTAINERS>
												<!-- Container Definition: ArtiStatesTaskState -->
												<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:e8303f32-586e-4a57-8910-c6c969a7f363">
													<SHORT-NAME>ArtiStatesTaskState</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Each state used by the OS has to be listed as ArtiStatesTaskState Parameter with a choice of the states.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
													<PARAMETERS>
														<!-- PARAMETER DEFINITION: ArtiStatesTaskStateEnhanced -->
														<ECUC-BOOLEAN-PARAM-DEF UUID="ECUC:3c4e4984-fd12-46b1-92e6-d2fa56d11758">
															<SHORT-NAME>ArtiStatesTaskStateEnhanced</SHORT-NAME>
															<DESC>
																<L-2 L="EN">Set to true, if the OS provides an "enhanced" state model with "READY" split to "Activated", "Preempted", "Released".</L-2>
															</DESC>
															<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
															<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
															<ORIGIN>AUTOSAR_ECUC</ORIGIN>
															<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
														</ECUC-BOOLEAN-PARAM-DEF>
														<!-- PARAMETER DEFINITION: ArtiStatesTaskStateEnum -->
														<ECUC-ENUMERATION-PARAM-DEF UUID="ECUC:2f811309-d4f6-4fc7-b12e-03e43ac7e547">
															<SHORT-NAME>ArtiStatesTaskStateEnum</SHORT-NAME>
															<DESC>
																<L-2 L="EN">ArtiStatesTaskState choice of the states.</L-2>
															</DESC>
															<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
															<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
															<ORIGIN>AUTOSAR_ECUC</ORIGIN>
															<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
															<LITERALS>
																<ECUC-ENUMERATION-LITERAL-DEF UUID="ECUC:f7c997c1-f1d0-9a3f-3cc8-98b4e5d4bdaa">
																	<SHORT-NAME>ArtiTaskStateActivated</SHORT-NAME>
																	<ORIGIN>AUTOSAR_ECUC</ORIGIN>
