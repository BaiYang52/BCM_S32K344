								<!-- Container Definition: ArtiOs -->
								<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:87148dee-7bd7-42cd-85b5-2211305f3490">
									<SHORT-NAME>ArtiOs</SHORT-NAME>
									<DESC>
										<L-2 L="EN">The ArtiOs container contains ARTI extensions to the EcucDefs/Os module.</L-2>
									</DESC>
									<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
									<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
									<SUB-CONTAINERS>
										<!-- Container Definition: ArtiOsAlarmClass -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:f6c8f934-40a8-495d-93c5-6d24cc11b848">
											<SHORT-NAME>ArtiOsAlarmClass</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Contains the layout of an ArtiOsAlarm object.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
											<REFERENCES>
												<!-- Reference Definition: ArtiOsAlarmClassGenericComponentClassRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:2b159123-ec19-44d2-ab6a-cbfd521680c6">
													<SHORT-NAME>ArtiOsAlarmClassGenericComponentClassRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to an ArtiGenericComponentClass that extends the ArtiOsAlarmClass.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiGeneric/ArtiGenericComponentClass</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsAlarmClassStateRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:7e2abcc9-b755-4a65-aeee-f0d5a13a6f40">
													<SHORT-NAME>ArtiOsAlarmClassStateRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectClassParameter that declares the attribute ArtiOsAlarmStateRef in ArtiOsAlarmInstances. This attribute specifies if an alarm is "RUNNING" or "STOPPED". The refered ArtiObjectClassParameter does include the mapping from integer to human readable "RUNNING" or "STOPPED".</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectClassParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
											</REFERENCES>
										</ECUC-PARAM-CONF-CONTAINER-DEF>
										<!-- Container Definition: ArtiOsAlarmInstance -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:13b6673b-5924-488d-9efc-98f04702dbe8">
											<SHORT-NAME>ArtiOsAlarmInstance</SHORT-NAME>
											<DESC>
												<L-2 L="EN">Represents an instance of an ArtiOsAlarm object, extending the EcuC OsTaskAlarm.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY-INFINITE>true</UPPER-MULTIPLICITY-INFINITE>
											<PARAMETERS>
												<!-- PARAMETER DEFINITION: ArtiOsAlarmInstanceAction -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:d8e08489-bab7-4efb-8629-c14919cb3f01">
													<SHORT-NAME>ArtiOsAlarmInstanceAction</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This attribute provides a string with a description of the action when the alarm expires, e.g. "ActivateTask TaskA".</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
												<!-- PARAMETER DEFINITION: ArtiOsAlarmInstanceCounter -->
												<ECUC-STRING-PARAM-DEF UUID="ECUC:756503f2-4eb8-461f-a079-355e4bb43368">
													<SHORT-NAME>ArtiOsAlarmInstanceCounter</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This attribute provides a string containing the name of the counter used by this alarm.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
													<ECUC-STRING-PARAM-DEF-VARIANTS>
														<ECUC-STRING-PARAM-DEF-CONDITIONAL/>
													</ECUC-STRING-PARAM-DEF-VARIANTS>
												</ECUC-STRING-PARAM-DEF>
											</PARAMETERS>
											<REFERENCES>
												<!-- Reference Definition: ArtiOsAlarmInstanceAlarmTimeRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:b4d33c37-865c-4c49-bf2c-dab6df3c1a6e">
													<SHORT-NAME>ArtiOsAlarmInstanceAlarmTimeRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This attribute specifies how to evaluate the time until the alarm expires next. The time should be represented in seconds.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
												<!-- Reference Definition: ArtiOsAlarmInstanceCycleTimeRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:35a98a28-b083-4c79-8201-8eafd004f9d6">
													<SHORT-NAME>ArtiOsAlarmInstanceCycleTimeRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This attribute specifies how to evaluate the cycle time for cyclic alarms. The value of "cycle time" is 0 for non-cyclic alarms. The time should be represendet in seconds.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<ORIGIN>AUTOSAR_ECUC</ORIGIN>
													<DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Arti/ArtiValues/ArtiObjectInstanceParameter</DESTINATION-REF>
												</ECUC-REFERENCE-DEF>
