												<!-- Reference Definition: ArtiHardwareCoreInstanceValidRef -->
												<ECUC-REFERENCE-DEF UUID="ECUC:b0132d13-b0f7-413d-bf4f-ddac77a553c0">
													<SHORT-NAME>ArtiHardwareCoreInstanceValidRef</SHORT-NAME>
													<DESC>
														<L-2 L="EN">Refers to the ArtiObjectInstanceParameter that contains the evaluation for the "validity" of this ArtiHwCoreInstance. Every object declaration may contain a VALID attribute telling the debugger whether the object's attributes are currently valid. It may have an integer type of any size. Its possible values are 0 (invalid) and non zero (object is valid).</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
