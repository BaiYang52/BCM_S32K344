												<ECUC-STRING-PARAM-DEF UUID="ECUC:13ba9a9c-0504-42ab-bba0-f5bc39dd5394">
													<SHORT-NAME>ArtiOsMessageContainerInstanceMsgType</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This attribute provides the type of the message.</L-2>
													</DESC>
