													<DESC>
														<L-2 L="EN">Refers to an ArtiGenericComponentClass that extends the OS description.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
