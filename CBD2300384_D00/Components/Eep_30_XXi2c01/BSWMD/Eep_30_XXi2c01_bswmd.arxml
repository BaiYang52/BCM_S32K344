										<!-- Container Definition: EepExternalDriver -->
										<ECUC-PARAM-CONF-CONTAINER-DEF UUID="cc5745c5-ade5-410b-912c-4e43b1a276eb">
											<SHORT-NAME>EepExternalDriver</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This container is present for external EEPROM drivers only. Internal EEPROM drivers do not use the parameter listed in this container, hence its multiplicity is 0 for internal drivers.</L-2>
											</DESC>
											<ADMIN-DATA>
