										<ECUC-INTEGER-PARAM-DEF UUID="ef98b718-7db5-4738-a985-b36132f9984c">
											<SHORT-NAME>EepMaxAllowedReadBlockSize</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This parameter represents the maximum allowed read size for the slow (normal) and fast mode.

Background: this parameters serves to generation of the data buffer(s) size and to EepFastReadBlockSize and EepNormalReadBlockSize parameters validation.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
