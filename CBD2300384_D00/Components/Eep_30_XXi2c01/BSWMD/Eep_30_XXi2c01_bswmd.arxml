											<DEFAULT-VALUE>0.005</DEFAULT-VALUE>
											<MAX>1.000</MAX>
											<MIN>0.000</MIN>
										</ECUC-FLOAT-PARAM-DEF>
										<ECUC-ENUMERATION-PARAM-DEF UUID="5edf6d35-ca7b-4e44-9fd8-8b04695b12e0">
											<SHORT-NAME>EepPageSize</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This parameter represents the physical EEPROM page size in bytes. For details please check the device users manual.

Background: this parameters serves to generation of the data buffer(s) size and to EepFastWritedBlockSize and EepNormalWriteBlockSize parameters validation.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
											<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
											<IMPLEMENTATION-CONFIG-CLASSES>
												<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
													<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
													<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
												</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
											</IMPLEMENTATION-CONFIG-CLASSES>
