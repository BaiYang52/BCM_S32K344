													<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
												</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
											</IMPLEMENTATION-CONFIG-CLASSES>
											<ORIGIN>Vector Informatik</ORIGIN>
											<REQUIRES-INDEX>false</REQUIRES-INDEX>
											<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
											<DEFAULT-VALUE>16</DEFAULT-VALUE>
											<MAX>16</MAX>
											<MIN>8</MIN>
										</ECUC-INTEGER-PARAM-DEF>
										<ECUC-INTEGER-PARAM-DEF UUID="1547ebeb-fd6e-4707-ae83-5fd0a17f50a8">
											<SHORT-NAME>EepTotalSize</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This parameter represents the EEPROM total addressing area in bytes. For details please check the device users manual.

Background: this parameters serves to EepBaseAddress and Eep_Size parameters validation.</L-2>
											</DESC>
											<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
