											<SHORT-NAME>I2cUnitEnd</SHORT-NAME>
											<DESC>
												<L-2 L="EN">This value specifies the hardware unit end address.</L-2>
											</DESC>
											<ADMIN-DATA>
												<SDGS>
													<SDG GID="DV:Display">
