					<ELEMENTS>
						<ECUC-MODULE-DEF UUID="fc5bb706-c2a1-49e8-8fc6-9e85fa2356d6">
							<SHORT-NAME>I2c</SHORT-NAME>
							<DESC>
								<L-2 L="EN">Inter-Integrated Circuit. The driver provides services for reading from and writing to devices connected via I2c buses. It provides access to I2c communication to several users (e.g. EEPROM, Watchdog, I/O ASICs) and the required mechanism to configure the onchip I2c peripheral.

#I2c #Driver 
#MICROSAR #Vector</L-2>
							</DESC>
							<CATEGORY>VENDOR_SPECIFIC_MODULE_DEFINITION</CATEGORY>
							<ADMIN-DATA>
