													</LONG-NAME>
													<DESC>
														<L-2 L="EN">This parameter specifies the transmission end notification to inform the user that a transmission request has been serviced.
</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
