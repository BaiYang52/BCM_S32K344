												<ECUC-BOOLEAN-PARAM-DEF UUID="737e6014-9677-4749-bdf5-7f4a18773ae6">
													<SHORT-NAME>I2cHandleNackAsError</SHORT-NAME>
													<LONG-NAME>
														<L-4 L="EN">Handle missing ACK as error</L-4>
													</LONG-NAME>
													<DESC>
														<L-2 L="EN">This parameter defines whether a NACK is handeld as error. 

True: NACK is handled as error (I2cErrorNotification callback is called, DEM event is reported).
False: NACK is not handled as error (I2cEndNotification is called).
</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
