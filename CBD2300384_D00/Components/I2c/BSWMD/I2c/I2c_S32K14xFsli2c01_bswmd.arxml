												<ECUC-BOOLEAN-PARAM-DEF UUID="a2b7e3cd-a978-41aa-b489-325b3c1b1231">
													<SHORT-NAME>I2cChainChannel</SHORT-NAME>
													<DESC>
														<L-2 L="EN">This parameter defines whether the channel is chained.

True: The channel is chained.
False: The channel is not chained.

Note: A chained channel requires follow up to be set. It does not set a restart condition and the retransmission of the slave address is ommited.</L-2>
													</DESC>
													<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
													<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
													<IMPLEMENTATION-CONFIG-CLASSES>
														<ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
															<CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
															<CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
														</ECUC-IMPLEMENTATION-CONFIGURATION-CLASS>
