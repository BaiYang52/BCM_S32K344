<?xml version="1.0" encoding="UTF-8"?>
<!--
***********************************************************************************************************************
Group format:

Can_<Platform>_<SubGroup>_xMB<MailboxAmount><IsrGroup>....._xBT<0,1,2>_xPAR<0,1>_xFD<0,1>_xRAM<0,1>

Platform: "Vybrid", "Imx", "S32", "Mpc5700"
SubGroup: hard coded in generator, define the BaseAddress mapping to physical channel (optional)
_xMB:     one for each physical channel (limited by ChannelMax)
          MailboxAmount: 16, 32, 64, 96, 128 for this channel
          IsrGroup: A-G or X for GENERIC
             GENERIC /* GROUP_X  no interrupt functions are added to OS */,
             GROUP_A /* single ISR */,
             GROUP_B /* 0to3, 4to7, 8to11, 12to15, 16to31, 32to39, 40to47, 48to55, 56to63, 64To79 (optional), 80to95 (optional) */,
             GROUP_C /* 0to3, 4to7, 8to11, 12to15, 16to31, 32to63, 64to95 (optional) */,
             GROUP_D /* 0, 1, 2, .., 15, 16to31, 32to63, 64to95 (optional), 96to127 (optional) */,
             GROUP_E /* 0to7, 8to15, 16to31, 32to63 */,
             GROUP_F /* 0to15, 16to31 (optional), 32to63 (optional), 64to95 (optional) */,
             GROUP_G /* 0to31, 32to63 (optional), 64to95 (optional), 96to127 (optional) */,
             GROUP_H /* 0to15, 16to31 (optional), 32to47 (optional), 48to63 (optional) */,
             GROUP_I /* 1 mailbox interrupt for all mailboxes */
_xBT:        0:  supportExtendedBitTiming=false, supportExtendedSjw=false
             1:  supportExtendedBitTiming=true, supportExtendedSjw=false
             2:  supportExtendedBitTiming=true, supportExtendedSjw=true
_xPAR:       0:  isParityCheckAvailable=false
             1:  isParityCheckAvailable=true
_xFD:        0:  supportCANFD=false
             1:  supportCANFD=true
_xRAM:       0:  supportExtendedRAMCheck=false
             1:  supportExtendedRAMCheck=true
_xERR:       0:  isErrorInterruptAvailable=false
             1:  isErrorInterruptAvailable=true
*********************************************************************************************************************** 
-->
