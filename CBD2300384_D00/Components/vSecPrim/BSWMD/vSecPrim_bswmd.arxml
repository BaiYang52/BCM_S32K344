									<MAX>65535</MAX>
									<MIN>1</MIN>
								</ECUC-INTEGER-PARAM-DEF>
							</PARAMETERS>
						</ECUC-PARAM-CONF-CONTAINER-DEF>
					</CONTAINERS>
				</ECUC-MODULE-DEF>
				<ECUC-MODULE-CONFIGURATION-VALUES UUID="7a21be29-e160-40da-88d4-bd3dd4ef4ae1">
					<SHORT-NAME>vSecPrim_Pre</SHORT-NAME>
					<DESC>
