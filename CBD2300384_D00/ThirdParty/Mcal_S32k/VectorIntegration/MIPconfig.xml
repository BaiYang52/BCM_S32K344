<MipConfig xmlns="http://www.vector.com/MIPv2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.vector.com/MIPv2 ../../McalIntegrationHelper/MIP3.0.0.xsd">
	<!--
  =====================================================================================================
  Generic Informations
  =====================================================================================================
  This is the configuration file for the 3rdParty McalIntegartionHelper.
  Please note: This file has been created and tested for a specific and agreed MCAL version.
               As typically pattern based specificatons and actions are used this configuration
               will be valid for other MCAL versions in most cases but this cannot be guaranteed.
  All steps processed by the tool are logged during execution and can be retraced later on.
  -->
	<GeneralInformation>
		<!-- Path to SIP base path relative to the location of this file 
         ATTENTION: All other paths within this configuraton file are relative to the SIP Base path! -->
		<SipBase_RelPath>..\\..\\..\\</SipBase_RelPath>
		<!-- Path to the MCAL supply folder relative to the SIP Base path -->
		<McalSupply_RelPath>ThirdParty\\Mcal_S32k.*\\Supply</McalSupply_RelPath>
	</GeneralInformation>
  <!--
  =====================================================================================================
  Package definitions
  - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  Attributes:
    - Summary:      Free text to describe the package content in short
    - Id:           Unique number to identify the package. This Id will be used by following commands.
    - TechRef:      Holds the relative path to the Technical Reference sheet.
  Elements:
    - NameExpected: This is the folder name of the package as specified by MCAL supplier.
                    Typically this folder name contains informations about version and supported 
                    controllers or families
    - StructureExpected: This specifies that the MCAL uses the structure expected structure.
    - Folder: This specifies the name of the folder that is part of the expected structure,
    		    with the help of the Name attribute it is possible to specify a folder name.
		    By default, every folder is considered mandatory, unless specified otherwise
		    with the attribute Mandatory set to false.
		    With the use of the Files attribute, it is possible to specify mandatory files in the structure.
    - Description:  Free text to describe the contents of this package in detail
    - Mandatory:    'true' if this package is mandatory, 'false' otherwise
  =====================================================================================================
  -->
	<Packages TechRef="?CONST.TechRef_PathRel?\TechnicalReference_3rdParty-MCAL-Integration_S32K.pdf">
		<!-- Package 1 -->
		<Package Summary="MCAL Package" Id="1">
			<NameExpected>S.?32K.*(MCAL|RTD).*</NameExpected>
			<StructureExpected>
				<Folder Name="eclipse">
					<Folder Name="plugins">
						<Folder Name="Mcu_TS_.*"/>
						<Folder Name="Resource_TS_.*"/>
					</Folder>
				</Folder>
			</StructureExpected>
			<Description>Base package containing the S32K3xx AUTOSAR 4.x MCAL</Description>
			<Mandatory>true</Mandatory>
		</Package>
		<!-- Package 2 -->
		<Package Summary="Tresos Tool" Id="2">
			<NameExpected>.*tresos.*</NameExpected>
			<StructureExpected>
				<Folder Name="bin" Files="tresos_cmd.bat, tresos_gui.exe"/>
				<Folder Name="plugins"/>
				<Folder Name="configuration" Mandatory="false"/>
				<Folder Name="licenses" Mandatory="false"/>
			</StructureExpected>
			<Description>Contains the 3rd Party Configuration and Generation Tool</Description>
			<Mandatory>true</Mandatory>
		</Package>
		<!-- Package 3 -->
		<Package Summary="HSE firmware" Id="3">
			<NameExpected>(?i)HSE_FW_S32.*_.*</NameExpected>
			<StructureExpected>
				<Folder Name="docs"/>
			</StructureExpected>
			<Description>Contains the HSE firmware and interface</Description>
			<Mandatory>false</Mandatory>
		</Package>
		<!-- Package 4 -->
		<Package Summary="Safety Peripheral Drivers" Id="4">
			<NameExpected>(?i)S.?32K.*SPD_\d*\.\d*\.\d*</NameExpected>
			<StructureExpected>
				<Folder Name="eclipse">
					<Folder Name="plugins">
						<Folder Name="Bist_TS_.*"/>
						<Folder Name="eMcem_TS_.*"/>
					</Folder>
				</Folder>
			</StructureExpected>
			<Description>Contains the SPD drivers</Description>
			<Mandatory>false</Mandatory>
		</Package>
		<!-- Package 5 -->
		<Package Summary="Sbc package" Id="5">
			<NameExpected>(S32K3\d*_)?FS26(_\w*)?_\d.\d_\d.\d.*</NameExpected>
			<StructureExpected>
				<Folder Name="eclipse">
					<Folder Name="plugins">
						<Folder Name="Sbc_fs26_.*"/>
						<Folder Name="Wdg_43_fs26_.*"/>
					</Folder>
				</Folder>
			</StructureExpected>
			<Description>Contains the Sbc drivers</Description>
			<Mandatory>false</Mandatory>
		</Package>
	</Packages>
	<Cdd>
		<ActionEnableCdd Summary="Enables CDD feature if MCAL Base package is in use." RelatedPackage="1">
			<Enable>true</Enable>
		</ActionEnableCdd>
	</Cdd>	
	<!--
  =====================================================================================================
  Below all actions are described which are needed in order to install or remove the MCAL packages.
  They are devided in the sections.
  - Install:     With this step the MCAL is installed/copied into the SIP structure thus commonly only
                 one action for each package is necessary namely copy the package.
                 If package is already available in SIP (e.g. had been included in SIP) these steps will 
                 be skipped.
  - Prepare:     During this step some necessary operation within the MCAL packages and within the 
                 Vector SIP are executed.
  - UndoPrepare: With this actions the actions described within the Prepare section will be undone.
  - Remove:      The actions described here will remove the MCAL packages!
  - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  For all 4 sections all available actions can be executed as often as needed.
  Order of action in this file is equal to the order of execution.
  =====================================================================================================
  -->
	<Install>
		<ActionCopyPackage Summary="Copy package" RelatedPackage="1"/>
		<ActionCopyPackage Summary="Copy package" RelatedPackage="2"/>
		<ActionCopyPackage Summary="Copy package" RelatedPackage="3"/>
		<ActionCopyPackage Summary="Copy package" RelatedPackage="4"/>
		<ActionCopyPackage Summary="Copy package" RelatedPackage="5"/>
	</Install>
	<Prepare>
		
		<!--Read the Minor Version Number of the CFG5 Version to find out which Microsar Release was delivered. Minor Version Number plus 3 results in the Microsar Release.-->
		<ActionGroup Summary="Define temporary variables">
			<ActionDefVar Summary="Define Temporary Variable 'CFG5_Version'" RelatedPackage="1" ExecuteHidden="true">
				<Name>CFG5_Version</Name>
				<LookForPatternInFile><![CDATA[(.*version=5\.)(\d\d)(.*)]]></LookForPatternInFile>
				<PathRel>DaVinciConfigurator\\Core\\.eclipseproduct</PathRel>
				<ValueBOP>$2</ValueBOP>
			</ActionDefVar>
	
			<ActionDefVar Summary="Define temporary variable 'Mcal_Mod_V'" RelatedPackage="1" ExecuteHidden="true">
				<Name>Mcal_Mod_V</Name>
				<LookForPathPattern>?CONST.Package_PathRel_Id1?\\eclipse\\plugins\\Base(NXP)?_TS_(.*)</LookForPathPattern>
				<ValueBOP>$2</ValueBOP>
			</ActionDefVar>
			<ActionDefVar Summary="Define temporary variable 'Mcal_Base_Name'" RelatedPackage="1" ExecuteHidden="true">
				<Name>Mcal_Base_Name</Name>
				<LookForPathPattern>?CONST.Package_PathRel_Id1?\\eclipse\\plugins\\(Base)(NXP)?_TS_(.*)</LookForPathPattern>
				<ValueBOP>$1$2</ValueBOP>
			</ActionDefVar>
			<ActionDefVar Summary="Define temporary variable 'ASR Version'" RelatedPackage="1" ExecuteHidden="true">
				<Name>Mcal_ASR_Version</Name>
				<LookForPatternInFile><![CDATA[(.*<parameter name="contentType" value="asc:)(.*)("/>)]]></LookForPatternInFile>
				<PathRel>?CONST.Package_PathRel_Id1?\\eclipse\\plugins\\Base(NXP)?_TS_?VAR.Mcal_Mod_V?\\plugin\.xml</PathRel>
				<ValueBOP>$2</ValueBOP>
			</ActionDefVar>
			<ActionDefVar Summary="Define temporary variable 'ASR Schema Version'" RelatedPackage="1" ExecuteHidden="true">
				<Name>Mcal_ASR_Schema_Version</Name>
				<LookForPatternInFile><![CDATA[(<AUTOSAR.*)]]></LookForPatternInFile>
				<PathRel>?CONST.Package_PathRel_Id1?\\eclipse\\plugins\\Base(NXP)?_TS_?VAR.Mcal_Mod_V?\\autosar\\Base(NXP)?\.epd</PathRel>
				<ValueBOP>$1</ValueBOP>
			</ActionDefVar>
			
			<ActionDefVar Summary="Define temporary variable 'HSE_BASE_PATH'" RelatedPackage="3" ExecuteHidden="true">
				<Name>HSE_BASE_PATH</Name>
				<LookForPathPattern>?CONST.Package_PathRel_Id3?(\\hse_full_mem)?\\interface</LookForPathPattern>
				<ValueBOP>$(HSE_PATH)$1</ValueBOP>
				<Condition Pattern="?CONST.Package_PathRel_Id3?(\\hse_full_mem)?\\interface" Exist="true"/>
			</ActionDefVar>
			
			<ActionDefVar Summary="Define temporary variable 'Spd_Mod_V'" RelatedPackage="4" ExecuteHidden="true">
				<Name>Spd_Mod_V</Name>
				<LookForPathPattern>?CONST.Package_PathRel_Id4?\\eclipse\\plugins\\SafetyBase_TS_(.*)</LookForPathPattern>
				<ValueBOP>$1</ValueBOP>
			</ActionDefVar>
			
			<ActionDefVar Summary="Define temporary variable 'Sbc_Mod_V'" RelatedPackage="5" ExecuteHidden="true">
				<Name>Sbc_Mod_V</Name>
				<LookForPathPattern>?CONST.Package_PathRel_Id5?\\eclipse\\plugins\\Wdg.*_TS_(.*)</LookForPathPattern>
				<ValueBOP>$1</ValueBOP>
			</ActionDefVar>
		</ActionGroup>
		<ActionGroup Summary="Customize Make Files">
			<ActionPatchFile Summary="Write ASR Version into in make file" RelatedPackage="1">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak</PathRel>
				<Pattern>(ASR_VERSION.*=)(.*)</Pattern>
				<ReplaceBOP>$1 ?VAR.Mcal_ASR_Version?</ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Set path to MCAL package (variable 'MCAL_PATH') in make file" RelatedPackage="1">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak</PathRel>
				<Pattern>(MCAL_PATH.*=)(.*)</Pattern>
				<ReplaceBOP>$1 ..\\?CONST.Package_PathRel_Id1?</ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Set Tresos plugin version (variable 'MCAL_MOD_V') in make file" RelatedPackage="1">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak</PathRel>
				<Pattern>(MCAL_MOD_V.*=)(.*)</Pattern>
				<ReplaceBOP>$1 ?VAR.Mcal_Mod_V?</ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Set Base Package Name (variable 'BASE_PACKAGE_NAME') in make file" RelatedPackage="1">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak</PathRel>
				<Pattern>(BASE_PACKAGE_NAME.*=)(.*)</Pattern>
				<ReplaceBOP>$1 ?VAR.Mcal_Base_Name?</ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Set path to HSE package (variable 'HSE_PATH') in make file" RelatedPackage="3">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules.mak</PathRel>
				<Pattern>(HSE_PATH\s*=)(.*)</Pattern>
				<ReplaceBOP>$1 ..\\?CONST.Package_PathRel_Id3?</ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Set HSE base path (variable 'HSE_BASE_PATH') in make file" RelatedPackage="3">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules.mak</PathRel>
				<Pattern>(HSE_BASE_PATH\s*=)(.*)</Pattern>
				<ReplaceBOP>$1 ?VAR.HSE_BASE_PATH?</ReplaceBOP>
				<Condition Pattern="?CONST.Package_PathRel_Id3?(\\hse_full_mem)?\\interface" Exist="true"/>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Set path to SPD package (variable 'SPD_PATH') in make file" RelatedPackage="4">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak</PathRel>
				<Pattern>(SPD_PATH.*=)(.*)</Pattern>
				<ReplaceBOP>$1 ..\\?CONST.Package_PathRel_Id4?</ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Set SPD plugin version (variable 'SPD_MOD_V') in make file" RelatedPackage="4">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak</PathRel>
				<Pattern>(SPD_MOD_V.*=)(.*)</Pattern>
				<ReplaceBOP>$1 ?VAR.Spd_Mod_V?</ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Set path to Sbc package (variable 'SBC_PATH') in make file" RelatedPackage="5">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak</PathRel>
				<Pattern>(SBC_PATH.*=)(.*)</Pattern>
				<ReplaceBOP>$1 ..\\?CONST.Package_PathRel_Id5?</ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Set Sbc plugin version (variable 'SBC_MOD_V') in make file" RelatedPackage="5">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak</PathRel>
				<Pattern>(SBC_MOD_V.*=)(.*)</Pattern>
				<ReplaceBOP>$1 ?VAR.Sbc_Mod_V?</ReplaceBOP>
			</ActionPatchFile>
		</ActionGroup>
		
		<ActionGroup Summary="Customize DaVinci Configurator 5 Configuration Files">
			<ActionPatchFile Summary="Set path to 3rd party tool in DaVinciConfigurator configuration file" RelatedPackage="2">
				<PathRel>?CONST.Generator_PathRel?\\Settings_Tresos\.xml</PathRel>
				<Pattern><![CDATA[(.*<Setting Name="TresosFolder" Value=")(.*)(".*/>)]]></Pattern>
				<ReplaceBOP><![CDATA[$1$(SipRootPath)\\?CONST.Package_PathRel_Id2?$3]]></ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Set ASR version of MCAL in DaVinciConfigurator configuration file" RelatedPackage="2">
				<PathRel>?CONST.Generator_PathRel?\\Settings_Tresos\.xml</PathRel>
				<Pattern><![CDATA[(.*<Setting Name="RequiredAsVersion" Value=)(.*)(".*/>)]]></Pattern>
				<ReplaceBOP><![CDATA[$1"?VAR.Mcal_ASR_Version?$3]]></ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Patch settings xml files and xsl transformation file" RelatedPackage="2" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\(Settings_|prepare_output_|InitFunctions_|GeneratorPackageInformation).*\.x.l</PathRel>
				<Pattern><![CDATA[(?<start>.*?(_|/|')TS_)(.*?)(?<rest>/|"|'.*?>)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Mcal_Mod_V?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Patch 'module'_bsmwd_rec.xml files" RelatedPackage="2" MultiFile="true">
				<PathRel>?CONST.Bswmd_PathRel?\\.*_bswmd_rec\.arxml</PathRel>
				<Pattern><![CDATA[(?<start>.*?(_|/|'|>)TS_)(.*?)(?<rest>/|"|'|<.*?>)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Mcal_Mod_V?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Patch module Rec config files. Define the required AUTOSAR version" RelatedPackage="1" MultiFile="true">
				<PathRel>?CONST.Bswmd_PathRel?\\.*_bswmd_rec\.arxml</PathRel>
				<Pattern><![CDATA[<AUTOSAR.*]]></Pattern>
				<ReplaceBOP>?VAR.Mcal_ASR_Schema_Version?</ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Remove Comment from InitFunctionCall in InitFunctions_Settings.xml" RelatedPackage="1">
				<PathRel>?CONST.Generator_PathRel?\\InitFunctions_Settings\.xml</PathRel>
				<Pattern><![CDATA[(.*)<!--(<InitFunctionCall>)(.*)(</InitFunctionCall>)-->(.*)]]></Pattern>
				<ReplaceBOP><![CDATA[$1$2$3$4$5]]></ReplaceBOP>
			</ActionPatchFile>		
			<ActionPatchFile Summary="Comment Tag InitFunctionCall in InitFunctions_Settings.xml for the Case that CFG5_Version is lower or equal 16" RelatedPackage="1">
				<PathRel>?CONST.Generator_PathRel?\\InitFunctions_Settings\.xml</PathRel>
				<Pattern><![CDATA[(.*)(<InitFunctionCall>)(.*)(</InitFunctionCall>)(.*)]]></Pattern>
				<ReplaceBOP><![CDATA[$1<!--$2$3$4-->$5]]></ReplaceBOP>
				<Condition Pattern="?VAR.CFG5_Version?" LowerEqual="16"/>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Patch Settings-Files according to SIP Structure" RelatedPackage="1" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\Settings_.*\.xml</PathRel>
				<Pattern><![CDATA[(?<start>.*)\\DaVinciConfigurator\\Generators\\Mcal_S32k(?<rest>.*?>)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}\\?CONST.Generator_PathRel?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Patch Settings-Files according to SIP Structure" RelatedPackage="1" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\Settings_.*\.xml</PathRel>
				<Pattern><![CDATA[(?<start>.*)\\Components\\Mcal_S32k\\GeneratorMsr(?<rest>.*?>)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}\\?CONST.Generator_PathRel?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
		</ActionGroup>
		
		<ActionGroup Summary="Patch DaVinci input files to Spd version">
			<ActionPatchFile Summary="Patch Spd settings xml files and xsl transformation file" RelatedPackage="4" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\(Settings_|prepare_output_|InitFunctions_|GeneratorPackageInformation).*\.x.l</PathRel>
				<Pattern><![CDATA[(?<start>.*?(_|/|')TS_)(.*?)(?<rest>/(SafetyBase|Bist|eMcem)(/|"|'|<|_).*?>?)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Spd_Mod_V?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			<!-- Merge actions -->
			<ActionPatchFile Summary="Patch Spd settings xml files and xsl transformation file" RelatedPackage="4" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\(Settings_|prepare_output_|InitFunctions_|GeneratorPackageInformation).*\.x.l</PathRel>
				<Pattern><![CDATA[(?<start>.*?(/|'|"| )(SafetyBase|Bist|eMcem)_TS_)(.*?)(?<rest>(/|"|'|<).*?>)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Spd_Mod_V?${rest}]]></ReplaceBOP>
			</ActionPatchFile>

			<ActionPatchFile Summary="Patch SPD 'module'_bsmwd_rec.xml files" RelatedPackage="4" MultiFile="true">
				<PathRel>?CONST.Bswmd_PathRel?\\(SafetyBase|Bist|eMcem)_bswmd_rec\.arxml</PathRel>
				<Pattern><![CDATA[(?<start>.*?(_|/|'|>)TS_)(.*?)(?<rest>(/|"|'|<).*?>)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Spd_Mod_V?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
		</ActionGroup>
		
		<ActionGroup Summary="Patch DaVinci input files to Sbc version">
			<ActionPatchFile Summary="Patch Sbc settings xml files and xsl transformation file" RelatedPackage="5" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\(Settings_|prepare_output_|InitFunctions_|GeneratorPackageInformation).*\.x.l</PathRel>
				<Pattern><![CDATA[(?<start>.*?(_|/|')TS_)(.*?)(?<rest>/(Sbc_fs26|Wdg_43_fs26)(/|"|'|<|_).*?>?)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Sbc_Mod_V?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			<!-- Merge actions -->
			<ActionPatchFile Summary="Patch Sbc settings xml files and xsl transformation file" RelatedPackage="5" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\(Settings_|prepare_output_|InitFunctions_|GeneratorPackageInformation).*\.x.l</PathRel>
				<Pattern><![CDATA[(?<start>.*?(/|'|"| )(Sbc_fs26|Wdg_43_fs26)_TS_)(.*?)(?<rest>(/|"|'|<).*?>?)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Sbc_Mod_V?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Patch SPD 'module'_bsmwd_rec.xml files" RelatedPackage="5" MultiFile="true">
				<PathRel>?CONST.Bswmd_PathRel?\\(Sbc|Wdg_43_fs26)_bswmd_rec\.arxml</PathRel>
				<Pattern><![CDATA[(?<start>.*?(_|/|'|>)TS_)(.*?)(?<rest>(/|"|'|<).*?>)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Sbc_Mod_V?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
		</ActionGroup>
		
		<ActionGroup Summary="Customize InitFunctions_Settings to MCAL version">
			<ActionPatchFile Summary="Deactivate No_Base_Init/OsIf_Init from InitFunctions_Settings.xml" RelatedPackage="1">
				<PathRel>?CONST.Generator_PathRel?\\InitFunctions_Settings\.xml</PathRel>
				<Pattern><![CDATA[(.*)(<!--(No_Base|OsIf)_Init-->)(.*)]]></Pattern>
				<ReplaceBOP><![CDATA[$2 <!--]]></ReplaceBOP>
			</ActionPatchFile>			
			<ActionPatchFile Summary="Deactivate No_Base_Init/OsIf_Init from InitFunctions_Settings.xml" RelatedPackage="1">
				<PathRel>?CONST.Generator_PathRel?\\InitFunctions_Settings\.xml</PathRel>
				<Pattern><![CDATA[(.*)(<!--End of (No_Base|OsIf)_Init-->)(.*)]]></Pattern>
				<ReplaceBOP><![CDATA[--> $2]]></ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Activate No_Base_Init in InitFunctions_Settings.xml for AUTOSAR version ASR4.0/ASR4.2/ASR4.3" RelatedPackage="1">
				<PathRel>?CONST.Generator_PathRel?\\InitFunctions_Settings\.xml</PathRel>
				<Pattern><![CDATA[(.*)(<!--.*No_Base_Init-->)(.*)]]></Pattern>
