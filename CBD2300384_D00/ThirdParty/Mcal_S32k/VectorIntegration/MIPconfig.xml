				<PathRel>?CONST.Generator_PathRel?\\Settings_.*\.xml</PathRel>
				<Pattern><![CDATA[(.*<Setting Name="Target" Value=")(.*)(".*/>)]]></Pattern>
				<ReplaceBOP><![CDATA[$1?VAR.Mcal_Target_Name?$3]]></ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Write Derivative into Settings files" RelatedPackage="2" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\Settings_.*\.xml</PathRel>
				<Pattern><![CDATA[(.*<Setting Name="Derivate" Value=")(.*)(".*/>)]]></Pattern>
				<ReplaceBOP><![CDATA[$1?VAR.Mcal_Derivative_Name?$3]]></ReplaceBOP>
			</ActionPatchFile>
			
		</ActionGroup>
		
		<ActionGroup Summary="Patch DaVinci input files to Eth defintion">
			<ActionDefVar Summary="Define temporary variable 'Eth_Defintion'" RelatedPackage="1" ExecuteHidden="true">
				<Name>Eth_Definition</Name>
				<LookForPatternInFile><![CDATA[(.*<SHORT-NAME>)(Eth_.*)?(TS_[A-Za-z0-9]*)(</SHORT-NAME>.*)]]></LookForPatternInFile>
				<PathRel>?CONST.Package_PathRel_Id1?\\eclipse\\plugins\\Eth_(43_GMAC_)?TS_?VAR.Mcal_Mod_V?\\autosar\\Eth_(43_GMAC_)?USR.IdentifyingFileFragment?\.epd</PathRel>
				<ValueBOP>$2$3</ValueBOP>
			</ActionDefVar>
			<ActionDefVar Summary="Define temporary variable 'Eth_Naming'" RelatedPackage="1" ExecuteHidden="true">
				<Name>Eth_Naming</Name>
				<BaseValue>?VAR.Eth_Definition?</BaseValue>
				<BasePattern>(Eth.*)_TS_[A-Za-z0-9]*</BasePattern>
				<ValueBOP>$1</ValueBOP>
			</ActionDefVar>
			<ActionDefVar Summary="Define temporary variable 'Eth_ApiInfix'" RelatedPackage="1" ExecuteHidden="true">
				<Name>Eth_ApiInfix</Name>
				<BaseValue>?VAR.Eth_Naming?</BaseValue>
				<BasePattern>Eth(_.*)</BasePattern>
				<ValueBOP>$1</ValueBOP>
			</ActionDefVar>
			
			<ActionPatchFile Summary="Patch Eth_bsmwd_rec.xml files to Eth definition" RelatedPackage="2">
				<PathRel>?CONST.Bswmd_PathRel?\\Eth_bswmd_rec\.arxml</PathRel>
				<Pattern><![CDATA[(?<start>.*?(>|>/))(Eth_.*)?TS_[A-Za-z0-9]*(?<rest>(/Eth|</).*)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Eth_Definition?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Patch Settings files to Eth definition" RelatedPackage="2" MultiFile="true">
				<PathRel>?CONST.Generator_PathRel?\\(Settings_S32K3xx|Settings_Eth|InitFunctions_Settings|prepare_output_S32K3xx)\.x.l</PathRel>
				<Pattern><![CDATA[(?<start>.*?('/|>/|"/|\s|="))(Eth_.*)?TS_[A-Za-z0-9]*(?<rest>(/Eth|"/?>).*)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Eth_Definition?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Comment out Api Infix and Vendor ID of Eth" RelatedPackage="1">
				<PathRel>?CONST.Bswmd_PathRel?\\Eth_bswmd_rec\.arxml</PathRel>	
				<Pattern><![CDATA[.*((<VENDOR-ID>|<VENDOR-API-INFIX>).*(</VENDOR-ID>|</VENDOR-API-INFIX>)).*]]></Pattern>
				<ReplaceBOP><![CDATA[<!--$1-->]]></ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Comment in Api Infix and Vendor ID of Eth" RelatedPackage="1">
				<PathRel>?CONST.Bswmd_PathRel?\\Eth_bswmd_rec\.arxml</PathRel>	
				<Pattern><![CDATA[.*((<VENDOR-ID>|<VENDOR-API-INFIX>).*(</VENDOR-ID>|</VENDOR-API-INFIX>)).*]]></Pattern>
				<ReplaceBOP><![CDATA[$1]]></ReplaceBOP>
				<Condition Pattern="?CONST.Package_PathRel_Id2?\\plugins\\Eth_43_GMAC_TS_(.*)" Exist="true"/>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Patch Settings_Eth to Eth version" RelatedPackage="1">
				<PathRel>?CONST.Generator_PathRel?\\Settings_Eth\.xml</PathRel>
				<Pattern><![CDATA[(?<start>.*?<Event entityName=")(Eth.*)(?<rest>_MainFunction" value="0.01"/>.*)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Eth_Naming?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Patch InitFunctions_Settings to Eth version" RelatedPackage="1">
				<PathRel>?CONST.Generator_PathRel?\\InitFunctions_Settings\.xml</PathRel>
				<Pattern><![CDATA[(?<start>.*>)Eth(_43_GMAC)?(?<rest>\..+</.+>.*)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Eth_Naming?${rest}]]></ReplaceBOP>
			</ActionPatchFile>
			<ActionPatchFile Summary="Patch InitFunctions_Settings to Eth version" RelatedPackage="1">
				<PathRel>?CONST.Generator_PathRel?\\InitFunctions_Settings\.xml</PathRel>
				<Pattern><![CDATA[(?<start>.*(>|;)(?i)Eth(?-i))(_43_GMAC)?(?<rest>_.+</.+>.*)]]></Pattern>
				<ReplaceBOP><![CDATA[${start}?VAR.Eth_ApiInfix?${rest}]]></ReplaceBOP>
				<SkipPattern>.+Eth(_43_GMAC)?\.h.+</SkipPattern>
			</ActionPatchFile>
			
			<ActionPatchFile Summary="Adapt ETH_PACKAGE_NAME to Eth version" RelatedPackage="1">
				<PathRel>?CONST.Make_PathRel?\\Mcal_.*_rules\.mak$</PathRel>
				<Pattern>\A\s*(ETH_PACKAGE_NAME\s*=)(.*)</Pattern>
				<ReplaceBOP>$1 ?VAR.Eth_Naming?</ReplaceBOP>
			</ActionPatchFile>
			
			<GroupCondition>
				<Condition Pattern="?CONST.Package_PathRel_Id2?\\plugins\\Eth_(43_GMAC_)?TS_(.*)" Exist="true"/>
			</GroupCondition>
		</ActionGroup>
	</Finalize>
</MipConfig>