                              <SHORT-NAME>EMIOS_PWM_IP_PS_SRC_PRESCALED_CLOCK</SHORT-NAME>
                              <ORIGIN>NXP</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>EMIOS_PWM_IP_PS_SRC_MODULE_CLOCK</SHORT-NAME>
                              <ORIGIN>NXP</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                          </LITERALS>
                        </ECUC-ENUMERATION-PARAM-DEF>
                        <ECUC-ENUMERATION-PARAM-DEF UUID="ECUC:ff7e8cbd-e7a0-463c-b4bb-db946b032575">
                          <SHORT-NAME>EmiosChPolarity</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">
                                                        Define the output polarity of the channel.
                                                    </L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                          <ORIGIN>NXP</ORIGIN>
