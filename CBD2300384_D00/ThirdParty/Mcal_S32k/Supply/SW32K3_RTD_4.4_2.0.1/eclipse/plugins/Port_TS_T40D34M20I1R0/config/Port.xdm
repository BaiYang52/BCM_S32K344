====================================================================================================
-->
  <d:ctr type="AUTOSAR" factory="autosar"
         xmlns:ad="http://www.tresos.de/_projects/DataModel2/08/admindata.xsd"
         xmlns:icc="http://www.tresos.de/_projects/DataModel2/08/implconfigclass.xsd"
         xmlns:mt="http://www.tresos.de/_projects/DataModel2/11/multitest.xsd" >
    <d:lst type="TOP-LEVEL-PACKAGES">
      <d:ctr name="TS_T40D34M20I1R0" type="AR-PACKAGE">
      <a:a name="UUID" value="ECUC:f7df7962-be27-40e8-8f74-bbc5c1a39132"/>
      <d:lst type="ELEMENTS">
          <d:chc name="Port" type="AR-ELEMENT" value="MODULE-DEF">
          <v:ctr type="MODULE-DEF">
            <a:a name="RELEASE" value="asc:4.4"/>
             <a:a name="ADMIN-DATA" type="ADMIN-DATA">
                <ad:ADMIN-DATA>
                  <ad:DOC-REVISIONS>
                    <ad:DOC-REVISION>
                      <ad:REVISION-LABEL>4.3.0</ad:REVISION-LABEL>
                      <ad:ISSUED-BY>AUTOSAR</ad:ISSUED-BY>
                      <ad:DATE>2014-10-31</ad:DATE>
                    </ad:DOC-REVISION>
                  </ad:DOC-REVISIONS>
                </ad:ADMIN-DATA>
              </a:a>
              <a:a name="POSTBUILDVARIANTSUPPORT" value="true"/>
              <a:a name="DESC">
                 <a:v>
                    <![CDATA[EN:
                        <html>
                              <p>
                                  Configuration of the Port module.
                              </p>
                        </html>
                    ]]>
                 </a:v>
              </a:a>
              <a:a name="LOWER-MULTIPLICITY" value="0"/>
              <a:a name="UPPER-MULTIPLICITY" value="1"/>
              <a:a name="UUID" value="ECUC:4809f9e0-8b2f-4a53-bebc-cb48476511d0"/>
              <v:var name="POST_BUILD_VARIANT_USED" type="BOOLEAN">
                <a:a name="DESC">
                  <a:v>
                    <![CDATA[EN:
                        <html>
                              <p>
                                Indicates whether a module implementation has or plans to have (i.e., introduced at link or post-build time) new post-build variation points.
                              </p>
                        </html>
                    ]]>
                  </a:v>
                </a:a>
                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                  <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                </a:a>
                <a:a name="LABEL" value="Post Build Variant Used"/>
                    <a:a name="ORIGIN" value="EB"/>
                    <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                    <a:da name="DEFAULT" value="false"/>
                    <a:da name="READONLY" value="FALSE"/>
                    <a:da name="TOOLTIP"
                          value="Indicates whether a module implementation has or plans to have (i.e., introduced at link or post-build time) new post-build variation points."/>
              </v:var>
              <!-- /** @implements ConfigVariant_Object */ -->
              <v:var name="IMPLEMENTATION_CONFIG_VARIANT" type="ENUMERATION">
                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                  <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                </a:a>
                <a:a name="LABEL" value="Config Variant"/>
                <a:a name="UUID" value="ECUC:255d6fd8-fffe-4dfb-a825-cad89b99b224"/>
                <a:a name="DESC">
                  <a:v>
                    <![CDATA[EN:
                        <html>
                          <p>
                            VariantPreCompile: Only precompile time configuration parameters. Only one set of parameters.
                            VariantPostBuild: Mix of precompile and postbuild time configuration parameters. Only one set of parameters.
                            If Config Variant = VariantPreCompile, the files Port_Cfg.h and Port_Cfg.c should be used.
                            If Config Variant = VariantPostBuild, the files Port_Cfg.h and Port_PBcfg.c should be used.
                          </p>
                        </html>
                        ]]>
                  </a:v>
                </a:a>
                <a:da name="DEFAULT" value="VariantPostBuild"/>
                <a:da name="RANGE">
                  <a:v>VariantPostBuild</a:v>
                  <a:v>VariantPreCompile</a:v>
                </a:da>
              </v:var>

                <!-- @implements PortConfigSet_Object -->
                <v:ctr name="PortConfigSet" type="IDENTIFIABLE">
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                              This container contains a configuration of the PORT driver / SIUL2 module.
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                <a:a name="UUID" value="ECUC:1f97de8a-e44f-4fd8-b302-4f1dc3cb96be"/>
              <!-- @implements NotUsedPortPin_Object -->
              <v:ctr name="NotUsedPortPin" type="IDENTIFIABLE">
                <a:a name="DESC">
                <a:v>
                  <![CDATA[EN:
                    <html>
                      <p>
                        The init parameters values for the not used pins in the PORT configuration.
                      </p>
                    </html>
                  ]]>
                </a:v>
                </a:a>
                <a:a name="UUID" value="ECUC:34d31eeb-49e6-4eff-b612-5445e4629a75"/>
                <v:var name="PortPinPue" type="BOOLEAN">
                  <a:a name="LABEL" value="PortPin Pull Enable"/>
                  <a:a name="DESC">
                  <a:v>
                    <![CDATA[EN:
                      <html>
                        <p>
                          Enables the pull function. Used only when the associated destination is a chip pin.
                          Checked box means the Pull Up or Pull Down configuration selected by 'PortPin PUS' is enabled for the pin.
                          Unchecked box means the Pull Up or Pull Down configuration selected by 'PortPin PUS' is disabled for the pin.
                          This is an implementation specific parameter.
                        </p>
                      </html>
                    ]]>
                  </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:8cae8cfa-482d-4356-ae6c-670a6580ecbf"/>
                  <a:da name="DEFAULT" value="false"/>
                </v:var>
                <v:var name="PortPinPus" type="BOOLEAN">
                  <a:a name="LABEL" value="PortPin Pull Select"/>
                  <a:a name="DESC">
                  <a:v>
                    <![CDATA[EN:
                      <html>
                        <p>
                            Determines whether the pull function is a pullup or pulldown when the pull function is enabled by the 'PortPin Pull Enable' field. Used only when the associated destination is a chip pin.
                            Checked box means the Pull Up configuration is set. Unchecked box means the Pull Down configuration is set.
                            This is an implementation specific parameter.
                        </p>
                      </html>
                    ]]>
                  </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:0d69f19a-546e-490b-85a9-efb83b184133"/>
                  <a:da name="DEFAULT" value="false"/>
                  <a:da name="EDITABLE" type="XPath">
                      <a:tst expr="(../PortPinPue = 'true')"/>
                  </a:da>
                </v:var>
                <!-- PortPinDirection in NotUsedPortPin -->
                <v:var name="PortPinDirection" type="ENUMERATION">
                  <a:a name="LABEL" value="PortPin Direction"/>
                  <a:a name="DESC">
                  <a:v>
                          <![CDATA[EN:
                            <html>
                              <p>
                                Selects the initial direction of the pin (IN or OUT). If the direction is not changeable, the value configured here is fixed.
                                The pin direction can be set only for the GPIO pins. For the Alternative Function
                                modes the OUT pin direction is hw selected.
                                If the IN direction is needed too, it can be set at runtime.
                                NOTE: To set the IN direction take care, please, that all the possible module
                                inputs, possible as Alternative Functions for the pad mode,
                                are hw connected together, if IN direction is enabled, to the pad.
                              </p>
                            </html>
                          ]]>
                  </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:581a4f2f-c659-477d-a525-acb268820776"/>
                  <a:da name="DEFAULT" value="PORT_PIN_IN"/>
                  <a:da name="RANGE">
                    <a:v>PORT_PIN_IN</a:v>
                    <a:v>PORT_PIN_OUT</a:v>
                    <a:v>PORT_PIN_DISABLED</a:v>
                  </a:da>
                </v:var>
                <v:var name="PortPinLevelValue" type="ENUMERATION">
                  <a:a name="LABEL" value="PortPin Level Value"/>
                  <a:a name="DESC">
                  <a:v>
                          <![CDATA[EN:
                            <html>
                              <p>
                                Port Pin Level value from Port pin list.
                              </p>
                            </html>
                          ]]>
                  </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID"
                           value="ECUC:c45ce513-7add-4b12-969c-336326e00ed7"/>
                  <a:da name="DEFAULT" value="PORT_PIN_LEVEL_LOW"/>
                  <a:da name="RANGE">
                    <a:v>PORT_PIN_LEVEL_HIGH</a:v>
                    <a:v>PORT_PIN_LEVEL_LOW</a:v>
                  </a:da>
                </v:var>
              </v:ctr>
                  <v:lst name="PortContainer" type="MAP">
                    <a:da name="MIN" value="1"/>
                    <!-- @implements PortContainer_Object -->
                    <v:ctr name="PortContainer" type="IDENTIFIABLE">
                       <a:a name="DESC">
                        <a:v>
                          <![CDATA[EN:
                              <html>
                                <p>
                                  Container collecting the PortPins.
                                </p>
                              </html>
                              ]]>
                        </a:v>
                      </a:a>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                    <a:v name="LOWER-MULTIPLICITY" value="1"/>
                    <a:v name="UPPER-MULTIPLICITY" value="*"/>
                      <a:a name="UUID"
                           value="ECUC:66380587-564d-45f3-bada-0475671e8218"/>
                       <v:var name="PortNumberOfPortPins" type="INTEGER">
                        <a:a name="LABEL" value="PortNumberOfPortPins"/>
                        <a:a name="DESC">
                          <a:v>
                            <![CDATA[EN:
                                <html>
                                  <p>
                                    The number of specified PortPins in this PortContainer.
                                  </p>
                                </html>
                                ]]>
                          </a:v>
                        </a:a>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID"
                            value="ECUC:00c84eb8-abf4-4a15-8e65-df9036e47464"/>
                        <a:da name="DEFAULT" type="XPath">
                            <a:tst expr="num:i(count(node:fallback(node:current()/../PortPin/*,text:split('1 2 3'))))"/>
                        </a:da>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&gt;=1"/>
                          <a:tst expr="&lt;= num:i(ecu:list(&apos;Port.Siul2MaxNumConfiguredMscrs&apos;)[1])"/>
                        </a:da>
                        <a:da name="RANGE" type="XPath">
                            <a:tst expr="node:fallback(., 1) = count(node:fallback(node:current()/../PortPin/*,text:split('1 2 3')))" false=" For calculating the correct value use the CALC button"/>
                        </a:da>
                        <a:da name="TOOLTIP" type="XPath" expr="num:i(num:i(count(node:current()/../PortPin/*)))">
                        </a:da>
                      </v:var>
                      <v:lst name="PortPin" type="MAP">
                        <a:da name="MIN" value="1"/>
                        <!-- @implements PortPin_Object -->
                        <v:ctr name="PortPin" type="IDENTIFIABLE">
                           <a:a name="DESC">
                            <a:v>
                              <![CDATA[EN:
                                  <html>
                                    <p>
                                      Configuration of the individual port pins.
                                    </p>
                                  </html>
                                  ]]>
                            </a:v>
                          </a:a>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:v name="LOWER-MULTIPLICITY" value="1"/>
                          <a:v name="UPPER-MULTIPLICITY" value="*"/>
                          <a:a name="UUID"
                               value="ECUC:c9c0881a-4bdf-473c-affd-831828ab4064"/>
                          <v:var name="PortPinPue" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Pull Enable"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                  <html>
                                    <p>
                                      Enables the pull function. Used only when the associated destination is a chip pin.
                                      Checked box means the Pull Up or Pull Down configuration selected by 'PortPin PUS' is enabled for the pin.
                                      Unchecked box means the Pull Up or Pull Down configuration selected by 'PortPin PUS' is disabled for the pin.
                                      This is an implementation specific parameter.
                                    </p>
                                  </html>
                                ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:3f14d3ba-dc79-447e-a196-fae15c7b4971"/>
                            <a:da name="DEFAULT" value="false"/>
                          </v:var>
                          <v:var name="PortPinPus" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Pull Select"/>
                            <a:a name="DESC">
                              <a:v>
                                    <![CDATA[EN:
                                      <html>
                                        <p>
                                            Determines whether the pull function is a pullup or pulldown when the pull function is enabled by the 'PortPin Pull Enable' field. Used only when the associated destination is a chip pin.
                                            Checked box means the Pull Up configuration is set. Unchecked box means the Pull Down configuration is set.
                                            This is an implementation specific parameter.
                                        </p>
                                      </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:6264733b-bdb5-403c-adec-d19317befed0"/>
                            <a:da name="DEFAULT" value="false"/>
                            <a:da name="EDITABLE" type="XPath">
                              <a:tst expr="(../PortPinPue = 'true')"/>
                            </a:da>
                          </v:var>
                          <v:var name="PortPinSafeMode" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Safe Mode"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Enable/Disable Safe Mode for the pin. Checked box means the Safe Mode is enabled.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:808fe5d3-7146-48d1-a06d-607300915665"/>
                            <a:da name="DEFAULT" value="false"/>
                            <a:da name="EDITABLE" type="XPath">
                              <a:tst expr="(../PortPinDirection = 'PORT_PIN_OUT') or (../PortPinDirection = 'PORT_PIN_INOUT')" true="true" false="false"/>
                            </a:da>
                          </v:var>
                          <v:var name="PortPinDse" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Drive Strength"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Enable Drive Strength for the configured Pin.
                                        Checked box means the Drive Strength is enabled.
                                        This is an implementation specific parameter.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:b3dbe90t-8ffe-445f-adse-19ffeb93f633"/>
                            <a:da name="DEFAULT" value="false"/>
                            <a:da name="EDITABLE" type="XPath">
                              <a:tst expr="(contains(node:fallback(../PortPinSiul2Instance,'SIUL2_0'),'SIUL2_0') and contains(concat(',',string(ecu:get(&apos;Port.PinsWithDSE&apos;)),','),concat(',',node:fallback(../PortPinPcr,0),',')))"/>
                            </a:da>
                          </v:var>
                          <!-- @implements PortPinReadBackEnable_Object -->
                          <v:var name="PortPinWithReadBack" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin With Read Back"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                  <html>
                                    <p>
                                      Enables/Disables the read back possibility for this pin. Checked box means the Read Back is enabled.
                                      When ReadBack is enabled, the Input Bufer of the pin gets enabled by setting the IBE bit in the MSCR (PCR) of the pin. Some alternate functions working as inputs might require having the IBE set to 1, so check this box in order to achieve this.
                                    </p>
                                  </html>
                                ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:f712457c-829e-4617-94f2-5bfdc472c24f"/>
                            <a:da name="DEFAULT" value="false"/>
                          </v:var>
                          <v:var name="PortPinPke" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Pull Keeper"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                  <html>
                                    <p>
                                      Enables/disables pad keeping in standby mode. When padkeeping is enabled in standby mode, the pad output path latches the value till standby exit.
                                      Checked box means pad keeping in stanby mode is enabled for the pin.
                                      This is an implementation specific parameter.
                                    </p>
                                  </html>
                                ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:7aaf50db-a989-41bb-bcea-5a3731c6647a"/>
                            <a:da name="DEFAULT" value="false"/>
                          </v:var>
                          <v:var name="PortPinIfe" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Input Filter Enable"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                  <html>
                                    <p>
                                      Enables/disables Input Filter.
                                      Checked box means Input Filter is enabled for the pin.
                                      This is an implementation specific parameter.
                                    </p>
                                  </html>
                                ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:7bcf50db-b989-41bb-bcea-5a3731c6647a"/>
                            <a:da name="DEFAULT" value="false"/>
                            <a:da name="EDITABLE" type="XPath">
                              <a:tst expr="(contains(node:fallback(../PortPinSiul2Instance,'SIUL2_0'),'SIUL2_0') and contains(concat(',',string(ecu:get(&apos;Port.PinsWithIF&apos;)),','),concat(',',node:fallback(../PortPinPcr,0),',')))"/>
                            </a:da>
                          </v:var>
                          <!-- @implements PortPinDirectionChangeable_Object -->
                          <v:var name="PortPinDirectionChangeable" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Direction Changeable"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Enable/Disable the changeability for the configured Pin. Checked box means the Direction Changeability is enabled.
                                        This is an implementation specific parameter. The changeable pin direction can be set only for the GPIO pins.
                                        For a mode different than GPIO, pin direction changeability shall be disabled.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID"
                                 value="ECUC:d4fda3be-5de0-4f40-95c8-1e101267c3d3"/>
                            <a:da name="DEFAULT" value="true"/>
                            <a:da name="EDITABLE" type="XPath">
                                <a:tst expr="(../PortPinMode = 'GPIO')" true="true" false="false"/>
                            </a:da>
                          </v:var>
                          <!-- @implements PortPinModeChangeable_Object -->
                          <v:var name="PortPinModeChangeable" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Mode Changeable"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Parameter to indicate if the mode of a port pin is changeable during runtime.
                                        Checked box: Port Pin mode changeable allowed.
                                        Unchecked box: Port Pin mode changeable not permitted
                                        The function for changing the pin modes is not supported by the safety implementation.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID"
                                 value="ECUC:53861334-fe2d-41df-8bf8-19c4189819b7"/>
                            <a:da name="DEFAULT" value="true"/>
                          </v:var>
                          <!-- @implements PortPinInvertControl_Object -->
                          <v:var name="PortPinInvertControl" type="BOOLEAN">
                            <a:a name="LABEL" value="PortPin Invert Control"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                      Invert the signal selected by SSS before transmitting it to the associated destination.
                                      Checked box means the signal will be inverted.
                                      This is an implementation specific parameter.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID"
                                 value="ECUC:53861334-fe2d-41df-8bf8-19c4189819b6"/>
                            <a:da name="DEFAULT" value="false"/>
                            <a:da name="INVALID" type="XPath">
                            <a:tst expr="((../../../../../../PortGeneral/SignalInversionConfigEnable ='false') and (. = 'true'))"
                          true="Port Signal Inversion Config Enable must be enabled in Port/PortGeneral/SignalInversionConfigEnable before enabling the PortPinInvertControl for each pins."/>
                            </a:da>
                          </v:var>
                          <v:var name="PortPinSiul2Instance" type="ENUMERATION">
                            <a:a name="LABEL" value="PortPin SIUL2 Instance"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Selects one of the SIULs instances available on the platform to configure the current pin from.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:daca2411-31e0-493f-8e05-3716f0464317"/>
                            <a:da name="DEFAULT" type="XPath" expr="ecu:list('Port.Siul2Instances')[1]"/>
                            <a:da name="RANGE" type="XPath" expr="ecu:list('Port.Siul2Instances')"/>
                          </v:var>
                          <!-- @implements PortPinId_Object -->
                          <v:var name="PortPinId" type="INTEGER">
                            <a:a name="LABEL" value="PortPin Id"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Pin Id of the port pin.
                                        This value will be assigned to the symbolic name
                                        derived from the port pin container short name.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="true"/>
                            <a:a name="UUID"
                                 value="ECUC:89dc979d-14a5-4550-b3a3-ee44747d6f11"/>
                            <a:da name="DEFAULT" type="XPath" expr="num:i((node:fallback(node:current()/../@index, '1')) + 1 + (count(node:fallback(../../../../*/PortPin/*/PortPinId,text:split('1 2 3')))) - count(node:fallback(../../*,text:split('1 2 3'))))"/>
                            <a:da name="INVALID" type="Range">
                                <a:tst expr="&gt;=1"/>
                                <a:tst expr="&lt;= num:i(ecu:list(&apos;Port.Siul2MaxNumConfiguredMscrs&apos;)[1])"/>
                            </a:da>
                            <a:da name="RANGE" type="XPath">
                                 <a:tst expr="text:uniq((node:fallback(../../../../*/PortPin/*/PortPinId,text:split('1 2 3'))), node:fallback(.,0))" false="The value of PortPinId is not unique for this configuration."/>
                                 <a:tst expr="node:fallback(., 0) &lt; (count(node:fallback(../../../../*/PortPin/*, text:split('1 2 3'))) + 1)" false="The value of PortPinId can't be higher than the number of defined pins"/>
                            </a:da>
                          </v:var>
                          <v:var name="PortPinPcr" type="INTEGER">
                            <a:a name="LABEL" value="PortPin Mscr"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Used to specify port configuration register: SIUL I/O Pin Multiplexed Signal Configuration Registers (MSCR number).
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:dd244e5b-63e5-4534-9012-a434f9a7a30a"/>
                            <a:da name="DEFAULT" type="XPath" expr="num:i((node:fallback(node:current()/../@index, '0') + 0) + (count(node:fallback(../../../../*/PortPin/*/PortPinPcr,text:split('1 2 3')))) - count(node:fallback(../../*,text:split('1 2 3'))))"/>
                            <a:da name="INVALID" type="Range">
                              <a:tst expr="&gt;=0"/>
                              <a:tst expr="&lt;=num:i(ecu:list(&apos;Port.Num16PinsBlocks&apos;)[1] * 16)"/>
                            </a:da>
                          </v:var>
                          <!-- PortPinDirection in PortPinlist -->
                          <!-- @implements PortPinDirection_Object -->
                          <v:var name="PortPinDirection" type="ENUMERATION">
                            <a:a name="LABEL" value="PortPin Direction"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Selects the direction of the pin (IN, OUT , INOUT or HIGH_Z) that will be configured by Port_Init() function if the pin is configured as GPIO.
                                        If the direction is not changeable, the value configured here is fixed. For the Alternative Function modes (PortPinMode is different than GPIO),
                                        the setting in this enumeration control is kept in the port configuration structure and it is used when Port_SetPinMode() is called at runtime to change the mode of the pin to GPIO.
                                        If your Alternative Function is an input functionality that requires the IBE bit to be set in the MSCR, please select the checkbox 'PortPinWithReadback.
                                        If direction is PORT_PIN_HIGH_Z, there will be no initial direction setting.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="ECUC:dafa241d-31e0-493f-8e05-3716f0464317"/>
                            <a:da name="DEFAULT" type="XPath">
                              <a:tst expr="contains(node:fallback(../PortPinMode,'ADC'),'ADC')" true="PORT_PIN_HIGH_Z" false="PORT_PIN_IN"/>
                            </a:da>
                            <a:da name="RANGE">
                              <a:v>PORT_PIN_IN</a:v>
                              <a:v>PORT_PIN_OUT</a:v>
                              <a:v>PORT_PIN_INOUT</a:v>
                              <a:v>PORT_PIN_HIGH_Z</a:v>
                            </a:da>
                            <a:da name="TOOLTIP" value="Use 'Calculate value' near PortPinDirection to get the default value"/>
                          </v:var>
                          <v:var name="PortPinInitialMode" type="ENUMERATION">
                            <a:a name="LABEL" value="PortPin Initial Mode"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Port pin mode from mode list for use with Port_Init() function.
                                        NOTE: This parameter is not used in the current implementation and is retained as per std
                                        AUTOSAR_EcucParamDef.arxml file.
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID"
                                 value="ECUC:62444a8a-0d6a-43a5-b035-23fce3437ddf"/>
                            <a:da name="DEFAULT" value="PORT_GPIO_MODE"/>
                            <a:da name="READONLY" value="true"/>
                            <a:da name="RANGE">
                              <a:v>PORT_GPIO_MODE</a:v>
                              <a:v>PORT_ALT1_FUNC_MODE</a:v>
                              <a:v>PORT_ALT2_FUNC_MODE</a:v>
                              <a:v>PORT_ALT3_FUNC_MODE</a:v>
                              <a:v>PORT_ANALOG_INPUT_MODE</a:v>
                              <a:v>PORT_ONLY_INPUT_MODE</a:v>
                              <a:v>PORT_EXTRA_INPUT_MODE</a:v>
                            </a:da>
                          </v:var>
                          <!-- @implements PortPinMode_Object -->
                          <v:var name="PortPinMode" type="ENUMERATION">
                            <a:a name="LABEL" value="PortPin Mode"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                <html>
                                  <p>
                                    Selects the PORT pin mode from the modes list. One or more modes may be valid for a pin. This way it is
                                    possible to select between multiple modes.( e.g. DIO (GPIO option) or ICU (eTimer option)).
                                  </p>
                                </html>
                                ]]>
                              </a:v>
                            </a:a>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                   type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID"
                                   value="ECUC:26e74eb3-84f4-4fd1-9bf9-9f2017b39257"/>
                              <a:da name="DEFAULT" value="GPIO"/>
                              <a:da name="RANGE" type="XPath">
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="GPIO"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_0_eMIOS_0_CH_17_Y_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="LCU0_LCU0_OUT4"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="FXIO_FXIO_D2_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_1_eMIOS_1_CH_0_X_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="LPSPI0_LPSPI0_PCS7_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="TRGMUX_TRGMUX_OUT3"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="ADC0_ADC0_S8"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="CMP1_CMP1_IN0"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="SIUL_EIRQ_0"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_0_eMIOS_0_CH_17_Y_IN"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_1_eMIOS_1_CH_0_X_IN"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="FXIO_FXIO_D2_IN"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="LPSPI0_LPSPI0_PCS7_IN"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="LPUART0_LPUART0_CTS"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_0_eMIOS_0_CH_17_Y_INOUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="FXIO_FXIO_D2_INOUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_1_eMIOS_1_CH_0_X_INOUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 0 and ecu:get('Port.Derivative')='s32k312'" true="LPSPI0_LPSPI0_PCS7_INOUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="GPIO"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_0_eMIOS_0_CH_9_H_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="LPUART0_LPUART0_RTS"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="FXIO_FXIO_D3_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="LCU0_LCU0_OUT5"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="LPSPI0_LPSPI0_PCS6_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="TRGMUX_TRGMUX_OUT0"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="ADC0_ADC0_S9"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="CMP1_CMP1_IN1"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="WKPU_WKPU_5"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="SIUL_EIRQ_1"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_0_eMIOS_0_CH_9_H_IN"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="FXIO_FXIO_D3_IN"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="LPSPI0_LPSPI0_PCS6_IN"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_0_eMIOS_0_CH_9_H_INOUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="FXIO_FXIO_D3_INOUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 1 and ecu:get('Port.Derivative')='s32k312'" true="LPSPI0_LPSPI0_PCS6_INOUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="GPIO"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="FCCU_FCCU_ERR0"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="eMIOS_1_eMIOS_1_CH_19_Y_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="FXIO_FXIO_D4_OUT"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="LCU0_LCU0_OUT3"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="ADC1_ADC1_X_0"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="WKPU_WKPU_0"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="CMP1_CMP1_IN2"/>
                                  <a:tst expr="node:fallback(../PortPinPcr, 0) = 2 and ecu:get('Port.Derivative')='s32k312'" true="SIUL_EIRQ_2"/>
