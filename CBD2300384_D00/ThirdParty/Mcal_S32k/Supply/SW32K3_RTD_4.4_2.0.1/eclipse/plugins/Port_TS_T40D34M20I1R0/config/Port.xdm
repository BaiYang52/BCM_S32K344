                                <a:tst expr="node:fallback(../PortPinPcr, 0) = 150 and node:fallback(../PortPinMode, 0) = 'GPIO' and ((ecu:get('Port.Derivative')='s32k314') or (ecu:get('Port.Derivative')='s32k324') or (ecu:get('Port.Derivative')='s32k344'))" true="OBE_GROUP2"/>
                                <a:tst expr="node:fallback(../PortPinPcr, 0) = 151 and node:fallback(../PortPinMode, 0) = 'GPIO' and ((ecu:get('Port.Derivative')='s32k314') or (ecu:get('Port.Derivative')='s32k324') or (ecu:get('Port.Derivative')='s32k344'))" true="OBE_GROUP2"/>
                                <a:tst expr="node:fallback(../PortPinPcr, 0) = 152 and node:fallback(../PortPinMode, 0) = 'GPIO' and ((ecu:get('Port.Derivative')='s32k314') or (ecu:get('Port.Derivative')='s32k324') or (ecu:get('Port.Derivative')='s32k344'))" true="OBE_GROUP2"/>
                                <a:tst expr="node:fallback(../PortPinPcr, 0) = 153 and node:fallback(../PortPinMode, 0) = 'GPIO' and ((ecu:get('Port.Derivative')='s32k314') or (ecu:get('Port.Derivative')='s32k324') or (ecu:get('Port.Derivative')='s32k344'))" true="OBE_GROUP2"/>
                                <a:tst expr="node:fallback(../PortPinPcr, 0) = 154 and node:fallback(../PortPinMode, 0) = 'GPIO' and ((ecu:get('Port.Derivative')='s32k314') or (ecu:get('Port.Derivative')='s32k324') or (ecu:get('Port.Derivative')='s32k344'))" true="OBE_GROUP2"/>
                            </a:da>
                            <a:da name="EDITABLE" type="XPath">
                              <a:tst expr="(../../../../../../PortGeneral/PortTspcSupport = 'true')"/>
                            </a:da>
                          </v:var>
                          <!-- @implements MscrPdacSlot_Object -->
                          <v:var name="MscrPdacSlot" type="ENUMERATION">
                            <a:a name="LABEL" value="MSCR VirtWrapper PDAC"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Select the PDAC slot for PortPin controlling MSCR, GPDO, PGPDO, and MPGPDO
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID"
                                 value="ECUC:62444a8a-0d6a-43a5-b035-23fce3437dde"/>
                            <a:da name="DEFAULT" value="VIRTUAL_WRAPPER_PDAC0"/>
                            <a:da name="EDITABLE" type="XPath" expr="((../../../../../../PortGeneral/VirtWrapperSupport ='true') and (not(node:exists('ASPathDataOfSchema:/AUTOSAR/EcucDefs/Rm/'))))"/>
                            <a:da name="RANGE" type="XPath" expr="ecu:list('Port.PdacSlot')"></a:da>
                          </v:var>
                          <!-- @implements ImcrPdacSlot_Object -->
                          <v:var name="ImcrPdacSlot" type="ENUMERATION">
                            <a:a name="LABEL" value="IMCR VirtWrapper PDAC"/>
                            <a:a name="DESC">
                              <a:v>
                                <![CDATA[EN:
                                    <html>
                                      <p>
                                        Select the PDAC slot for PortPin controlling IMCR
                                      </p>
                                    </html>
                                    ]]>
                              </a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="NXP"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID"
                                 value="ECUC:62444a8a-0d6a-43a5-b035-23fce3437ddc"/>
                            <a:da name="DEFAULT" value="VIRTUAL_WRAPPER_PDAC0"/>
                            <a:da name="EDITABLE" type="XPath" expr="((../../../../../../PortGeneral/VirtWrapperSupport ='true') and (not(node:exists('ASPathDataOfSchema:/AUTOSAR/EcucDefs/Rm/'))))"/>
                            <a:da name="RANGE" type="XPath" expr="ecu:list('Port.PdacSlot')"></a:da>
                          </v:var>
                          <!-- @implements PortPinEcucPartitionRef_Object -->
                          <v:lst name="PortPinEcucPartitionRef">
                          <a:da name="INVALID" type="XPath">
                            <a:tst expr="(num:i(count(./*)) = 0) and (num:i(count(../../../../../../PortGeneral/PortEcucPartitionRef/*)) > 0)" true="At least one partition need to be defined in PortPinEcucPartitionRef"/>
                          </a:da>
                          <v:ref name="PortPinEcucPartitionRef" type="REFERENCE">
                            <a:a name="DESC">
                              <a:v>EN: Maps the Port pin to zero a multiple ECUC partitions. The ECUC partitions referenced are a subset of the ECUC partitions where the Port driver is mapped to.</a:v>
                              <a:v>EN: Tags: atp.Status=draft</a:v>
                            </a:a>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                              <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="true"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SCOPE" value="ECU"/>
                            <a:a name="UUID" value="ECUC:14ac88hh-619e-4029-a793-3535990384ad"/>
                            <a:da name="REF" value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/EcuC/EcucPartitionCollection/EcucPartition"/>
                            <a:da name="INVALID" type="XPath">
                              <a:tst expr="text:uniq(../*, .)" false="Duplicate Partition."/>
                              <a:tst expr="count(text:grep(../../../../../../../PortGeneral/PortEcucPartitionRef/*,.)) > 0"
                                false="The ECUC partition must be defined on the PortEcucPartitionRef."/>
                            </a:da>
                          </v:ref>
                          </v:lst>
                           </v:ctr>
                          </v:lst>
                       </v:ctr>
                     </v:lst>
                    <!-- @implements UnTouchedPortPin_Object -->
                    <v:lst name="UnTouchedPortPin" type="MAP">
                      <a:da name="MIN" value="0"/>
                      <v:ctr name="UnTouchedPortPin" type="IDENTIFIABLE">
                       <a:a name="DESC">
                        <a:v>
                          <![CDATA[EN:
                              <html>
                                <p>
                                  List containing Pins that will not be touched by Port_Init() function.
                                </p>
                              </html>
                              ]]>
                        </a:v>
                      </a:a>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:v name="LOWER-MULTIPLICITY" value="1"/>
                      <a:v name="UPPER-MULTIPLICITY" value="*"/>
                      <a:a name="UUID" value="ECUC:d9c0881a-4bdf-473c-affd-831828ab4064"/>
                      <v:var name="PortPinSiul2Instance" type="ENUMERATION">
                        <a:a name="LABEL" value="PortPin SIUL2 Instance"/>
                        <a:a name="DESC">
                          <a:v>
                            <![CDATA[EN:
                                <html>
                                  <p>
                                    Selects one of the SIULs instances available on the platform to configure the current pin from.
                                  </p>
                                </html>
                                ]]>
                          </a:v>
                        </a:a>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="NXP"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID" value="ECUC:daca2423-31e0-493f-8e05-3716f0464317"/>
                        <a:da name="DEFAULT" type="XPath" expr="ecu:list('Port.Siul2Instances')[1]"/>
                        <a:da name="RANGE" type="XPath" expr="ecu:list('Port.Siul2Instances')"/>
                      </v:var>
                      <v:var name="PortPinPcr" type="INTEGER">
                        <a:a name="LABEL" value="PortPin Mscr"/>
                        <a:a name="DESC">
                          <a:v>
                            <![CDATA[EN:
                                <html>
                                  <p>
                                    Used to specify port configuration register: SIUL I/O Pin Multiplexed Signal Configuration Registers (MSCR number).
                                  </p>
                                </html>
                                ]]>
                          </a:v>
                        </a:a>
                        <a:a name="ORIGIN" value="NXP"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID" value="ECUC:ad244e5b-63e5-4534-9012-a214f9a7a30a"/>
                        <a:da name="DEFAULT" type="XPath" expr="ecu:list('Port.MscrJtagPins')[num:i(node:fallback(node:current()/../@index, num:i(0)) + 1)]"/>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&gt;=0"/>
                          <a:tst expr="&lt;=num:i(ecu:list(&apos;Port.Num16PinsBlocks&apos;)[1] * 16)"/>
                        </a:da>
                      </v:var>
                     </v:ctr>
                  </v:lst>
                  <!-- @implements UntouchedIMCR_Object -->
                  <v:lst name="UntouchedIMCR" type="MAP">
                      <a:da name="MIN" value="0"/>
                      <v:ctr name="UntouchedIMCR" type="IDENTIFIABLE">
                       <a:a name="DESC">
                        <a:v>
                          <![CDATA[EN:
                              <html>
                                <p>
                                  List containing IMCR of Pins that will not be touched by Port_Init() function.
                                </p>
                              </html>
                              ]]>
                        </a:v>
                      </a:a>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:v name="LOWER-MULTIPLICITY" value="1"/>
                      <a:v name="UPPER-MULTIPLICITY" value="*"/>
                      <a:a name="UUID"
                           value="ECUC:d9c0881a-4bdf-473c-affd-831829jk1064"/>
                      <v:var name="IMCRSiul2Instance" type="ENUMERATION">
                        <a:a name="LABEL" value="IMCR SIUL2 Instance"/>
                        <a:a name="DESC">
                          <a:v>
                            <![CDATA[EN:
                                <html>
                                  <p>
                                    Selects one of the SIULs instances available on the platform to configure the current IMCR.
                                  </p>
                                </html>
                                ]]>
                          </a:v>
                        </a:a>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="NXP"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID" value="ECUC:daca2423-31e0-493f-8e05-37188p464317"/>
                        <a:da name="DEFAULT" type="XPath" expr="ecu:list('Port.Siul2Instances')[1]"/>
                        <a:da name="RANGE" type="XPath" expr="ecu:list('Port.Siul2Instances')"/>
                      </v:var>
                      <v:var name="UntouchedPortPinImcr" type="INTEGER">
                        <a:a name="LABEL" value="UntouchedPortPin Imcr"/>
                        <a:a name="DESC">
                          <a:v>
                            <![CDATA[EN:
                                <html>
                                  <p>
                                    Selects one of the IMCR will be Untouched
                                  </p>
                                </html>
                                ]]>
                          </a:v>
                        </a:a>
                        <a:a name="ORIGIN" value="NXP"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID" value="ECUC:ad24re5b-63e5-476h-1fgs-a214f9a7a30a"/>
                        <a:da name="DEFAULT" type="XPath" expr="num:i((node:fallback(node:current()/../@index, '0')) + (count(node:fallback(../../../UntouchedIMCR/*/UntouchedPortPinImcr,text:split('1 2 3')))) - count(node:fallback(../../*,text:split('1 2 3'))))"/>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&gt;=0"/>
                          <a:tst expr="&lt;=num:i(ecu:get('Port.Siul2InstanceNumImcrs'))"/>
                        </a:da>
                      </v:var>
                     </v:ctr>
                  </v:lst>
                </v:ctr>
              <!-- @implements PortGeneral_Object -->
              <v:ctr name="PortGeneral" type="IDENTIFIABLE">
                <a:a name="DESC">
                  <a:v>
                    <![CDATA[EN:
                        <html>
                          <p>
                            Module wide configuration parameters of the PORT driver.
                          </p>
                        </html>
                        ]]>
                  </a:v>
                </a:a>
                <a:a name="UUID" value="ECUC:002fc40a-1304-484b-980a-9290886a1f0b"/>
                <!-- @implements PortDevErrorDetect_Object -->
                <v:var name="PortDevErrorDetect" type="BOOLEAN">
                  <a:a name="LABEL" value="Port Development Error Detect"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                              Switches the Development Error Detection and Notification ON or OFF.
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                       type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:6a7bcc4d-97ad-4a4a-a4bd-a3e4a89090c2"/>
                  <a:da name="DEFAULT" value="true"/>
                </v:var>
                <!--  @implements SIUL2PortIPDevErrorDetect_Object  -->
                <v:var name="SIUL2PortIPDevErrorDetect" type="BOOLEAN">
                  <a:a name="LABEL" value="SIUL2 IP Port Development Error Detect" />
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                                                <html><p>
                                                    Enables and Disables DevAssert checks in IP code.<br>
                                                    True: Enabled.<br>
                                                    False: Disabled.<br>
                                                </p></html>
                                            ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP" />
                  <a:a name="SCOPE" value="LOCAL" />
                  <a:a name="SYMBOLICNAMEVALUE" value="false" />
                  <a:a name="UUID" value="ECUC:068c841e-9f94-429d-b5a8-c10387eefd19" />
                  <a:da name="DEFAULT" value="false" />
                </v:var>
                <!-- @implements PortSetPinDirectionApi_Object -->
                <v:var name="PortSetPinDirectionApi" type="BOOLEAN">
                  <a:a name="LABEL" value="Port SetPinDirection Api"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                              Pre-processor switch to enable/disable the use of the function Port_SetPinDirection().
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                       type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:f223bc4c-3516-482a-ae62-48f144566318"/>
                  <a:da name="DEFAULT" value="true"/>
                </v:var>
                <!-- @implements PortSetPinModeApi_Object -->
                <v:var name="PortSetPinModeApi" type="BOOLEAN">
                  <a:a name="LABEL" value="Port SetPinMode Api"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                              The function for changing the pin modes is not supported by the safety implementation.
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:1f7dd044-d03f-43b6-842f-d9374c1d2746"/>
                  <a:da name="DEFAULT" value="true"/>
                </v:var>
                <!-- @implements PortVersionInfoApi_Object -->
                <v:var name="PortVersionInfoApi" type="BOOLEAN">
                  <a:a name="LABEL" value="Port VersionInfo Api"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                               Pre-processor switch to enable/disable the API to read out the modules version information.
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:2c37b26f-6eb3-4634-b10b-a635599a9f1b"/>
                  <a:da name="DEFAULT" value="true"/>
                </v:var>
                <!-- @implements PortSetPinModeDoesNotTouchGpioLevel_Object -->
                <v:var name="PortSetPinModeDoesNotTouchGpioLevel" type="BOOLEAN">
                  <a:a name="LABEL" value="Port SetPinMode Does Not Touch GPIO Levels"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                               Pre-processor switch. When not checked, the function Port_SetPinMode() will set the output level of the pin to the value configured in the PortPinLevelValue combo when called at run time to change mode of a pin from alternate function to GPIO. When checked, the function Port_SetPinMode() will not touch the output level of the pin when called at run time to change mode of a pin from alternate function to GPIO.
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:2c37b26f-6cb3-4634-b20b-b635599a9f1b"/>
                  <a:da name="DEFAULT" value="false"/>
                </v:var>
                <!-- @implements PortSetAsUnusedPinApi_Object -->
                <v:var name="PortSetAsUnusedPinApi" type="BOOLEAN">
                  <a:a name="LABEL" value="Port Set As Unused Pin API"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                              The function void Port_SetAsUnusedPin shall configure the referenced pin with all the properties specified in the NotUsedPortPin container.
                              The function void Port_SetAsUsedPin shall configure the referenced pin with all the properties that where set during the Port_Init operation.
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:1f7dy044-d03f-43b6-889f-d9376j1d2776"/>
                  <a:da name="DEFAULT" value="false"/>
                </v:var>
                <!-- @implements PortResetPinModeApi_Object -->
                <v:var name="PortResetPinModeApi" type="BOOLEAN">
                  <a:a name="LABEL" value="Port Reset Pin Mode API"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                              The function Port_ResetPinMode shall revert the port pin mode of the referenced pin to the value that was set by Port_Init operation.
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:1f7dy044-d03f-43b6-863k-d9376j9d2776"/>
                  <a:da name="DEFAULT" value="false"/>
                </v:var>
                <!-- @implements PortEnableUserModeSupport_Object -->
                <v:var name="PortEnableUserModeSupport" type="BOOLEAN">
                    <a:a name="DESC">
                        <a:v>
                            <![CDATA[EN:<html>
                                When this parameter is enabled, the Port module will adapt to run from user mode, with the following measures:<p/>
                                a) configuring REG_PROT for SIUL2 IP so that the registers under protection can be accessed from user mode by setting UAA bit in REG_PROT_GCR to 1<p/>
                                b) using 'call trusted function' stubs for all internal function calls that access registers requiring supervisor mode.<p/>
                                For more information, please see chapter 5.7 user mode Support in IM <p/>
                                Note: Implementation Specific Parameter.
                            </html>]]>
                        </a:v>
                    </a:a>
                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:a name="LABEL" value="Enable Port User Mode Support"/>
                    <a:a name="ORIGIN" value="NXP"/>
                    <a:a name="SCOPE" value="LOCAL"/>
                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                    <a:a name="UUID" value="ECUC:2c37b26f-6cb3-4634-b20b-b636699a9f1c"/>
                    <a:da name="DEFAULT" value="false"/>
                </v:var>
                <!-- @implements PortMulticoreSupport_Object -->
                <v:var name="PortMulticoreSupport" type="BOOLEAN">
                  <a:a name="DESC">
                  <a:v><![CDATA[EN:<html><p>This parameter globally enables the possibility to support multicore. If this parmeter is enabled, at least one EcucPartition needs to be defined (in all variants). The S32K312, S32K314, S32K341, S32K342 and S32K344 derivatives will be treated as a single-core device.<br>
                  <h1>Note</h1>This is an Implementation Specific Parameter.
                        </p></html>]]></a:v>
                  </a:a>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                  </a:a>
                  <a:a name="LABEL" value="Port Multicore Support"/>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false" />
                  <a:a name="UUID" value="ECUC:8436de9b-c7z1-4ab0-9e80-145z3870a2ab" />
                  <a:da name="DEFAULT" value="false" />
                  <a:a name="EDITABLE" type="XPath">
                    <a:tst expr="(ecu:get('Port.Package') = 's32k324_mapbga257') or (ecu:get('Port.Package') = 's32k324_mqfp172') or (ecu:get('Port.Package') = 's32k322_mqfp100') or (ecu:get('Port.Package') = 's32k322_mqfp172')" true='true'/>
                  </a:a>
                  <a:a name="INVALID" type="XPath">
                    <a:tst expr="(. = 'true') and not(num:i(count(../../PortGeneral/PortEcucPartitionRef/*) > 0))"
                           true="Port Multicore Support is only enabled when at least one EcucPartition needs to be defined (in all variants)."/>
                    <a:tst expr="(. = 'true') and (ecu:get('Port.Package') = 's32k344_mapbga257' or ecu:get('Port.Package') = 's32k344_mqfp172' or ecu:get('Port.Package') = 's32k314_mapbga257' or ecu:get('Port.Package') = 's32k314_mqfp172' or ecu:get('Port.Package') = 's32k312_mqfp100' or ecu:get('Port.Package') = 's32k312_mqfp172' or ecu:get('Port.Package') = 's32k342_mqfp100' or ecu:get('Port.Package') = 's32k342_mqfp172' or ecu:get('Port.Package') = 's32k341_mqfp100' or ecu:get('Port.Package') = 's32k341_mqfp172')"
                           true="The S32K312, S32K314, S32K341, S32K342 and S32K344 derivative will be treated as single-core device. So the MulticoreSupport should be disabled"/>
                  </a:a>
                </v:var>
                <!-- @implements PortTspcSupport_Object -->
                <v:var name="PortTspcSupport" type="BOOLEAN">
                  <a:a name="DESC">
                  <a:v><![CDATA[EN:<html><p>This parameter shall allows to support configure The Touch Sensing Pin Coupling<br>
                        </p></html>]]></a:v>
                  </a:a>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                  </a:a>
                  <a:a name="LABEL" value="TSPC Support"/>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false" />
                  <a:a name="UUID" value="ECUC:8436de9b-c7e1-4ab0-9e80-145e2270a2ab" />
                  <a:da name="DEFAULT" value="false" />
                  <a:a name="EDITABLE" value="true"/>
                </v:var>
                <!-- @implements PortEcucPartitionRef_Object -->
                <v:lst name="PortEcucPartitionRef">
                  <v:ref name="PortEcucPartitionRef" type="REFERENCE">
                    <a:a name="DESC">
                        <a:v>
                            <![CDATA[EN:
                            <html>
                            <p>Maps the Port driver to zero a multiple ECUC partitions to make the modules API available in this partition.</p>
                            <p> Tags: atp.Status=draft </p>
                            </html>
                            ]]>
                        </a:v>
                    </a:a>
                    <a:a name="IMPLEMENTATIONCONFIGCLASS"
                         type="IMPLEMENTATIONCONFIGCLASS">
                      <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                      <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                    <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="true"/>
                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                    <a:a name="SCOPE" value="ECU"/>
                    <a:a name="UUID"
                         value="ECUC:f86d720b-a1e5-4f3f-a656-0f491v2l8563"/>
                    <a:da name="REF" value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/EcuC/EcucPartitionCollection/EcucPartition"/>
                    <a:da name="INVALID" type="XPath">
                       <a:tst expr="text:uniq(../*, .)" false="Duplicate Partition."/>
                       <a:tst expr="count(text:grep(node:refs('ASPathDataOfSchema:/TS_T40D34M20I1R0/Os')/OsApplication/*/OsAppEcucPartitionRef, .)) = 0"
                       true="This ECUC partition must be defined in OS."/>
                       <a:tst expr="../../../PortGeneral/PortMulticoreSupport" false="The Port Multicore Support parameter is not enabled"/>
                    </a:da>
                  </v:ref>
                </v:lst>
                <!-- @implements SignalInversionConfigEnable_Object -->
                <v:var name="SignalInversionConfigEnable" type="BOOLEAN">
                  <a:a name="LABEL" value="Port Signal Inversion Config Enable"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                                This parameter globally enables the posibility to invert the signal of the port pin.
                                If this parameter is disabled, the signal of the port pin will not be allowed to invert.
                                If this parameter is enabled, the signal of the port pin will be possible to be inverted in case the invert configuration of each pin is also enabled for this pin.
                                This is an implementation specific parameter.
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:1f7dy044-d03f-43b6-863k-d9376j9d2770"/>
                  <a:da name="DEFAULT" value="false"/>
                </v:var>
                <!-- @implements VirtWrapperSupport_Object -->
                <v:var name="VirtWrapperSupport" type="BOOLEAN">
                  <a:a name="LABEL" value="Port VirtWrapper Support"/>
                  <a:a name="DESC">
                    <a:v>
                      <![CDATA[EN:
                          <html>
                            <p>
                                This parameter enables the virtualization wrapper functionality.<p/>
                                This is an implementation specific parameter.<p/>
                                RM Enable Virtual Wrapper feature is required to enabled when Port Virtual Wrapper Support is enabled.<p/>
                            </p>
                          </html>
                          ]]>
                    </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:1f7dy044-d03f-43b6-863k-d9381j9d2770"/>
                  <a:da name="DEFAULT" value="false"/>
                  <a:a name="INVALID" type="XPath">
                    <a:tst expr="(node:value(.) = 'true') and (node:refs('ASPathDataOfSchema:/AUTOSAR/EcucDefs/Rm/RmGeneral/RmVirtWrapperConfigurable/') = 'false')" true="Rm Virtual Wrapper support is required to enabled when Port Virtual Wrapper feature is enabled"/>
                  </a:a>
                </v:var>
              </v:ctr>
              <!-- @implements CommonPublishedInformation_Object -->
              <v:ctr name="CommonPublishedInformation" type="IDENTIFIABLE">
                <a:a name="DESC">
                  <a:v>
                    <![CDATA[EN:
                        <html>
                          <p>
                            Common container, aggregated by all modules. It contains published information about vendor and versions.
                          </p>
                        </html>
                        ]]>
                  </a:v>
                </a:a>
                <a:a name="UUID" value="ECUC:99795b3a-dc2e-41ea-9170-bcd47bae8adc"/>
                <v:var name="ArReleaseMajorVersion" type="INTEGER_LABEL">
                  <a:a name="LABEL" value="AUTOSAR Major Version"/>
                  <a:a name="DESC">
                      <a:v>
                      <![CDATA[EN:
                          <html>
                             <p>
                               Major version number of AUTOSAR specification on which the appropriate implementation is based on.
                             </p>
                          </html>
                      ]]>
                      </a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:92cf1f0c-9506-4d76-a6fc-a87390f825a3"/>
                  <a:da name="DEFAULT" value="4"/>
                  <a:da name="INVALID" type="Range">
                    <a:tst expr="&gt;=4"/>
                    <a:tst expr="&lt;=4"/>
                  </a:da>
                </v:var>
                <v:var name="ArReleaseMinorVersion" type="INTEGER_LABEL">
                  <a:a name="LABEL" value="AUTOSAR Minor Version"/>
                  <a:a name="DESC">
                      <a:v><![CDATA[EN:
                           <html>
                               <p>
                                 Minor version number of AUTOSAR specification on which the appropriate implementation is based on.
                               </p>
                           </html>
                      ]]></a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:53a815d1-6a05-4591-adfe-68df4edbe89a"/>
                  <a:da name="DEFAULT" value="4"/>
                  <a:da name="INVALID" type="Range">
                      <a:tst expr="&gt;=4"/>
                      <a:tst expr="&lt;=4"/>
                  </a:da>
                </v:var>
                <v:var name="ArReleaseRevisionVersion" type="INTEGER_LABEL">
                  <a:a name="LABEL" value="AUTOSAR Revision Version"/>
                  <a:a name="DESC">
                      <a:v><![CDATA[EN:
                        <html>
                            <p>
                                Revision version number of AUTOSAR specification on which the appropriate implementation is based on.
                            </p>
                        </html>
                      ]]></a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:46cb1cd8-7f5b-4d24-99ef-77753f37467e"/>
                  <a:da name="DEFAULT" value="0"/>
                  <a:da name="INVALID" type="Range">
                      <a:tst expr="&gt;=0"/>
                      <a:tst expr="&lt;=0"/>
                  </a:da>
                </v:var>
                <v:var name="ModuleId" type="INTEGER_LABEL">
                  <a:a name="LABEL" value="Module Id."/>
                  <a:a name="DESC">
                      <a:v><![CDATA[EN:
                               <html>
                                   <p>
                                     Module ID of this module from Module List.
                                   </p>
                               </html>
                      ]]></a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:e752c4d6-a47e-4c65-a106-4eecfaf6f5ca"/>
                  <a:da name="DEFAULT" value="124"/>
                  <a:da name="INVALID" type="Range">
                      <a:tst expr="&gt;=124"/>
                      <a:tst expr="&lt;=124"/>
                  </a:da>
                </v:var>
                <v:var name="SwMajorVersion" type="INTEGER_LABEL">
                  <a:a name="LABEL" value="Software Major Version"/>
                  <a:a name="DESC">
                      <a:v><![CDATA[EN:
                        <html>
                            <p>
                                Major version number of the vendor specific implementation of the module. The numbering is vendor specific.
                            </p>
                        </html>
                      ]]></a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:803ad2c7-b0fc-4b00-890f-1bd226a85e88"/>
                  <a:da name="DEFAULT" value="2"/>
                  <a:da name="INVALID" type="Range">
                      <a:tst expr="&gt;=2"/>
                      <a:tst expr="&lt;=2"/>
                  </a:da>
                </v:var>
                <v:var name="SwMinorVersion" type="INTEGER_LABEL">
                  <a:a name="LABEL" value="Software Minor Version"/>
                  <a:a name="DESC">
                    <a:v><![CDATA[EN:
                        <html>
                            <p>
                                Minor version number of the vendor specific implementation of the module. The numbering is vendor specific.
                            </p>
                        </html>
                        ]]></a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:5a20015e-662b-426f-8683-ec08d8ddeaf8"/>
                  <a:da name="DEFAULT" value="0"/>
                  <a:da name="INVALID" type="Range">
                    <a:tst expr="&gt;=0"/>
                    <a:tst expr="&lt;=0"/>
                  </a:da>
                </v:var>
                <v:var name="SwPatchVersion" type="INTEGER_LABEL">
                  <a:a name="LABEL" value="Software Patch Version"/>
                  <a:a name="DESC">
                    <a:v><![CDATA[EN:
                       <html>
                       <p>
                           Patch level version number of the vendor specific implementation of the module. The numbering is vendor specific.
                       </p>
                       </html>
                    ]]></a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:9dc886a8-6052-4bc4-a09d-d4ef3229728e"/>
                  <a:da name="DEFAULT" value="1"/>
                  <a:da name="INVALID" type="Range">
                    <a:tst expr="&gt;=1"/>
                    <a:tst expr="&lt;=1"/>
                  </a:da>
                </v:var>
                <v:var name="VendorApiInfix" type="STRING_LABEL">
                  <a:a name="LABEL" value="Vendor Api Infix"/>
                  <a:a name="DESC">
                      <a:v><![CDATA[EN:
                      <html>
                          <p>
                          In driver modules which can be instantiated several times on a single ECU, BSW00347 requires that the name of APIs is extended by the VendorId and a vendor specific name.
                          This parameter is used to specify the vendor specific name. In total, the implementation specific name is generated as follows:
                          &lt;ModuleName&gt;_&gt;VendorId&gt;_&lt;VendorApiInfix&gt;&lt;Api name from SWS&gt;.
                          E.g.  assuming that the VendorId of the implementor is 123 and the implementer chose a VendorApiInfix of &quot;v11r456&quot; a api name Can_Write defined in the SWS will translate to Can_123_v11r456Write.
                          This parameter is mandatory for all modules with upper multiplicity &gt; 1. It shall not be used for modules with upper multiplicity =1.
                          </p>
                      </html>
                      ]]></a:v>
                  </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v class="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v class="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="NXP"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="ECUC:258e4d5c-05f9-4122-a309-f8f4ea6b2a12"/>
                  <a:da name="DEFAULT" value=""/>
                  <a:a name="OPTIONAL" value="true"/>
                  <a:da name="READONLY" value="true"/>
                </v:var>
                <v:var name="VendorId" type="INTEGER_LABEL">
                  <a:a name="LABEL" value="Vendor Id"/>
                    <a:a name="DESC">
                        <a:v><![CDATA[EN:
                                <html>
                                    <p>
                                        Vendor ID of the dedicated implementation of this module according to the AUTOSAR vendor list.
                                    </p>
                                </html>
                        ]]></a:v>
                    </a:a>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                    <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                  </a:a>
                    <a:a name="ORIGIN" value="NXP"/>
                    <a:a name="SCOPE" value="LOCAL"/>
                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                    <a:a name="UUID" value="ECUC:0eea4f69-4305-4de2-95dd-3d535295e477"/>
                    <a:da name="DEFAULT" value="43"/>
                    <a:da name="INVALID" type="Range">
                        <a:tst expr="&gt;=43"/>
                        <a:tst expr="&lt;=43"/>
                    </a:da>
                </v:var>
              </v:ctr>
              <d:ref type="REFINED_MODULE_DEF" value="ASPath:/AUTOSAR/EcucDefs/Port"/>
            </v:ctr>
          </d:chc>
          <d:chc name="Port_EcuParameterDefinition"
                 type="AR-ELEMENT" value="ECU_PARAMETER_DEFINITION">
            <d:ctr type="AR-ELEMENT">
            <a:a name="UUID" value="ECUC:b11d9356-6af9-4d50-ab1b-17c7180096f0"/>
              <a:a name="DEF"
                   value="ASPath:/AR_PACKAGE_SCHEMA/ECU_PARAMETER_DEFINITION"/>
              <d:lst name="MODULE_REF">
                <d:ref type="MODULE_REF" value="ASPath:/TS_T40D34M20I1R0/Port"/>
              </d:lst>
            </d:ctr>
          </d:chc>
          <d:chc name="Port_ModuleDescription"
                 type="AR-ELEMENT" value="BSW_MODULE_DESCRIPTION">
            <d:ctr type="AR-ELEMENT">
              <a:a name="DEF"
                   value="ASPath:/AR_PACKAGE_SCHEMA/BSW_MODULE_DESCRIPTION"/>
              <d:var name="MODULE_ID" type="INTEGER" >
                <a:a name="EDITABLE" value="false"/>
                <a:a name="IMPORTER_INFO" value="@DEF"/>
              </d:var>
              <d:ref type="RECOMMENDED_CONFIGURATION" >
                <a:a name="EDITABLE" value="false"/>
                <a:a name="IMPORTER_INFO" value="@DEF"/>
              </d:ref>
              <d:ref type="PRE_CONFIGURED_CONF" >
                <a:a name="EDITABLE" value="false"/>
                <a:a name="IMPORTER_INFO" value="@DEF"/>
              </d:ref>
              <d:ref type="VENDOR_SPECIFIC_MODULE_DEF"
                     value="ASPath:/TS_T40D34M20I1R0/Port"/>
            </d:ctr>
          </d:chc>
        </d:lst>
      </d:ctr>
    </d:lst>
  </d:ctr>

</datamodel>
