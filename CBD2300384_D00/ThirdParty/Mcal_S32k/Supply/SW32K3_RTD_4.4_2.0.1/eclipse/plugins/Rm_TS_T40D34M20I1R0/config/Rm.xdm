                                    <a:da name="DEFAULT" value="false"/>
                                </v:var>

                                <v:lst name="MPU_M7_ModuleConfig" type="MAP">
                                    <a:a name="LABEL" value="Module Configurations"/>
                                    <a:da name="MIN" value="0"/>
                                    <!-- <a:da name="DEFAULT" type="XPath" expr="ecu:get('Rm.Mpu_M7.DefaultRegionCount')"/> -->
                                    <a:a name="TAB" value="MPU M7"/>
                                    <a:da name="EDITABLE" type="XPath" expr="node:fallback( node:current()/../../../RmGeneral/RmMpuM7Configurable, num:i(0))" />
                                    <a:da name="INVALID" type="XPath">
                                            <a:tst expr="../../../RmGeneral/RmMpuM7Configurable = 'true' and (num:i(count(*)) = 0)"
                                            true ="At least one MPU M7 configuration must be configured when RM Enable MPU M7 Support is checked!"/>
                                            <a:tst expr="../../../RmGeneral/RmEnableMultiCore = 'false' and (num:i(count(*)) > 1)"
                                            true ="Only one configuration element is allowed when disable Multicore support!"/>
                                    </a:da>
                                    <v:ctr name="MPU_M7_ModuleConfig" type="IDENTIFIABLE">
                                        <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:
                                                    <html><p>Configuration for the ARM Cortex M7 MPU.</p></html>
                                                ]]>
