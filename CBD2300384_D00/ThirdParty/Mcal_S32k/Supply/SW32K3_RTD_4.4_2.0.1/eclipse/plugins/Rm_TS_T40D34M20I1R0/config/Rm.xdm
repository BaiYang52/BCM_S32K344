                                                    </a:v>
                                                </a:a>
                                                <a:a name="UUID" value="ECUC:d421f556-3c8b-4540-ae49-e3dd64827ceb"/>
                                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                        <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                                </a:a>
                                                <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                <a:a name="ORIGIN" value="NXP"/>
                                                <a:da name="DEFAULT" value="XRDC_FULL_ACCESS"/>
                                                <a:da name="RANGE">
                                                    <a:v>XRDC_FULL_ACCESS</a:v>
                                                    <a:v>XRDC_SUPERVISOR_ACCESS_ONLY</a:v>
                                                    <a:v>XRDC_READ_ONLY</a:v>
                                                    <a:v>XRDC_SUPERVISOR_READ_ONLY</a:v>
                                                    <a:v>XRDC_NO_ACCESS</a:v>
                                                </a:da>
                                                <a:a name="EDITABLE" type="XPath">
                                                    <a:tst expr="./../Secure_Access_Policy = 'XRDC_FULL_ACCESS'"/>
                                                </a:a>
                                            </v:var>
                                        </v:ctr>
                                    </v:lst>
                                </v:ctr>
                            </v:lst>

                            <v:lst name="Rm_XRDC_Memory_Config" type="MAP">
                                <a:a name="LABEL" value="XRDC Memory Config"/>
                                <a:a name="EDITABLE" type="XPath">
                                      <a:tst expr="../../RmGeneral/RmEnableXRDCSupport ='true'"/>
                                </a:a>
                                <a:da name="INVALID" type="XPath">
                                <a:tst expr="../../RmGeneral/RmEnableXRDCSupport ='true' and (num:i(count(*))= 0)"
                                true ="At least one Memory Region must be configured when XRDC Support is checked!"/>
                                </a:da>
                                <v:ctr name = "Rm_XRDC_Memory_Config" type = "IDENTIFIABLE">
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:<html> Vendor specific:
                                                All data need to configure Memory use for Domain.
                                            </html>]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="UUID" value="ECUC:291f97d7-0114-47f4-b7c2-d16a2bdc0dca"/>
                                    <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                    </a:a>

                                    <v:var name="XrdcMrcInstance" type="ENUMERATION">
                                        <a:a name="LABEL" value="XRDC Memory Region Controller"/>
                                        <a:a name="DESC" value="Select Memory region controller will be used to control the address range below"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:a name="UUID" value="ECUC:221fd9c7-8327-4be7-b449-6bdaca7139db"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:da name="DEFAULT" type="XPath" expr="(ecu:list('Rm.XRDC.Mrc.Names.List'))[position()-1=node:fallback(node:current()/../@index,'0')]"></a:da>
                                        <a:a name="RANGE" type="XPath" expr = "ecu:list('Rm.XRDC.Mrc.Names.List')"/>
                                        <a:da name="INVALID" type="XPath">
                                             <a:tst expr="num:i(count(./../../*[ecu:get(text:replace('Rm.XRDC.Mrc.MrcName','MrcName',node:when(string-length(./XrdcMrcInstance)>0,./XrdcMrcInstance, node:current()))) = ecu:get(text:replace('Rm.XRDC.Mrc.MrcName','MrcName',node:current()))])) > num:i(ecu:get(text:concat('Rm.XRDC.Mrc.DescriptorCount.', .)))" true="Number of the configured MrcInstance exceed number of its descriptors."/>
                                        </a:da>
                                    </v:var>
                                    <v:var name="XrdcStartAddress" type="INTEGER">
                                        <a:a name="DESC" value="Start address of Memory region"/>
                                        <a:a name="LABEL" value="Start Address"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:a name="UUID" value="ECUC:3b4086e0-eb52-4ba8-98c6-eaef1807d631"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:da name="INVALID" type="XPath">
                                            <a:tst expr="node:value(./../XrdcEndAddress) &lt; node:value(.)" true="End address must larger than Start address"/>
                                            <a:tst expr="num:i(node:value(./../XrdcEndAddress) +1 - node:value(.)) &lt; 4096" true="minimum size of region should be larger than 4096 bytes"/>
                                            <a:tst expr="(node:fallback(., 0) mod 4096) != 0" true="the address should be modulo by 4096 bytes"/>
                                        </a:da>
                                        <a:a name="INVALID" type="Range">
                                            <a:tst expr="&gt;=0x0"/>
                                            <a:tst expr="&lt;=0x6000000000"/>
                                        </a:a>
                                        <a:a name="DEFAULT_RADIX" value="HEX" />
                                        <a:da name="DEFAULT" value="0"/>
                                    </v:var>

                                    <v:var name="XrdcEndAddress" type="INTEGER">
                                        <a:a name="DESC" value="End address of Memory region"/>
                                        <a:a name="LABEL" value="End Address"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:a name="UUID" value="ECUC:aab9723f-c3e7-4080-b430-f212f5eecc9b"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:a name="DEFAULT_RADIX" value="HEX" />
                                        <a:da name="INVALID" type="Range">
                                            <a:tst expr="&lt;=0x6000000000"/>
                                            <a:tst expr="&gt;=0x0"/>
                                        </a:da>
                                        <a:da name="INVALID" type="XPath">
                                            <a:tst expr="((node:fallback(., 0)+1) mod 4096) != 0" true="End address + 1 must be modulo 4096"/>
                                        </a:da>
                                        <a:da name="DEFAULT" value="0"/>
                                    </v:var>

                                    <v:var name="XrdcSema4Enable" type="BOOLEAN">
                                        <a:a name="LABEL" value="Semaphore Enable"/>
                                        <a:a name="DESC" value="Enable Semaphore would require the domain must own the gate to have access right for this memory range "/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="INVALID" type="XPath">
                                             <a:tst expr="./../../../../RmGeneral/RmEnableSema42Support ='false' and (. ='true')" true=" Please turn on Semaphore Support first"/>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:a name="UUID" value="ECUC:a337d428-96c2-45af-8b4d-97fbacefbfba"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:da name="DEFAULT" value="false"/>
                                    </v:var>

                                    <v:ref name="XrdcSema42LogicChannel" type="REFERENCE">
                                        <a:a name="UUID" value="ECUC:35a1e74e-ea11-4420-a21d-caf8f47be123"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:a name="SCOPE" value="LOCAL"/>
                                        <a:a name="DESC" value="EN: Select XrdcSema42LogicChannel to select specified Sema42 Logic Channel"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v class="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v class="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:da name="REF" value="ASPathDataOfSchema:/TS_T40D34M20I1R0/Rm/RmConfigSet/Sema42_ModuleConfig/Sema42LogicChannelConfiguration"/>
                                        <a:da name="INVALID" type="XPath">
                                            <a:tst expr="((./../XrdcSema4Enable = 'false') or (node:refvalid(.) and contains(../XrdcMrcInstance,ecu:get(concat('Rm.XRDC.Master.Prefix.XRDC_',substring-after(node:ref(.)/Sema42HardwareInstance,'SEMA42_'))))))" false = "Reference is not valid or the sema4 channel does not correspond to the XRDC instance"/>
                                        </a:da>
                                        <a:a name="ENABLE" type="XPath">
                                            <a:tst expr="../XrdcSema4Enable ='true'"/>
                                        </a:a>
                                    </v:ref>
                                </v:ctr>
                            </v:lst>

                            <v:lst name="Rm_XRDC_Peripheral_Config" type="MAP">
                                <a:a name="LABEL" value="XRDC Peripheral Config"/>
                                <a:a name="EDITABLE" type="XPath">
                                      <a:tst expr="../../RmGeneral/RmEnableXRDCSupport ='true'"/>
                                </a:a>
                                <a:da name="INVALID" type="XPath">
                                <a:tst expr="../../RmGeneral/RmEnableXRDCSupport ='true' and (num:i(count(*))= 0)"
                                true ="At least one Peripheral must be configured when XRDC Support is checked!"/>
                                </a:da>
                                <v:ctr name = "Rm_XRDC_Peripheral_Config" type = "IDENTIFIABLE">
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:<html> Vendor specific:
                                                All data need to configure Peripheral for Domain.
                                            </html>]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                    </a:a>
                                    <a:a name="UUID" value="ECUC:f57fbeeb-2921-4942-95fd-c2659efd6818"/>

                                    <v:var name="XrdcPeripheralSlot" type="ENUMERATION">
                                        <a:a name="DESC" value="Peripheral slot number of a block of peripherals. Checking Reference manual for chip specific"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:a name="UUID" value="ECUC:4eaea45a-8c32-4638-9398-afe821070476"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:da name="DEFAULT" type="XPath" expr="ecu:list('Rm.XRDC.Pdac.Names.List')[position()-1=node:fallback(node:current()/../@index,'0')]"/>
                                        <a:a name="RANGE" type="XPath" expr = "ecu:list('Rm.XRDC.Pdac.Names.List')"/>
                                        <a:da name="INVALID" type="XPath">
                                            <a:tst expr="text:uniq(../../*/XrdcPeripheralSlot, .)" false="Peripheral Slot must be unique"/>
                                        </a:da>
                                    </v:var>

                                    <v:var name="XrdcSema4Enable" type="BOOLEAN">
                                        <a:a name="DESC" value="Enable Semaphore would require the domain must own the gate to have access right for this peripheral"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="INVALID" type="XPath">
                                             <a:tst expr="./../../../../RmGeneral/RmEnableSema42Support ='false' and (. ='true')" true=" Please turn on Semaphore Support first"/>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:a name="UUID" value="ECUC:a337d428-96c3-45af-8b4d-97fbacefbfbb"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:da name="DEFAULT" value="false"/>
                                    </v:var>

                                    <v:ref name="XrdcSema42LogicChannel" type="REFERENCE">
                                        <a:a name="UUID" value="ECUC:35a1e74e-ea11-4420-a21d-caf8f47be456"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:a name="DESC" value="EN: Select XrdcSema42LogicChannel to select specified Sema42 Logic Channel"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v class="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v class="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:da name="REF" value="ASPathDataOfSchema:/TS_T40D34M20I1R0/Rm/RmConfigSet/Sema42_ModuleConfig/Sema42LogicChannelConfiguration"/>
                                        <a:da name="INVALID" type="XPath">
                                            <a:tst expr="((./../XrdcSema4Enable = 'false') or (node:refvalid(.) and contains(../XrdcPeripheralSlot,ecu:get(concat('Rm.XRDC.Master.Prefix.XRDC_',substring-after(node:ref(.)/Sema42HardwareInstance,'SEMA42_'))))))" false = "Reference is not valid or the sema4 channel does not correspond to the XRDC instance"/>
                                        </a:da>
                                        <a:a name="ENABLE" type="XPath">
                                            <a:tst expr="../XrdcSema4Enable ='true'"/>
                                        </a:a>
                                    </v:ref>
                                </v:ctr>
                            </v:lst>
                            <v:ctr name="MPU_M7_Configuration" type="IDENTIFIABLE">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                            <html><p>Configuration for the ARM Cortex M7 MPU.</p></html>
                                        ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="UUID" value="ECUC:be68078a-ba7e-4321-b0a2-8097d0117449"/>
                                <a:a name="TAB" value="MPU M7"/>

                                <v:var name="MpuDevErrorDetect" type="BOOLEAN">
                                    <a:a name="LABEL" value="Mpu Development Error Detection"/>
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:
                                                <html>
                                                    <p>MpuDevErrorDetect</p>
                                                    <p>Switches the Development Error Detection and Notification ON or OFF.</p>
                                                    Note: Implementation Specific Parameter. <p/>
                                                </html>
                                            ]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                    </a:a>
