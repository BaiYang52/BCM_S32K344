                                                                    <td colspan="1">R,W
                                                                <tr>
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="2">XRDC_SUPERVISOR_ACCESS_ONLY
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">None
