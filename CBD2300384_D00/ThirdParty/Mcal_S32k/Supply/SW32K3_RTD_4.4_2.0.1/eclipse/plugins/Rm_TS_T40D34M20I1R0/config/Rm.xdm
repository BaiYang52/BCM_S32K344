                                <a:a name="UUID" value="ECUC:be68078a-ba7e-4321-b0a2-8097d0115121"/>
                                <a:a name="TAB" value="Sema42"/>
                                <v:var name="Sema42DevErrorDetect" type="BOOLEAN">
                                    <a:a name="LABEL" value="Sema42 Development Error Detection"/>
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:
                                                <html>
                                                    <p>Sema42DevErrorDetect</p>
                                                    <p>Switches the Development Error Detection and Notification ON or OFF.</p>
                                                    Note: Implementation Specific Parameter. <p/>
                                                </html>
                                            ]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                    </a:a>
                                    <a:a name="ORIGIN" value="NXP"/>
                                    <a:a name="SCOPE" value="LOCAL"/>
                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                    <a:a name="UUID" value="ECUC:7228a335-4003-8881-8e1a-bb3d9f731131"/>
                                    <a:da name="DEFAULT" value="true"/>
                                </v:var>
                                
                                <v:lst name="Sema42LogicChannelConfiguration" type="MAP">
                                    <a:a name="LABEL" value="Sema42 Logic Channel"/>
                                    <a:a name="TAB" value="Sema42"/>
                                    <a:da name="EDITABLE" type="XPath" expr="node:fallback(node:current()/../../../RmGeneral/RmEnableSema42Support, num:i(0))"/>
                                    <a:da name="INVALID" type="XPath">
                                            <a:tst expr="../../../RmGeneral/RmEnableSema42Support = 'true' and (num:i(count(*)) = 0)"
                                            true ="At least one SEMA42 configuration must be configured when RM Enable Sema42 Support is checked!"/>
                                    </a:da>

                                    <v:ctr name="Sema42LogicChannelConfiguration" type="IDENTIFIABLE">
                                        <a:a name="LABEL" value="Sema42 Logic Channel"/>
                                        <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:
                                                    <html>Configuration for Sema42 Instance</html>
                                                ]]>
                                            </a:v>
                                        </a:a>
                                        <a:a name="UUID" value="ECUC:fb100d71-d46f-4f34-bccb-1c528f725ead"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v class="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v class="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        
                                        <v:var name="Sema42LogicChannel_LogicName" type="STRING">
                                            <a:a name="DESC">
                                                <a:v>
                                                    <![CDATA[EN:<html> Vendor specific:
                                                        Logic Channel Name.
                                                    </html>]]>
                                                </a:v>
                                            </a:a>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="LABEL" value="Logic Channel Name"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="SCOPE" value="LOCAL"/>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                            <a:a name="UUID" value="ECUC:2df0549d-3953-49bd-b22e-0c4f9a28139b"/>
                                            <a:da name="DEFAULT" type="XPath" expr="concat( 'SEMA42_LOGIC_CH_' , node:fallback(node:current()/../@index,'0') )"/>
                                            <a:da name="INVALID" type="XPath">
                                                <a:tst expr="text:uniq(../../*/Sema42LogicChannel_LogicName, .)" false="Duplicate Logic Channel Name!"/>
                                            </a:da>
                                        </v:var>
                                        
                                        <v:var name="Sema42HardwareInstance" type="ENUMERATION">
                                            <a:a name="LABEL" value="Hardware Instance"/>
                                            <a:a name="DESC">
                                                <a:v>
                                                    <![CDATA[EN:<html>
                                                        Vendor specific: Select the physical Sema42 Instance.
                                                    </html>]]>
                                                </a:v>
                                            </a:a>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="SCOPE" value="LOCAL"/>
                                            <a:a name="SYMBOLICNAMEVALUE" value="true"/>
                                            <a:a name="UUID" value="ECUC:e2b36f15-2b03-416d-a0d5-0639b652f0f7"/>
                                            <a:da name="DEFAULT" type="XPath" expr="ecu:list('Rm.Sema42.HardwareInstance.List')[position()-1=((node:fallback(node:current()/../@index,'0') - (node:fallback(node:current()/../@index,'0') mod 16)) div 16)]"/>
                                            <a:da name="RANGE" type="XPath" expr="ecu:list('Rm.Sema42.HardwareInstance.List')"/>
                                        </v:var>
                                        
                                        <v:var name="Sema42HardwareChannel" type="INTEGER">
                                            <a:a name="LABEL" value="Hardware Channel"/>
                                            <a:a name="DESC">
                                                <a:v>
                                                    <![CDATA[EN:<html>
                                                        Vendor specific: Select the physical Sema42 Channel.
                                                    </html>]]>
                                                </a:v>
                                            </a:a>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="UUID" value="ECUC:a9b95a15-f535-4cf6-bc35-0766d1954a74"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:da name="DEFAULT" type="XPath" expr="node:fallback(node:current()/../@index,'0')"/>
                                            <a:da name="INVALID" type="Range">
                                                <a:tst expr="&lt;=15"/>
                                                <a:tst expr="&gt;=0"/>
                                            </a:da>
                                            <a:da name="INVALID" type="XPath">
                                                <a:tst expr="count(../../*[(Sema42HardwareChannel = node:current()) and (Sema42HardwareInstance = node:current()/../Sema42HardwareInstance)]) = 1"
                                                false="Duplicate hardware instance and hardware channel."/>
                                            </a:da>
                                        </v:var>
                                    </v:ctr>
                                </v:lst>
                            </v:ctr>
                            <v:ctr name="Pflash_Configuration" type="IDENTIFIABLE">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                            <html><p>Configuration for the "Pflash.</p></html>
                                        ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="TAB" value="Pflash"/>
                                <a:a name="UUID" value="ECUC:be68078a-ba7e-4321-b0a2-8097d0117118"/>
                                <a:a name="EDITABLE" type="XPath">
                                    <a:tst expr="../../RmGeneral/RmPflashConfigurable ='true'"/>
                                </a:a>
                                <!--  PflashDevErrorDetect -->
                                <v:var name="PflashDevErrorDetect" type="BOOLEAN">
                                    <a:a name="LABEL" value="Pflash Development Error Detection"/>
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:
                                                <html>
                                                    <p>PflashDevErrorDetect</p>
                                                    <p>Switches the Development Error Detection and Notification ON or OFF.</p>
                                                    Note: Implementation Specific Parameter. <p/>
                                                </html>
                                            ]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                    </a:a>
                                    <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                    <a:a name="ORIGIN" value="NXP"/>
                                    <a:a name="SCOPE" value="LOCAL"/>
                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                    <a:a name="UUID" value="ECUC:7228a335-4003-3381-8e1a-bb3d9f733112"/>
                                    <a:da name="DEFAULT" value="true"/>
                                </v:var>
                                <v:lst name="PflashMasterProtection" type="MAP">
                                    <a:da name="EDITABLE" type="XPath" expr="node:fallback( node:current()/../../../RmGeneral/RmPflashConfigurable, num:i(0))" />
                                    <a:da name="INVALID" type="XPath">
                                        <a:tst expr="../../../RmGeneral/RmPflashConfigurable ='true' and (num:i(count(*)) = 0)" true="If RM Enable Plfash Support is checked, then at least 1 channel must be configured"/>
                                    </a:da>
                                    <a:a name="TAB" value="Pflash"/>
                                    <v:ctr name="PflashMasterProtection" type="IDENTIFIABLE">
                                        <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                        </a:a>
                                        <a:a name="LABEL" value="Pflash Master Protection"/>
                                        <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:
                                                    <html>
                                                        <p>Pflash Master Protection</p>
                                                    </html>
                                                ]]>
                                            </a:v>
                                        </a:a>
                                        <a:a name="UUID" value="ECUC:7228a235-4103-858a-8e1a-bb3d9f731131"/>
                                        <v:var name="PflashControler" type="ENUMERATION">
                                            <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:
                                                    <html>
                                                        <p>Select controller: PLFASH or PLFASH ALTERNATE</p>
                                                    </html>
                                                ]]>
                                            </a:v>
                                            </a:a>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="SCOPE" value="LOCAL"/>
                                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                            <a:a name="UUID" value="ECUC:7228a335-4003-8881-8e1a-bb3d9f73b1a1"/>
                                            <a:da name="RANGE">
                                                <a:v>PFLASH_CTRL</a:v>
                                                <a:v>PFLASH_ATL_CTRL</a:v>
                                            </a:da>
                                            <a:da name="DEFAULT" value="PFLASH_CTRL"/>
                                        </v:var>
                                        <v:var name="PflashMAP" type="ENUMERATION">
                                            <a:a name="DESC">
                                                <a:v>
                                                    <![CDATA[EN:
                                                        <html>
                                                            <p>Select master for mode protection</p>
                                                        </html>
                                                    ]]>
                                                </a:v>
                                            </a:a>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="SCOPE" value="LOCAL"/>
                                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                            <a:a name="UUID" value="ECUC:7228a3d5-4003-8b81-8e1a-bb3d9f73b1a1"/>
                                            <a:da name="RANGE">
                                                    <a:v>PFLASH_M15AP</a:v>
                                                    <a:v>PFLASH_M14AP</a:v>
                                                    <a:v>PFLASH_M13AP</a:v>
                                                    <a:v>PFLASH_M12AP</a:v>
                                                    <a:v>PFLASH_M11AP</a:v>
                                                    <a:v>PFLASH_M10AP</a:v>
                                                    <a:v>PFLASH_M9AP</a:v>
                                                    <a:v>PFLASH_M8AP</a:v>
                                                    <a:v>PFLASH_M7AP</a:v>
                                                    <a:v>PFLASH_M6AP</a:v>
                                                    <a:v>PFLASH_M5AP</a:v>
                                                    <a:v>PFLASH_M4AP</a:v>
                                                    <a:v>PFLASH_M2AP</a:v>
                                                    <a:v>PFLASH_M1AP</a:v>
                                                    <a:v>PFLASH_M0AP</a:v>
                                            </a:da>
                                            <a:da name="DEFAULT" value="PFLASH_M0AP"/>
                                        </v:var>

                                        <v:var name="PflashMasterAccess" type="ENUMERATION">
                                            <a:a name="DESC">
                                                <a:v>
                                                    <![CDATA[EN:
                                                        <html>
                                                            <p>Select access right for each master</p>
                                                        </html>
                                                    ]]>
                                                </a:v>
                                            </a:a>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="SCOPE" value="LOCAL"/>
                                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                            <a:a name="UUID" value="ECUC:7328a335-4a03-8882-8e1a-bb3d9f73b1a1"/>
                                            <a:da name="RANGE">
                                                <a:v>PFLASH_READ_NOT_ALLOWED</a:v>
                                                <a:v>PFLASH_READ_ALLOWED</a:v>
                                            </a:da>
                                            <a:da name="DEFAULT" value="PFLASH_READ_ALLOWED"/>
                                        </v:var>
                                    </v:ctr>
                                </v:lst> <!-- PFLASH list -->
                            </v:ctr>
                            <v:ctr name="Crossbar_Configuration" type="IDENTIFIABLE">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                            <html><p>Configuration for the Crossbar.</p></html>
                                        ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="LABEL" value="Crossbar"/>
                                <a:a name="TAB" value="Crossbar"/>
                                <a:a name="UUID" value="ECUC:be68078a-ba7e-4321-b0a2-8097d0117115"/>
                                <a:a name="EDITABLE" type="XPath">
                                        <a:tst expr="../../RmGeneral/RmCrossbarConfigurable ='true'"/>
                                </a:a>

                                <!--  CrossbarDevErrorDetect -->
                                <v:var name="CrossbarDevErrorDetect" type="BOOLEAN">
                                    <a:a name="LABEL" value="Crossbar Development Error Detection"/>
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:
                                                <html>
                                                    <p>CrossbarDevErrorDetect</p>
                                                    <p>Switches the Development Error Detection and Notification ON or OFF.</p>
                                                    Note: Implementation Specific Parameter. <p/>
                                                </html>
                                            ]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                    </a:a>
                                    <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                    <a:a name="ORIGIN" value="NXP"/>
                                    <a:a name="SCOPE" value="LOCAL"/>
                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                    <a:a name="UUID" value="ECUC:7228a335-4003-3381-8e1a-bb3d9f733114"/>
                                    <a:da name="DEFAULT" value="true"/>
                                </v:var>
                                <v:lst name="RmCrossbarInstance" type="MAP">
                                    <a:da name="MIN" value="0"/>
                                    <a:da name="MAX" value="2"/>
                                    <a:a name="EDITABLE" type="XPath">
                                    <a:tst expr="../../../RmGeneral/RmCrossbarConfigurable ='true'"/>
                                    </a:a>
                                    <a:a name="TAB" value="Crossbar"/>
                                    <a:da name="INVALID" type="XPath">
                                        <a:tst expr="../../../RmGeneral/RmCrossbarConfigurable ='true' and (count(node:fallback(./*,1)) = 0)" true="If Rm Enable Crossbar Switch = ON, then at least 1 channel must be configured"/>
                                    </a:da>
                                    <v:ctr name="RmCrossbarInstance" type="IDENTIFIABLE">
                                        <a:a name="DESC" value="EN: Vendor specific: Configuration of a crossbar instance."/>
                                        <a:a name="UUID" value="ECUC:5d10957b-c38a-66ed-b06b-4b7e365f1cc3"/>
                                        <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                        </a:a>

                                        <v:var name="RmCrossbarHwInstance" type="ENUMERATION">
                                            <a:a name="DESC">
                                                <a:v>
                                                    <![CDATA[EN:<html> Vendor specific:
                                                    Select the crossbar switch instance.
                                                    Note: For S32K3XX, only XRDC_1 (XRDC Lite Peripheral) is programmable. Also for S32K312, AXBS is not programmable.
                                                    </html>]]>
                                                </a:v>
                                            </a:a>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="LABEL" value="Crossbar Hardware Instance"/>
                                            <a:a name="SCOPE" value="LOCAL"/>
                                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                            <a:a name="UUID" value="ECUC:0aaa248e-f32e-45b6-94be-372ca32a5726"/>
                                            <a:da name="DEFAULT" type="XPath" expr="(ecu:list('Rm.Crossbar.CrossbarInstances.List'))[position()-1=node:fallback(node:current()/../@index,'0')]">
                                            </a:da>
                                            <a:da name="INVALID" type="XPath">
                                                <a:tst expr="text:uniq(../../*/RmCrossbarHwInstance, .)" false="Duplicate hardware instance of the crossbar switch"/>
                                            </a:da>
                                            <a:da name="RANGE" type="XPath" expr="ecu:list('Rm.Crossbar.CrossbarInstances.List')"/>
                                        </v:var>

                                        <v:lst name="RmCrossbarHwSlavePort" type="MAP">
                                            <a:da name="MIN" value="0"/>
                                            <a:da name="MAX" value="7"/>
                                            <a:da name="INVALID" type="XPath">
                                                <a:tst expr="../../../../../RmGeneral/RmCrossbarConfigurable ='true' and (count(node:fallback(./*,1)) = 0)" true="If Rm Enable Crossbar Switch = ON, then at least 1 channel must be configured"/>
                                            </a:da>
                                            <v:ctr name="RmCrossbarHwSlavePort" type="IDENTIFIABLE">
                                                <a:a name="DESC">
                                                        <a:v>
                                                                <![CDATA[EN:<html>
                                                                    Hardware slave port configuration.
                                                                </html>]]>
                                                        </a:v>
                                                </a:a>
                                                <a:a name="UUID" value="ECUC:762d3422-214a-550f-9f1a-61a2630520cf"/>
                                                <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                    <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                                    <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                                </a:a>

                                                <v:var name="RmSlavePortNumber" type="INTEGER">
                                                    <a:a name="DESC">
                                                        <a:v>
                                                            <![CDATA[EN:<html> Vendor specific:
                                                                Slave port number in hardware.
                                                            </html>]]>
                                                        </a:v>
                                                    </a:a>
                                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                        <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                                    </a:a>
                                                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                    <a:a name="ORIGIN" value="NXP"/>
                                                    <a:a name="SCOPE" value="LOCAL"/>
                                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                                    <a:a name="UUID" value="ECUC:b90b7537-4320-4954-81a0-d0c4167fe36e"/>
                                                    <a:da name="DEFAULT" type="XPath"  expr="num:i(num:i(node:fallback(../../../RmCrossbarHwInstance,'AXBS_0') = 'AXBS_0') * ecu:list('Rm.Crossbar.AXBS0.Slave')[position()-1=node:fallback(node:current()/../@index,'0')]
                                                                                            + num:i(node:fallback(../../../RmCrossbarHwInstance,'AXBS_0') = 'AXBS_1') * ecu:list('Rm.Crossbar.AXBS1.Slave')[position()-1=node:fallback(node:current()/../@index,'0')]
                                                                                            )"
                                                                                            />
                                                    <a:a name="LABEL" value="Slave Port Number"/>
                                                    <a:da name="INVALID" type="Range">
                                                        <a:tst expr="&lt;=7"/>
                                                        <a:tst expr="&gt;=0"/>
                                                    </a:da>
                                                    <a:da name="RANGE" type="XPath">
                                                        <a:tst expr="text:uniq(node:fallback( ../../*/RmSlavePortNumber, text:split('0') ), node:fallback( ., 1 )) " false="The slave port number must be unique for the same AXBS instance."/>
                                                        <a:tst expr="(node:fallback(../../../RmCrossbarHwInstance,'AXBS_0') = 'AXBS_0') and (string(node:containsValue(ecu:list('Rm.Crossbar.AXBS0.Slave'),.)) = 'false')"  true="the current slave port number doesn't belong to AXBS0"/>
                                                        <a:tst expr="(node:fallback(../../../RmCrossbarHwInstance,'AXBS_0') = 'AXBS_1') and (string(node:containsValue(ecu:list('Rm.Crossbar.AXBS1.Slave'),.)) = 'false')"  true ="the current slave port number doesn't belong to AXBS1"/>
                                                    </a:da>
                                                </v:var>

                                                <v:var name="RmCrossbarPrioMaster0" type="INTEGER">
                                                    <a:a name="DESC">
                                                        <a:v>
                                                            <![CDATA[EN:<html> Vendor specific:
                                                                Priority of the master 0 on the cross bar.
                                                            </html>]]>
                                                        </a:v>
                                                    </a:a>
                                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                        <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                                    </a:a>
                                                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                    <a:a name="ORIGIN" value="NXP"/>
                                                    <a:a name="SCOPE" value="LOCAL"/>
                                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                                    <a:a name="UUID" value="ECUC:b89b7537-4320-4954-81a0-d0c4167fe36e"/>
