                                                                    <td colspan="2">XRDC_SUPERVISOR_READ_ONLY
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R
                                                                    <td colspan="1">None
                                                                <tr>
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="2">XRDC_NO_ACCESS
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                <tr>
                                                                    <td colspan="2">XRDC_SUPERVISOR_ACCESS_ONLY
                                                                    <td colspan="2">NA
                                                                    <td colspan="1">R,W
