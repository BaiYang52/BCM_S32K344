<d:ctr type="AUTOSAR" factory="autosar"
    xmlns:ad="http://www.tresos.de/_projects/DataModel2/08/admindata.xsd"
    xmlns:icc="http://www.tresos.de/_projects/DataModel2/08/implconfigclass.xsd"
    xmlns:mt="http://www.tresos.de/_projects/DataModel2/11/multitest.xsd" >
    <d:lst type="TOP-LEVEL-PACKAGES">
        <d:ctr name="TS_T40D34M20I1R0" type="AR-PACKAGE">
            <a:a name="UUID" value="ECUC:b29f2c08-0514-4b78-8757-9cd197ea3150"/>
            <d:lst type="ELEMENTS">
                <!-- @implements Rm_Object -->
                <d:chc name="Rm" type="AR-ELEMENT" value="MODULE-DEF">
                    <v:ctr type="MODULE-DEF">
                        <a:a name="RELEASE" value="asc:4.4"/>
                        <a:a name="ADMIN-DATA" type="ADMIN-DATA">
                            <ad:ADMIN-DATA>
                                <ad:DOC-REVISIONS>
                                    <ad:DOC-REVISION>
                                        <ad:REVISION-LABEL>4.6.0</ad:REVISION-LABEL>
                                        <ad:ISSUED-BY>AUTOSAR</ad:ISSUED-BY>
                                        <ad:DATE>2014-10-31</ad:DATE>
                                    </ad:DOC-REVISION>
                                </ad:DOC-REVISIONS>
                            </ad:ADMIN-DATA>
                        </a:a>
                        <a:a name="DESC"
                             value="EN: Vendor specific: Configuration of the Rm (Resource Manager) module."/>
                        <a:a name="POSTBUILDVARIANTSUPPORT" value="true"/>
                        <a:a name="UUID" value="ECUC:b750487e-a7d6-48f5-a05a-d25be733d971"/>
                        <v:var name="POST_BUILD_VARIANT_USED" type="BOOLEAN">
                            <a:a name="DESC"
                                value="Indicates whether a module implementation has or plans to have (i.e., introduced at link or post-build time) new post-build variation points."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="LABEL" value="Post Build Variant Used"/>
                            <a:a name="ORIGIN" value="EB"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                            <a:da name="DEFAULT" value="false"/>
                            <a:da name="TOOLTIP"
                                value="Indicates whether a module implementation has or plans to have (i.e., introduced at link or post-build time) new post-build variation points."/>
                        </v:var>
                        <v:var name="IMPLEMENTATION_CONFIG_VARIANT" type="ENUMERATION">
                            <a:a name="LABEL" value="Config Variant"/>
                            <a:a name="UUID" value="ECUC:22d0e0f2-35f0-4b4c-8241-a27fb18f9ad4"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v class="PreCompile">VariantPostBuild</icc:v>
                                <icc:v class="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="DESC">
                                <a:v>
                                    <![CDATA[EN:<html>
                                        <p>VariantPostBuild: Mix of precompile and postbuild time configuration parameters.<br>
                                        </p>
                                    </html>]]>
                                </a:v>
                            </a:a>
                            <a:da name="DEFAULT" value="VariantPreCompile"/>
                            <a:da name="RANGE">
                                <a:v>VariantPostBuild</a:v>
                                <a:v>VariantPreCompile</a:v>
                            </a:da>
                        </v:var>

                        <v:ctr name="RmGeneral" type="IDENTIFIABLE">
                            <a:a name="DESC" value="EN: Vendor specific: Configuration of general Rm parameters."/>
                            <a:a name="UUID" value="ECUC:967c3e2b-7845-4bc8-848f-e0a6291bf4d0"/>
                            <a:a name="LABEL" value="Rm General Configuration"/>
                            <v:var name="Rm_VersionInfoApi" type="BOOLEAN">
                                <a:a name="DESC" value="EN: Vendor specific: Enables/Disables the get version info API function"/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v class="PreCompile">VariantPostBuild</icc:v>
                                    <icc:v class="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="ECUC:42da3770-7248-47fd-b1a8-8986ca635060"/>
                                <a:da name="DEFAULT" value="true"/>
                            </v:var>

                            <!-- @implements RmDevErrorDetect_Object -->
                            <v:var name="RmDevErrorDetect" type="BOOLEAN">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN: <html> Vendor specific:
                                        <p>Switches the Development Error Detection and Notification on or off.</p>
                                            <ul>
                                                <li>true: Enabled.</li>
                                                <li>false: Disabled.</li>
                                            </ul>
                                        </html>]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="LABEL" value="Rm Development Error Detect"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="ECUC:d8897d9d-1ae0-4020-85fc-70dfeb9f28fe"/>
                                <a:da name="DEFAULT" value="true"/>
                            </v:var>

                            <!-- EnableUserModeSupport -->
                            <!-- @implements RmEnableUserModeSupport_Object -->
                            <v:var name="RmEnableUserModeSupport" type="BOOLEAN">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:<html>
                                            When this parameter is enabled, the RM module will adapt to run from User Mode, with the following measures:<p/>
                                            b) using 'call trusted function' stubs for all internal function calls that access registers requiring supervisor mode.<p/>
                                            for more information, please see chapter 5.7 User Mode Support in IM <p/>
                                            Note: Implementation Specific Parameter.
                                        </html>]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="LABEL" value="Rm Enable User Mode Support"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="ECUC:fdf29f83-dbae-4cd2-abf2-c0941851a05e"/>
                                <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <!-- RmEnableMultiCore -->
                            <v:var name="RmEnableMultiCore" type="BOOLEAN">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:<html>
                                            When this parameter is enabled, the RM module will adapt to run with Multicore:<p/>
                                        </html>]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="LABEL" value="Rm Enable MultiCore Support"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="ECUC:89eea1f4-7523-11e8-adc0-fa7ae54baebc"/>
                                <a:da name="DEFAULT" value="false"/>
                                <a:da name="INVALID" type="XPath">
                                    <a:tst expr="((ecu:get('Rm.MulticoreSupport') = 'false') and (. = 'true'))"
                                           true="Multicore feature is not supported in this derivative."/>
                                    <a:tst expr="((. = 'true') and(./../RmMpuM7Configurable = 'false'))"
                                           true="Multicore feature only support for MPU M7 please enable RM Enable MPU M7 Support"/>
                                </a:da>
                            </v:var>

                            <!-- RmEnableXRDCSupport -->
                            <!-- @implements RmEnableXRDCSupport_Object -->
                            <v:var name="RmEnableXRDCSupport" type="BOOLEAN">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:<html>
                                            When this parameter is enabled, the Xrdc APIs are enabled to the user<p/>
                                        </html>]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="LABEL" value="RM Enable XRDC Support"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="ECUC:89eea1f4-7523-11e8-adc0-fa7ae6c2debc"/>
                                <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <!-- RmEnableSema42Support -->
                            <!-- @implements RmEnableSema42Support_Object -->
                            <v:var name="RmEnableSema42Support" type="BOOLEAN">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:<html>
                                            When this parameter is enabled, the Sema42 APIs are enabled to the user<p/>
                                        </html>]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v class="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v class="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="LABEL" value="RM Enable Sema42 Support"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="ECUC:89eea1f4-7523-11e8-ad22-fa7ae6c2debc"/>
                                <a:da name="DEFAULT" value="false"/>
                                <a:da name="INVALID" type="XPath">
                                    <a:tst expr="((ecu:get('Rm.Sema42Support') = 'false')and (. = 'true'))" true="Sema42 is not supported in this derivative."/>
                                    <a:tst expr="(../../RmGeneral/RmEnableXRDCSupport ='true' and node:value(.) = 'true') or (node:value(.) = 'false')" false="To enable SEMA42 API, XRDC support must be enabled"/>
                                </a:da>
                            </v:var>
                            <!-- RmMpuM7Configurable -->
                            <!-- @implements RmMpuM7Configurable_Object -->
                            <v:var name="RmMpuM7Configurable" type="BOOLEAN">
                                <a:a name="LABEL" value="RM Enable MPU M7 Support"/>
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                        <html>
                                            <p>RmMpuM7Configurable</p>
                                            <p>Check this in order to be able to use the ARM Cortex M7 MPU.</p>
                                            <p></p>Note: Implementation Specific Parameter. <p/>
                                        </html>
                                    ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="UUID" value="ECUC:72a8a638-4009-4639-124a-bb4daf844a8b"/>
                                <a:da name="DEFAULT" value="true"/>
                            </v:var>
                            <!-- RmPflashConfigurable -->
                            <v:var name="RmPflashConfigurable" type="BOOLEAN">
                                <a:a name="LABEL" value="RM Enable Plfash Support"/>
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                        <html>
                                            <p>RmPflashConfigurable</p>
                                            <p>Check this in order to be able to use the Master protection.</p>
                                            <p></p>Note: Implementation Specific Parameter. <p/>
                                        </html>
                                    ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="UUID" value="ECUC:72a8a638-10a9-46b9-114a-bb4daf844a8b"/>
                                <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <v:var name="RmCrossbarConfigurable" type="BOOLEAN">
                                <a:a name="LABEL" value="RM Enable Crossbar Support"/>
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                        <html>
                                            <p>RmCrossbarConfigurable</p>
                                            <p>Check this in order to be able to use the crossbar configuration feature.</p>
                                            <p></p>Note: Implementation Specific Parameter. <p/>
                                        </html>
                                    ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="UUID" value="ECUC:72c8d631-10a9-4639-124a-bb4daf844a8b"/>
                                <a:da name="DEFAULT" value="false"/>
                                <a:da name="INVALID" type="XPath">
                                    <a:tst expr="(. ='true' ) and (ecu:get('Rm.Crossbar.CrossbarSupport') = 'false')" true="Crossbar programming does not support derivative S32K312!"/>
                                </a:da>
                            </v:var>
                            <v:var name="RmXbicConfigurable" type="BOOLEAN">
                                <a:a name="LABEL" value="RM Enable Xbic Support"/>
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                        <html>
                                            <p>RmXbicConfigurable</p>
                                            <p>Check this in order to be able to use XBIC api sets to verify the integrity of crossbar transfers.</p>
                                            <p></p>Note: Implementation Specific Parameter. <p/>
                                        </html>
                                    ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="UUID" value="ECUC:72a8a638-10a9-4619-124f-ba4daf844a8b"/>
                                <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <!-- @implements RmVirtWrapperConfigurable_Object -->
                            <v:var name="RmVirtWrapperConfigurable" type="BOOLEAN">
                                <a:a name="LABEL" value="RM Enable Virtual Wrapper feature"/>
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                        <html>
                                            <p>RmVirtWrapperConfigurable</p>
                                            <p>Check this in order to be able Virtual wrapper feature. This feature need to enable along side with port virtual wrapper feature to ensure collaboration set of pads protection. When virtual wrapper is enable RM driver will automatically ajust configuration for hw protection.</p>
                                            <p></p>Note: Implementation Specific Parameter. <p/>
                                        </html>
                                    ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                </a:a>
                                <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                <a:a name="ORIGIN" value="NXP"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="UUID" value="ECUC:72d8e638-10a9-4639-124a-be4daf844a8b"/>
                                <a:da name="DEFAULT" value="false"/>
                            </v:var>
                        </v:ctr>

                        <v:ctr name="RmConfigSet" type="IDENTIFIABLE">
                            <a:a name="DESC">
                                <a:v><![CDATA[EN: <html> Vendor specific: This container is the base for a multiple configuration set
                                    </html>]]>
                                </a:v>
                            </a:a>
                            <a:a name="UUID" value="ECUC:b825a11b-5f5e-48b6-9c71-0e63b429c3da"/>
                            <v:ctr name="Xrdc_Configuration" type="IDENTIFIABLE">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                            <html><p>Configuration for the Xrdc.</p></html>
                                        ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="UUID" value="ECUC:be68078a-ba7e-4321-b0a2-8097d0117110"/>
                                <a:a name="EDITABLE" type="XPath">
                                    <a:tst expr="../../RmGeneral/RmEnableXRDCSupport ='true'"/>
                                </a:a>

                                <v:var name="XrdcDevErrorDetect" type="BOOLEAN">
                                    <a:a name="LABEL" value="Xrdc Development Error Detection"/>
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:
                                                <html>
                                                    <p>XrdcDevErrorDetect</p>
                                                    <p>Switches the Development Error Detection and Notification ON or OFF.</p>
                                                    Note: Implementation Specific Parameter. <p/>
                                                </html>
                                            ]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                    </a:a>
                                    <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                    <a:a name="ORIGIN" value="NXP"/>
                                    <a:a name="SCOPE" value="LOCAL"/>
                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                    <a:a name="UUID" value="ECUC:7228a335-4003-3381-8e1a-bb3d9f733111"/>
                                    <a:da name="DEFAULT" value="true"/>
                                </v:var>
                                
                                <!--  XrdcRegisterLock -->
                                <v:var name="XrdcRegistersLock" type="BOOLEAN">
                                        <a:a name="LABEL" value="Xrdc Registers Lock"/>
                                        <a:a name="DESC" value="Lock XRDC registers (except PIDm registers) in order to prevent them from being unintentionally modified during Runtime."/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="INVALID" type="XPath">
                                             <a:tst expr="../../../RmGeneral/RmEnableXRDCSupport ='false' and (. ='true')" true=" Please turn on XRDC Support first"/>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                        <a:a name="UUID" value="ECUC:be68078a-ba7e-4321-b0a2-8097d0117120"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:da name="DEFAULT" value="false"/>
                                </v:var>
                                <!--  XrdcPIDRegisterLock -->
                                <v:var name="XrdcPIDRegisterLock" type="ENUMERATION">
                                        <a:a name="DESC" value="Select lock mode for PIDm registers"/>
                                        <a:a name="LABEL" value="Xrdc PID Registers Lock"/>
                                        <a:a name="EDITABLE" type="XPath">
                                            <a:tst expr="../XrdcRegistersLock ='true'"/>
                                        </a:a>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                        <a:a name="UUID" value="ECUC:a9e581b0-9f73-459c-8c1d-690f73a7eb86"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:da name="DEFAULT" value="XRDC_PID_UNLOCKED"/>
                                        <a:da name="RANGE">
                                            <a:v>XRDC_PID_UNLOCKED</a:v>
                                            <a:v>XRDC_PID_ALLOW_ACCESS_FROM_MASTER</a:v>
                                            <a:v>XRDC_PID_FULLY_LOCKED</a:v>
                                        </a:da>
                                </v:var>
                            </v:ctr>

                            <v:lst name="Rm_XRDC_Domain_Assignment" type="MAP">
                                <a:a name="LABEL" value="XRDC Domain Assignment"/>
                                <a:a name="EDITABLE" type="XPath">
                                    <a:tst expr="../../RmGeneral/RmEnableXRDCSupport ='true'"/>
                                </a:a>
                                <a:da name="INVALID" type="XPath">
                                <a:tst expr="../../RmGeneral/RmEnableXRDCSupport ='true' and (num:i(count(*))= 0)"
                                true ="At least one Domain Assignment must be configured when XRDC Support is checked!"/>
                                </a:da>
                                <v:ctr name = "Rm_XRDC_Domain_Assignment" type = "IDENTIFIABLE">
                                    <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:<html>
                                                    All data need to configure one Domain.
                                                </html>]]>
                                            </a:v>
                                    </a:a>
                                    <a:a name="UUID" value="ECUC:b31e0234-6514-405b-8738-1b767c971884"/>
                                    <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                    </a:a>


                                    <v:var name= "DomainID" type="ENUMERATION">
                                        <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:<html> Vendor specific:
                                                    Id for the current Domain.
                                                    Note: Implementation Specific Parameter.
                                                </html>]]>
                                            </a:v>
                                        </a:a>
                                        <a:a name="UUID" value="ECUC:b40023f0-dc5c-4198-bc4d-ab27cb37c4b3"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                            <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                        </a:a>
                                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                        <a:a name="ORIGIN" value="NXP"/>
                                        <a:da name="DEFAULT" type="XPath" expr="(ecu:list('Rm.XRDC.DomainID'))[position()-1=node:fallback(node:current()/../@index,'0')]"/>
                                        <a:da name="INVALID" type="XPath">
                                            <a:tst expr="text:uniq(../../*/DomainID, .)" false="Duplicate Domain ID!"/>
                                        </a:da>
                                        <a:da name="RANGE" type="XPath" expr="ecu:list('Rm.XRDC.DomainID')"/>
                                    </v:var>

                                    <v:lst name="Domain_Master_Assignment" type="MAP">
                                        <a:da name="INVALID" type="XPath">
                                            <a:tst expr="../../../../RmGeneral/RmEnableXRDCSupport ='true' and (num:i(count(*))= 0)"
                                                true ="At least one Domain Master Assignment must be configured when XRDC Support is checked!"/>
                                        </a:da>
                                        <v:ctr name="Domain_Master_Assignment" type="IDENTIFIABLE">
                                        <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:<html> Vendor specific:
                                                    All data need to configure one Master.
                                                </html>]]>
                                            </a:v>
                                        </a:a>
                                        <a:a name="UUID" value="ECUC:06a24c3a-e58b-4721-b07c-b37e842ffc31"/>
                                        <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                        </a:a>

                                        <v:var name="XrdcMasterInstance" type="ENUMERATION">
                                            <a:a name="DESC" value="Select the master of XRDC"/>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="LABEL" value="Xrdc Master Instance"/>
                                            <a:a name="UUID" value="ECUC:d14a0579-15b2-43e7-b7b0-f625d5b04b6a"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:da name="DEFAULT" type="XPath" expr="ecu:list('Rm.XRDC.Master.List')[position()-1=node:fallback(node:current()/../@index,'0')]">
                                            </a:da>
                                            <a:da name="RANGE" type ="XPath" expr= "ecu:list('Rm.XRDC.Master.List')"/>
                                        </v:var>

                                        <v:var name="XrdcPIDEnable" type="ENUMERATION">
                                            <a:a name="DESC" value="PID mode enable - only valid if the master instance is core type"/>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="LABEL" value="Xrdc PID Enable"/>
                                            <a:a name="UUID" value="ECUC:a9e581b0-9f73-459c-8c1d-690f73a7eb75"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="EDITABLE" type="XPath">
                                                <a:tst expr="contains(ecu:list('Rm.XRDC.CoreMaster.List'),../XrdcMasterInstance)"/>
                                            </a:a>
                                            <a:da name="DEFAULT" value="XRDC_MDA_PID_DISABLE"/>
                                            <a:da name="RANGE">
                                                <a:v>XRDC_MDA_PID_DISABLE</a:v>
                                                <a:v>XRDC_MDA_PID_ENABLE_EXPRESSION0</a:v>
                                                <a:v>XRDC_MDA_PID_ENABLE_EXPRESSION1</a:v>
                                            </a:da>
                                        </v:var>

                                        <v:var name="XrdcMasterPID" type="INTEGER">
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="LABEL" value="Xrdc Master PID"/>
                                            <a:a name="UUID" value="ECUC:bac8d865-f024-4b85-91fe-8ac2fc9c013b"/>
                                            <a:a name="DESC" value="Process Identifier. This field only has meaning if the core is core master type and PID mode enable"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="EDITABLE" type="XPath">
                                                <a:tst expr="contains(ecu:list('Rm.XRDC.CoreMaster.List'),../XrdcMasterInstance)"/>
                                                <a:tst expr="node:fallback(../XrdcPIDEnable, 'XRDC_MDA_PID_DISABLE') != 'XRDC_MDA_PID_DISABLE'"/>
                                            </a:a>
                                            <a:da name="DEFAULT" value="0"/>
                                            <a:da name="INVALID" type="Range">
                                                <a:tst expr="&lt;=63"/>
                                                <a:tst expr="&gt;=0"/>
                                            </a:da>
                                        </v:var>

                                        <v:var name="XrdcMasterPIDMask" type="INTEGER">
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="LABEL" value="Xrdc Master PID Mask"/>
                                            <a:a name="UUID" value="ECUC:e88bd573-7b89-4b20-a2ff-2fc64f403934"/>
                                            <a:a name="DESC" value="Process Identifier Mask. This field only has meaning if the core is core master type and PID mode enable"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:da name="DEFAULT" value="0"/>
                                            <a:a name="EDITABLE" type="XPath">
                                                <a:tst expr="contains(ecu:list('Rm.XRDC.CoreMaster.List'),../XrdcMasterInstance)"/>
                                                <a:tst expr="node:fallback(../XrdcPIDEnable, 'XRDC_MDA_PID_DISABLE') != 'XRDC_MDA_PID_DISABLE'"/>
                                            </a:a>
                                            <a:da name="INVALID" type="Range">
                                                <a:tst expr="&lt;=63"/>
                                                <a:tst expr="&gt;=0"/>
                                            </a:da>
                                        </v:var>
                                        <v:var name="XrdcDIDBDisable" type="BOOLEAN">
                                            <a:a name="DESC" value="Disabled DID bypass. This field only has meaning if the core is non-core master type"/>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="EDITABLE" type="XPath">
                                                <a:tst expr="contains(ecu:list('Rm.XRDC.CoreMaster.List'),node:value(../XrdcMasterInstance))!= 'true'"/>
                                            </a:a>
                                            <a:a name="LABEL" value="Xrdc Disable DID Bypass"/>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="UUID" value="ECUC:05f32b7b-873c-4678-9559-c9919f90de4d"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:da name="DEFAULT" value="false"/>
                                        </v:var>

                                        <v:var name="XrdcMasterMode" type="ENUMERATION">
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                <a:a name="LABEL" value="Xrdc Master Secure Mode"/>
                                                <a:a name="UUID" value="ECUC:c2e0a120-1957-4b8c-84b8-7db4ffddd3c1"/>
                                                <a:a name="DESC" value="Specifies the secure attribute. This field only has meaning if the core is non-core master type"/>
                                                <a:a name="ORIGIN" value="NXP"/>
                                            <a:da name="DEFAULT" value="XRDC_SECURE"/>
                                            <a:a name="EDITABLE" type="XPath">
                                                <a:tst expr="contains(ecu:list('Rm.XRDC.CoreMaster.List'),node:value(../XrdcMasterInstance))!= 'true'"/>
                                            </a:a>
                                            <a:da name="RANGE">
                                                <a:v>XRDC_SECURE</a:v>
                                                <a:v>XRDC_NON_SECURE</a:v>
                                                <a:v>XRDC_INPUT_FROM_BUS_MASTER</a:v>
                                            </a:da>
                                        </v:var>

                                        <v:var name="XrdcMasterPriviledgeMode" type="ENUMERATION">
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="LABEL" value="Xrdc Master Privileged Mode"/>
                                            <a:a name="UUID" value="ECUC:c2e0a221-195b-4b8c-84b8-7db4ffddd3c1"/>
                                            <a:a name="DESC" value="Specifies the privileged (supervisor/user) attribute. This field only has meaning if the core is non-core master type"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:da name="DEFAULT" value="XRDC_INPUT_PRIVILEDGE_FROM_BUS_MASTER"/>
                                            <a:a name="EDITABLE" type="XPath">
                                                <a:tst expr="contains(ecu:list('Rm.XRDC.CoreMaster.List'),node:value(../XrdcMasterInstance))!= 'true'"/>
                                            </a:a>
                                            <a:da name="RANGE">
                                                <a:v>XRDC_USER_MODE</a:v>
                                                <a:v>XRDC_PRIVILEDGE_MODE</a:v>
                                                <a:v>XRDC_INPUT_PRIVILEDGE_FROM_BUS_MASTER</a:v>
                                            </a:da>
                                        </v:var>
                                        </v:ctr>
                                    </v:lst>

                                    <v:lst name="Domain_Peripheral_Assignment" type="MAP">
                                        <a:da name="INVALID" type="XPath">
                                            <a:tst expr="../../../../RmGeneral/RmEnableXRDCSupport ='true' and (num:i(count(*))= 0)"
                                                    true ="At least one Domain Peripheral Assignment must be configured when XRDC Support is checked!"/>
                                        </a:da>
                                        <v:ctr name="Domain_Peripheral_Assignment" type="IDENTIFIABLE">
                                            <a:a name="DESC">
                                                    <a:v>
                                                        <![CDATA[EN:<html> Vendor specific:
                                                            All data need to configure Peripheral for one Domain.
                                                        </html>]]>
                                                    </a:v>
                                            </a:a>
                                            <a:a name="UUID" value="ECUC:b4cee1d0-5729-4ce8-81da-1a0a1d009ee9"/>
                                            <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                            </a:a>

                                            <v:ref name="Domain_Peripheral_Assignment" type="REFERENCE">
                                                <a:a name="DESC">
                                                    <a:v>
                                                        <![CDATA[EN:<html> Vendor specific:
                                                            Reference to Peripheral config.
                                                        </html>]]>
                                                    </a:v>
                                                </a:a>
                                                <a:a name="UUID" value="ECUC:a8bc95ac-246d-4fb3-aaff-f702ed529ee5"/>
                                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                        <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                                </a:a>
                                                <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                <a:a name="ORIGIN" value="NXP"/>
                                                    <a:da name="REF"
                                                    value="ASPathDataOfSchema:/TS_T40D34M20I1R0/Rm/RmConfigSet/Rm_XRDC_Peripheral_Config"/>
                                                <a:da name="INVALID" type="XPath">
                                                    <a:tst expr="node:refexists(concat('./../../../../../Rm_XRDC_Peripheral_Config/', substring-after(node:value(.), 'RmConfigSet/')))" false = "Rm XRDC Peripheral Config does not contain this node"/>
                                                </a:da>
                                                <a:da name="WARNING" type="XPath">
                                                    <a:tst expr="text:uniq(./../../../../*/Domain_Peripheral_Assignment/*/Domain_Peripheral_Assignment,.)" false = "A peripheral might appear in multiple domains"/>
                                                </a:da>
                                            </v:ref>

                                            <v:var name="Secure_Access_Policy" type="ENUMERATION">
                                                <a:a name="DESC">
                                                    <a:v>
                                                        <![CDATA[EN:<html> Vendor specific:
                                                            Mode access to policy of mode Secure.
                                                            Access policy look up table:
                                                            <table>
                                                                <tr>
                                                                    <th colspan="4"><b>Configuration Fields</b>
                                                                    <th colspan="4"><b>Allowable accesses</b>
                                                                <tr>
                                                                    <td colspan="2"><b>Secure_Access_Policy</b>
                                                                    <td colspan="2"><b>Non_Secure_Access_Policy</b>
                                                                    <td colspan="1"><b>Secure Privileged</b>
                                                                    <td colspan="1"><b>Secure User</b>
                                                                    <td colspan="1"><b>NonSecure Privileged</b>
                                                                    <td colspan="1"><b>NonSecure User</b>
                                                                <tr>
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                <tr>
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="2">XRDC_SUPERVISOR_ACCESS_ONLY
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">None
                                                                <tr>
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="2">XRDC_READ_ONLY
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R
                                                                    <td colspan="1">R
                                                                <tr>
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="2">XRDC_SUPERVISOR_READ_ONLY
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R
                                                                    <td colspan="1">None
                                                                <tr>
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="2">XRDC_NO_ACCESS
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                <tr>
                                                                    <td colspan="2">XRDC_SUPERVISOR_ACCESS_ONLY
                                                                    <td colspan="2">NA
                                                                    <td colspan="1">R,W
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                <tr>
                                                                    <td colspan="2">XRDC_READ_ONLY
                                                                    <td colspan="2">NA
                                                                    <td colspan="1">R
                                                                    <td colspan="1">R
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                <tr>
                                                                    <td colspan="2">XRDC_NO_ACCESS
                                                                    <td colspan="2">NA
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                            </table>
                                                        </html>]]>
                                                    </a:v>
                                                </a:a>
                                                <a:a name="UUID" value="ECUC:3baaaf5c-9ab4-42e9-89ab-99bc301693da"/>
                                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                        <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                                </a:a>
                                                <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                <a:a name="ORIGIN" value="NXP"/>
                                                <a:da name="DEFAULT" value="XRDC_FULL_ACCESS"/>
                                                <a:da name="RANGE">
                                                    <a:v>XRDC_FULL_ACCESS</a:v>
                                                    <a:v>XRDC_READ_ONLY</a:v>
                                                    <a:v>XRDC_SUPERVISOR_ACCESS_ONLY</a:v>
                                                    <a:v>XRDC_NO_ACCESS</a:v>
                                                </a:da>
                                            </v:var>

                                            <v:var name="Non_Secure_Access_Policy" type="ENUMERATION">
                                                <a:a name="DESC">
                                                    <a:v>
                                                        <![CDATA[EN:<html> Vendor specific:
                                                            Mode access to policy of mode Non_Secure.
                                                            Access policy look up table:
                                                            <table>
                                                                <tr>
                                                                    <th colspan="4"><b>Configuration Fields</b>
                                                                    <th colspan="4"><b>Allowable accesses</b>
                                                                <tr>
                                                                    <td colspan="2"><b>Secure_Access_Policy</b>
                                                                    <td colspan="2"><b>Non_Secure_Access_Policy</b>
                                                                    <td colspan="1"><b>Secure Privileged</b>
                                                                    <td colspan="1"><b>Secure User</b>
                                                                    <td colspan="1"><b>NonSecure Privileged</b>
                                                                    <td colspan="1"><b>NonSecure User</b>
                                                                <tr>
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="2">XRDC_FULL_ACCESS
                                                                    <td colspan="1">R,W
