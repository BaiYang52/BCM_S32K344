                                                    <a:a name="DEFAULT_RADIX" value="HEX"/>
                                                    <a:da name="INVALID" type="XPath">
                                                        <a:tst expr="num:i(num:i(node:fallback(node:current()/../EndAddress, num:i(0))) - num:i(node:fallback(node:current()/../StartAddress, num:i(0))) + num:i(1)) = num:i(node:value(.))" false="Please recalculate value"/>
                                                        <a:tst expr="(num:i(node:fallback(node:current()/../StartAddress, num:i(0))) mod num:i(node:value(.))) = 0" false="The StartAddress is aligned to the size of the region. For example, a 64KB region must be aligned on a multiple of 64KB, for example, at 0x00010000 or 0x00020000"/>
