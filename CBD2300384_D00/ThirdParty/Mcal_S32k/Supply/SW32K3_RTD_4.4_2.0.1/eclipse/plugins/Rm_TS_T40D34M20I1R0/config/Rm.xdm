                                                    <a:a name="SCOPE" value="LOCAL"/>
                                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                                    <a:a name="UUID" value="ECUC:72d30c3d-9311-41a6-ba35-40021a249a79"/>
                                                    <a:da name="DEFAULT" value="false"/>
                                                    <a:da name="EDITABLE" type="XPath">
                                                        <a:tst expr="num:i(num:i(../../../RmCrossbarHwInstance = 'AXBS_0') * num:i(node:containsValue(ecu:list('Rm.Crossbar.AXBS0.Masters'),concat('Master',substring-after(node:name(.),'RmCrossbarEnablePrioElevM'))))
