                                                                <tr>
                                                                    <td colspan="2">XRDC_NO_ACCESS
                                                                    <td colspan="2">NA
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
                                                                    <td colspan="1">None
