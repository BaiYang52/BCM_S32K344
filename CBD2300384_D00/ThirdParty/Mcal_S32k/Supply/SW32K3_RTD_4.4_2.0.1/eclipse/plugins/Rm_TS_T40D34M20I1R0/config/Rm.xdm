                            <v:ctr name="Virt_Wrapper_Configuration" type="IDENTIFIABLE">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                            <html><p>Configuration for the "Virtual Wrapper.</p></html>
                                        ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="TAB" value="Virtual Wrapper"/>
                                <a:a name="UUID" value="ECUC:c2ef9c2c-20a9-47f5-9016-d1781580e15b"/>
                                <!--  VirtWrapperDevErrorDetect -->
                                <v:var name="VirtWrapperDevErrorDetect" type="BOOLEAN">
                                    <a:a name="LABEL" value="Virtual Wrapper Development Error Detection"/>
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:
                                                <html>
                                                    <p>VirtWrapperDevErrorDetect</p>
                                                    <p>Switches the Development Error Detection and Notification ON or OFF.</p>
                                                    Note: Implementation Specific Parameter. <p/>
                                                </html>
                                            ]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                    </a:a>
                                    <a:a name="POSTBUILDVARIANTVALUE" value="false"/>
                                    <a:a name="ORIGIN" value="NXP"/>
                                    <a:a name="SCOPE" value="LOCAL"/>
                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                    <a:a name="UUID" value="ECUC:69bae456-b90d-450b-ba31-ccc4f42e2ae2"/>
                                    <a:da name="DEFAULT" value="true"/>
                                </v:var>
                                <v:lst name="Mscr_Config_List" type="MAP">
                                    <a:a name="TAB" value="Virtual Wrapper"/>
                                    <a:da name="MIN" type="XPath" expr="num:i(count(ecu:list('Rm.VirtWrapper.MscrNames.List')))"/>
                                    <a:da name="MAX" type="XPath" expr="num:i(count(ecu:list('Rm.VirtWrapper.MscrNames.List')))"/>
                                    <a:a name="LABEL" value="Output Muxing Registers Assignment"/>
                                    <a:a name="ENABLE" type="XPath">
                                        <a:tst expr="../../../RmGeneral/RmVirtWrapperConfigurable = 'true'"/>
                                    </a:a>
                                    <v:ctr name="Mscr_Config_List" type="IDENTIFIABLE">
                                        <a:a name="DESC">
