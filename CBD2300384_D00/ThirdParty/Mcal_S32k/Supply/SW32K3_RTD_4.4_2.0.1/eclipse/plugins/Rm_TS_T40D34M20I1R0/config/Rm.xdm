                                                </v:var>

                                                <v:var name="RmCrossbarEnableFixedPrio" type="BOOLEAN">
                                                    <a:a name="DESC">
                                                    <a:v><![CDATA[EN:<html>Vendor specific: <p> On this slave port, select the arbitraion mode: if enabled the arbitration mode will be FIXED PRIORITY, if disabled it will be ROUND ROBIN.</p></html>]]></a:v>
                                                    </a:a>
                                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                        <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                                    </a:a>
                                                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                    <a:a name="LABEL" value="Enable Fixed Priority Arbitration"/>
                                                    <a:a name="ORIGIN" value="NXP"/>
                                                    <a:a name="SCOPE" value="LOCAL"/>
                                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                                    <a:a name="UUID" value="ECUC:72d30d3d-9311-41a6-ba35-40021a249a75"/>
                                                    <a:da name="DEFAULT" value="false"/>
                                                </v:var>

                                                <v:var name="RmCrossbarParkingControl" type="ENUMERATION">
                                                    <a:a name="LABEL" value="Parking Control"/>
                                                    <a:a name="DESC">
                                                        <a:v>
                                                            <![CDATA[EN:
                                                            <html>
                                                            Determines the slave port’s parking control. The low-power park feature results in an overall power
                                                            savings if the slave port is not saturated; however, this forces an extra latency clock when any master tries
                                                            to access the slave port while not in use because it is not parked on any master.
                                                            </p></html>
                                                            ]]>
                                                        </a:v>
                                                    </a:a>
                                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                        <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                                    </a:a>
                                                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                    <a:a name="SCOPE" value="LOCAL"/>
                                                    <a:a name="ORIGIN" value="NXP"/>
                                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                                    <a:a name="UUID" value="ECUC:2e702c03-9a34-407f-9476-e14c2d713c75"/>
                                                    <a:da name="DEFAULT" value="ParkField"/>
                                                    <a:da name="RANGE">
                                                        <a:v>ParkField</a:v>
                                                        <a:v>LastMaster</a:v>
                                                        <a:v>LowPowerPark</a:v>
                                                    </a:da>
                                                </v:var>

                                                <v:var name="RmCrossbarParkField" type="ENUMERATION">
                                                    <a:a name="DESC">
                                                        <a:v>
                                                            <![CDATA[EN:<html> Vendor specific:
                                                            Determines which master port the current slave port parks on when no masters are actively making requests and the RmCrossbarParkingControl=ParkField.
                                                            </html>]]>
                                                        </a:v>
                                                    </a:a>
                                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                        <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                                    </a:a>
                                                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                                    <a:a name="EDITABLE" type="XPath">
                                                        <a:tst expr="(node:fallback(../RmCrossbarParkingControl, 'ParkField') = 'ParkField') = 'true'"/>
                                                    </a:a>
                                                    <a:a name="ORIGIN" value="NXP"/>
                                                    <a:a name="LABEL" value="Park field"/>
                                                    <a:a name="SCOPE" value="LOCAL"/>
                                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                                    <a:a name="UUID" value="ECUC:0aaa248e-f32e-45b6-97be-442ca32a5726"/>
                                                    <a:da name="DEFAULT" type="XPath" expr="(ecu:list('Rm.Crossbar.CrossbarMasters'))[position()-1=node:fallback(node:current()/../@index,'0')]"/>
                                                    <a:da name="RANGE" type="XPath">
                                                    <a:tst expr="ecu:list('Rm.Crossbar.CrossbarMasters')"/>
                                                    </a:da>
                                                    <a:da name="INVALID" type="XPath">
                                                        <a:tst expr="(node:fallback(../../../RmCrossbarHwInstance,'AXBS_0') = 'AXBS_0') and (string(node:containsValue(ecu:list('Rm.Crossbar.AXBS0.Masters'),.)) = 'false')"  true="the current master port doesn't belong to AXBS0"/>
                                                        <a:tst expr="(node:fallback(../../../RmCrossbarHwInstance,'AXBS_0') = 'AXBS_1') and (string(node:containsValue(ecu:list('Rm.Crossbar.AXBS1.Masters'),.)) = 'false')"  true ="the current master port doesn't belong to AXBS1"/>
                                                    </a:da>
                                                </v:var>
                                            </v:ctr>
                                        </v:lst>
                                    </v:ctr>
                                </v:lst> <!--crossbar-->
                            </v:ctr>  <!--crossbar-->

                            <v:ctr name="Xbic_Configuration" type="IDENTIFIABLE">
                                <a:a name="DESC">
                                    <a:v>
                                        <![CDATA[EN:
                                            <html><p>Configuration for the Xbic.</p></html>
                                        ]]>
                                    </a:v>
                                </a:a>
                                <a:a name="UUID" value="ECUC:be68078a-ba7e-4321-b0a2-8097d0115141"/>
                                <a:a name="TAB" value="Xbic"/>
                                <v:var name="XbicDevErrorDetect" type="BOOLEAN">
                                    <a:a name="LABEL" value="Xbic Development Error Detection"/>
                                    <a:a name="DESC">
                                        <a:v>
                                            <![CDATA[EN:
                                                <html>
                                                    <p>XbicDevErrorDetect</p>
                                                    <p>Switches the Development Error Detection and Notification ON or OFF.</p>
                                                    Note: Implementation Specific Parameter. <p/>
                                                </html>
                                            ]]>
                                        </a:v>
                                    </a:a>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                                    </a:a>
                                    <a:a name="ORIGIN" value="NXP"/>
                                    <a:a name="SCOPE" value="LOCAL"/>
                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                    <a:a name="UUID" value="ECUC:7228a335-4003-8881-8e1a-bb3d9f731140"/>
                                    <a:da name="DEFAULT" value="true"/>
                                </v:var>
                                <v:lst name="XbicCheckingControl" type="MAP">
                                    <a:da name="EDITABLE" type="XPath" expr="node:fallback( node:current()/../../../RmGeneral/RmXbicConfigurable, num:i(0))" />
                                    <a:da name="MIN" value="0"/>
                                    <a:da name="MAX" type="XPath" expr="ecu:list('Rm.Xbic.XbicInstances.Count')"/>
                                    <a:a name="TAB" value="Xbic"/>
                                    <v:ctr name="XbicCheckingControl" type="IDENTIFIABLE">
                                        <a:a name="POSTBUILDVARIANTMULTIPLICITY" value="false"/>
                                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                            <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                        </a:a>
                                        <a:a name="LABEL" value="Xbic Checking Control"/>
                                        <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:
                                                    <html>
                                                        <p>Xbic Checking Control</p>
                                                        <p>Configuration enable/disable slave port EDC Error Detection (SE) and master port for Feedback Integrity Check (ME) of all of Xbic Instances.</p>
                                                        Note: Any SE and ME that are not configured will be enabled by default <p/>
                                                    </html>
                                                ]]>
                                            </a:v>
                                        </a:a>
                                        <a:a name="UUID" value="ECUC:7228a235-4103-858a-8e1a-bb3d9f731234"/>
                                        <v:var name="XbicInstance" type="ENUMERATION">
                                            <a:a name="DESC">
                                            <a:v>
                                                <![CDATA[EN:
                                                    <html>
                                                        <p>Select Xbic instance</p>
                                                    </html>
                                                ]]>
                                            </a:v>
                                            </a:a>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                                            </a:a>
                                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                                            <a:a name="ORIGIN" value="NXP"/>
                                            <a:a name="SCOPE" value="LOCAL"/>
                                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                            <a:a name="UUID" value="ECUC:7228a335-4003-8881-8e1a-bb3d9f7235"/>
                                            <a:da name="RANGE" type="XPath" expr="(ecu:list('Rm.Xbic.XbicInstances.List'))"/>
                                            <a:da name="DEFAULT" type="XPath" expr="(ecu:list('Rm.Xbic.XbicInstances.List'))[position()-1=node:fallback(node:current()/../@index,'0')]"/>
                                            <a:da name="INVALID" type="XPath">
                                                <a:tst expr="text:uniq(../../*/XbicInstance, .)" false="Duplicate XbicInstance!"/>
                                            </a:da>
                                        </v:var>
                                        <v:var name="SE0" type="BOOLEAN">
                                            <a:a name="LABEL" value="SE0"/>
                                            <a:a name="EDITABLE" type="XPath">
                                                <a:tst expr="contains(ecu:list(text:replace('Rm.Xbic.Temp.SlaveList','Temp',text:concat('XbicInstance',substring-after(../XbicInstance, 'XBIC_')))),substring-after(node:name(.), 'SE')) ='true'"/>
                                            </a:a>
                                            <a:a name="DESC" value="Enable/Disable Attribute integrity checking for slave port"/>
                                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
